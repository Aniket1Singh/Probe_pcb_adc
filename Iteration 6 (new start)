/* ================================================================== */
/*  OUTPUT LINE  —  8 columns exactly as specified                    */
/*                                                                     */
/*  [1] RefR       : Reference_Set_Value (integer, the stored ref)    */
/*  [2] EMF        : raw EMF in mV, 3 decimal places                  */
/*  [3] DispPPM    : S_ppm = max(Q,R) as integer                      */
/*  [4] Type       : "F" if Q>=R (fast dominant), "A" if R>Q          */
/*  [5] H2_Flag    : "AIR" | "UP" | "DOWN" | "REC"                    */
/*  [6] Rec_Pct    : recovery % 0-100 integer                         */
/*  [7] OR_Status  : "NORMAL"|"OVERRANGE"|"WAIT_DROP"|"PRESS_TARE"    */
/*  [8] Warmup     : 0=Init 1=Unstable 2=ProxFail 3=WaitTare 4=Done  */
/* ================================================================== */
static void tx_output_line(float emf_mv) {
    /* Col 1: RefR = Reference_Set_Value */
    USART1_sendLong((long)Reference_Set_Value);
    USART1_sendChar(' ');

    /* Col 2: EMF in mV, 3 decimal places */
    USART1_sendFloat(emf_mv, 3);
    USART1_sendChar(' ');

    /* Col 3: DispPPM = S = max(Q,R); zero during warmup / blanking */
    {
        long disp_ppm = 0;
        bool is_running_phase = (warmup_phase == WARMUP_RUNNING);
        bool in_or = (or_state != OR_NORMAL);
        if (is_running_phase && !in_or)
            disp_ppm = S_ppm;
        USART1_sendLong(disp_ppm);
    }
    USART1_sendChar(' ');

    /* Col 4: Type — "F" if Q>=R, "A" if R>Q */
    USART1_sendChar((Q_ppm >= R_ppm) ? 'F' : 'A');
    USART1_sendChar(' ');

    /* Col 5: H2_Flag
       AIR state splits into two sub-states (mirrors Python _update_ready_box):
         AIR_L  — daughter near mother (|daughter - mother| <= DMP): LOW LEAKS, clean baseline
         AIR_H  — daughter far from mother: HIGH LEAKS / baseline drifted
       All other states are unchanged: UP / DOWN / REC.
       While gated (OR or warmup not done) we still output AIR_L / AIR_H
       so the operator can see baseline quality during warmup.            */
    {
        const char *flag;
        bool in_or = (or_state != OR_NORMAL);
        bool near  = (fabsf(daughter_baseline - mother_baseline) <= P.daughter_mother_prox);

        if (in_or || warmup_phase != WARMUP_RUNNING) {
            /* Gated — show leak status anyway so warmup quality is visible */
            flag = near ? "AIR_L" : "AIR_H";
        } else if (II == 1.0f) {
            flag = "UP";
        } else if (II == -1.0f && II_prev == 1.0f) {
            flag = "DOWN";
        } else if (II == -1.0f && rec_pct < 100.0f) {
            flag = "REC";
        } else {
            /* Full recovery / baseline — report leak quality */
            flag = near ? "AIR_L" : "AIR_H";
        }
        USART1_sendStr(flag);
    }
    USART1_sendChar(' ');

    /* Col 6: Rec_Pct 0-100 integer */
    {
        uint8_t rp = (uint8_t)(rec_pct + 0.5f);
        if (rp > 100) rp = 100;
        USART1_sendUInt(rp);
    }
    USART1_sendChar(' ');

    /* Col 7: OR_Status */
    {
        const char *ors;
        switch (or_state) {
            case OR_OVERRANGE: ors = "OVERRANGE";  break;
            case OR_WAIT_DROP: ors = "WAIT_DROP";  break;
            case OR_STABLE:    ors = "PRESS_TARE"; break;
            default:           ors = "NORMAL";     break;
        }
        USART1_sendStr(ors);
    }
    USART1_sendChar(' ');

    /* Col 8: Warmup_Status
       0 = Init (sample_count < warmup, first-time wait)
       1 = Unstable / high SD (SD too high, waiting)
       2 = Prox Fail (SD ok but too far from prev MB)
       3 = Stable / Wait Tare (ready_for_tare)
       4 = Done (running)                                              */
    {
        uint8_t ws;
        if (warmup_phase == WARMUP_RUNNING) {
            ws = 4;
        } else if (warmup_phase == WARMUP_READY_TARE) {
            ws = 3;
        } else if (warmup_phase == WARMUP_PROX_FAIL) {
            ws = 2;
        } else {
            /* WARMUP_WAITING */
            ws = ((uint32_t)sample_count < (uint32_t)P.warmup) ? 0 : 1;
        }
        USART1_sendUInt(ws);
    }

    USART1_sendChar(0x0D); USART1_sendChar(0x0A);
}

/* ================================================================== */
/*  RUN MODE                                                           */
/* ================================================================== */
void run_mode(void) {
    while (1) {
        if (cmd_ready) {
            cmd_ready = false;
            process_cmd();
        }
        if (!is_running) continue;

        read_sensor();

        /* emf_mv = (raw_mV - Reference_Set_Value) / 1000  — matches V2 */
        float raw_mv_f  = sensor_final_output;
        float delta_f   = raw_mv_f - (float)Reference_Set_Value;
        float emf_mv    = delta_f / 1000.0f;

        engine_step(emf_mv);

        USART1_sendChar(0x0A);
        tx_output_line(emf_mv);
    }
}

/* ================================================================== */
/*  MAIN                                                               */
/* ================================================================== */
int main(void) {
    PORTA_DIR    = 0xFF;
    PORTA_OUTSET = ADC_RESET;
    PORTB_DIR    = 0xFF;
    _delay_ms(500);

    InitI2C();
    USART1_init();
    _delay_ms(100);

    timer_init();
    sei();

    limit = (unsigned int)mem_read(6);
    _delay_ms(20);

    Reference_Set_Value = mem_read(220);
    if (Reference_Set_Value > 2000000) Reference_Set_Value = 0;

    offset_value = mem_read(150);
    if (offset_value > 100) offset_value = 30;

    /* Load both calibration tables from EEPROM */
    calib_load(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST, CALIB_FAST_DEFAULT);
    calib_load(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN,   CALIB_AN_DEFAULT);

    /* Load stored mother_baseline (for warmup proximity check) */
    mb_ee_load();

    USART1_sendStr("MNST\r\n");
    USART1_sendStr("T5-H2-V2.9.9k READY\r\n");
    USART1_sendStr("Send *start# to begin.\r\n");
    USART1_sendStr("Cmds: *SET *CAL *TEAR *IGNORE_PROX *GET PARAMS *RF *T *SET CAL *SET ANCAL\r\n");

    setInputMultiplexer(ADS122C04_MUX_AIN1_AIN0);
    setGain(ADS122C04_GAIN_1);
    enablePGA(ADS122C04_PGA_DISABLED);
    setDataRate(ADS122C04_DATA_RATE_175SPS);
    setOperatingMode(ADS122C04_OP_MODE_NORMAL);
    setConversionMode(ADS122C04_CONVERSION_MODE_SINGLE_SHOT);
    setVoltageReference(ADS122C04_VREF_INTERNAL);
    enableInternalTempSensor(ADS122C04_TEMP_SENSOR_OFF);
    setDataCounter(ADS122C04_DCNT_DISABLE);
    setDataIntegrityCheck(ADS122C04_CRC_DISABLED);
    setBurnOutCurrent(ADS122C04_BURN_OUT_CURRENT_OFF);
    setIDACcurrent(ADS122C04_IDAC_CURRENT_OFF);
    setIDAC1mux(ADS122C04_IDAC1_DISABLED);
    setIDAC2mux(ADS122C04_IDAC2_DISABLED);
    _delay_ms(5);

    uint8_t rb0 = 0, rb1 = 0;
    ADS122C04_readReg(ADS122C04_CONFIG_0_REG, &rb0);
    ADS122C04_readReg(ADS122C04_CONFIG_1_REG, &rb1);
    diag_dr   = (rb1 >> 5) & 0x07;
    diag_pga  = rb0 & 0x01;
    diag_gain = (rb0 >> 1) & 0x07;
    set_sample_timing(diag_dr);

    reset();
    _delay_ms(2);
    setDataRate(ADS122C04_Reg.reg1.bit.DR);

    run_mode();
}
