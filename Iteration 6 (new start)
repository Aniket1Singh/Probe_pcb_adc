void set_sample_timing(uint8_t dr) {
    switch(dr) {
        case ADS122C04_DATA_RATE_20SPS:   inter_sample_ms=50;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_45SPS:   inter_sample_ms=22;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_90SPS:   inter_sample_ms=44;  drdy_timeout_ms=44;  break;
        case ADS122C04_DATA_RATE_175SPS:  inter_sample_ms=30;  drdy_timeout_ms=36;  break;
        case ADS122C04_DATA_RATE_330SPS:  inter_sample_ms=12;  drdy_timeout_ms=18;  break;
        case ADS122C04_DATA_RATE_600SPS:  inter_sample_ms=8;   drdy_timeout_ms=12;  break;
        case ADS122C04_DATA_RATE_1000SPS: inter_sample_ms=4;   drdy_timeout_ms=8;   break;
        default:                          inter_sample_ms=50;  drdy_timeout_ms=75;  break;
    }
}
void filter_raw_sensor(void) {
    if (sensor_final_output >= pub_adc_value) {
        diff_adc_value = sensor_final_output - pub_adc_value;
        if (diff_adc_value > (float)limit) pub_adc_value = sensor_final_output;
        else                               sensor_final_output = pub_adc_value;
    } else {
        diff_adc_value = pub_adc_value - sensor_final_output;
        if (diff_adc_value > (float)limit) pub_adc_value = sensor_final_output;
        else                               sensor_final_output = pub_adc_value;
    }
}
static void read_sensor_slow(void) {
    float adc_avg = 0.0f;
    for (unsigned int i = 0; i < 4; i++) {
        bool drdy = 0; uint16_t mc = 0; start();
        do { mc++; _delay_ms(1); drdy = checkDataReady(); } while (!drdy && mc < drdy_timeout_ms);
        uint32_t raw = readADC(); if (raw >= 0x800000) raw = 0;
        adc_avg += ((float)raw) / 4096.0f * 1000.0f;
        for (uint16_t d = 0; d < inter_sample_ms; d++) _delay_ms(1);
    }
    sensor_final_output = adc_avg / 4.0f;
    if (sensor_final_output > 2047999.0f) sensor_final_output = 2047999.0f;
    filter_raw_sensor();
}
static void read_sensor_single(void) {
    bool drdy = 0; uint32_t t = millis_count; start();
    do { drdy = checkDataReady(); } while (!drdy && (millis_count - t) < drdy_timeout_ms);
    uint32_t raw = readADC(); if (raw >= 0x800000) raw = 0;
    sensor_final_output = ((float)raw) / 4096.0f * 1000.0f;
    if (sensor_final_output > 2047999.0f) sensor_final_output = 2047999.0f;
    t = millis_count; while ((millis_count - t) < inter_sample_ms) {}
    filter_raw_sensor();
}
void read_sensor(void) {
    switch (diag_dr) {
        case ADS122C04_DATA_RATE_20SPS:
        case ADS122C04_DATA_RATE_45SPS: read_sensor_slow();   break;
        default:                        read_sensor_single(); break;
    }
}

/* ================================================================== */
/*  COMMAND PARSER                                                     */
/* ================================================================== */
static long parse_long(char **str) {
    char *p = *str;
    while (*p == ' ' || *p == '\t') p++;
    long sign = 1;
    if      (*p == '-') { sign = -1; p++; }
    else if (*p == '+') {            p++; }
    long val = 0;
    while (*p >= '0' && *p <= '9') { val = val * 10 + (*p++ - '0'); }
    *str = p;
    return sign * val;
}
static float parse_float(char **str) {
    char *p = *str;
    while (*p == ' ' || *p == '\t') p++;
    float sign = 1.0f;
    if      (*p == '-') { sign = -1.0f; p++; }
    else if (*p == '+') {               p++; }
    long int_part = 0;
    while (*p >= '0' && *p <= '9') { int_part = int_part * 10 + (*p++ - '0'); }
    float val = (float)int_part;
    if (*p == '.') {
        p++;
        float frac = 0.0f, scale = 0.1f;
        while (*p >= '0' && *p <= '9') { frac += (*p++ - '0') * scale; scale *= 0.1f; }
        val += frac;
    }
    *str = p;
    return sign * val;
}

static void send_params(void) {
    USART1_sendStr("PARAMS:\r\n");           tx_flush();
    USART1_sendStr(" JMP="); USART1_sendFloat(P.jmp,5);           tx_newline(); tx_flush();
    USART1_sendStr(" ALP="); USART1_sendFloat(P.alp,5);           tx_newline(); tx_flush();
    USART1_sendStr(" UPG="); USART1_sendFloat(P.upG,2);           tx_newline(); tx_flush();
    USART1_sendStr(" ING="); USART1_sendFloat(P.inG,4);           tx_newline(); tx_flush();
    USART1_sendStr(" DNG="); USART1_sendFloat(P.dnG,2);           tx_newline(); tx_flush();
    USART1_sendStr(" DNI="); USART1_sendFloat(P.dnI,4);           tx_newline(); tx_flush();
    USART1_sendStr(" REC="); USART1_sendFloat(P.rec,4);           tx_newline(); tx_flush();
    USART1_sendStr(" DRF="); USART1_sendFloat(P.drf,2);           tx_newline(); tx_flush();
    USART1_sendStr(" NTH="); USART1_sendFloat(P.n_thresh,6);      tx_newline(); tx_flush();
    USART1_sendStr(" OCP="); USART1_sendUInt(P.o_cap);             tx_newline(); tx_flush();
    USART1_sendStr(" RZP="); USART1_sendFloat(P.rec_zero_pct,4);  tx_newline(); tx_flush();
    USART1_sendStr(" WRM="); USART1_sendUInt(P.warmup);            tx_newline(); tx_flush();
    USART1_sendStr(" ORT="); USART1_sendFloat(P.or_thresh,2);     tx_newline(); tx_flush();
    USART1_sendStr(" ORX="); USART1_sendFloat(P.or_exit_mv,2);    tx_newline(); tx_flush();
    USART1_sendStr(" ORS="); USART1_sendFloat(P.or_sd_stable,8);  tx_newline(); tx_flush();
    USART1_sendStr(" DMP="); USART1_sendFloat(P.daughter_mother_prox,3); tx_newline(); tx_flush();
    USART1_sendStr("FAST_CALIB:\r\n"); tx_flush();
    for (uint8_t i = 0; i < CALIB_N; i++) {
        USART1_sendStr(" ["); USART1_sendUInt(i); USART1_sendStr("] ");
        USART1_sendFloat(CALIB_FAST[i].p_mv, 4);
        USART1_sendStr("mV -> ");
        USART1_sendLong(CALIB_FAST[i].ppm);
        USART1_sendStr("ppm\r\n"); tx_flush();
    }
    USART1_sendStr("AN_CALIB:\r\n"); tx_flush();
    for (uint8_t i = 0; i < CALIB_N; i++) {
        USART1_sendStr(" ["); USART1_sendUInt(i); USART1_sendStr("] ");
        USART1_sendFloat(CALIB_AN[i].p_mv, 4);
        USART1_sendStr("mV -> ");
        USART1_sendLong(CALIB_AN[i].ppm);
        USART1_sendStr("ppm\r\n"); tx_flush();
    }
    if (mother_baseline_valid) {
        USART1_sendStr("STORED_MB=");
        USART1_sendFloat(stored_mother_baseline, 3);
        USART1_sendStr("mV\r\n"); tx_flush();
    } else {
        USART1_sendStr("STORED_MB=none\r\n"); tx_flush();
    }
    USART1_sendStr("END\r\n"); tx_flush();
}

static void process_cmd(void) {
    const char *s = (const char*)&company[1];

    /* *start# */
    if (s[0]=='s' && s[1]=='t' && s[2]=='a' && s[3]=='r' && s[4]=='t' && s[5]=='#') {
        is_running = true;
        USART1_sendStr("OK_START\r\n");
        USART1_sendStr("COLS: RefR  EMF_mV  DispPPM  Type  H2_Flag  Rec_Pct  OR_Status  Warmup\r\n");
        return;
    }

    /* *TEAR# */
    if (s[0]=='T' && s[1]=='E' && s[2]=='A' && s[3]=='R' && s[4]=='#') {
        do_tear(); return;
    }

    /* *IGNORE_PROX# — bypass proximity check and immediately seed baseline */
    if (s[0]=='I' && s[1]=='G' && s[2]=='N' && s[3]=='O' && s[4]=='R' && s[5]=='E'
        && s[6]=='_' && s[7]=='P' && s[8]=='R' && s[9]=='O' && s[10]=='X' && s[11]=='#') {
        ignore_prox = true;
        if (!baseline_seeded && warmup_phase == WARMUP_PROX_FAIL) {
            /* Force-seed with current C mean */
            float seed = wu_mean();
            daughter_baseline = seed;
            mother_baseline   = seed;
            baseline_seeded   = true;
            warmup_phase      = WARMUP_READY_TARE;
        }
        USART1_sendStr("OK_IGNORE_PROX\r\n");
        return;
    }

    /* *RF<7-digit># */
    if (s[0]=='R' && s[1]=='F' && rxcntr==12) {
        long long a = ((s[2]-'0')*1000000LL) + ((s[3]-'0')*100000LL)
                    + ((s[4]-'0')*10000LL)   + ((s[5]-'0')*1000LL)
                    + ((s[6]-'0')*100LL)     + ((s[7]-'0')*10LL)
                    + ((s[8]-'0')*1LL);
        Reference_Set_Value = a;
        mem_write(220, (long)Reference_Set_Value);
        USART1_sendStr("OK\r\n"); return;
    }

    /* *T<4-digit><2-digit># */
    if (s[0]=='T' && rxcntr==10) {
        long a = (s[1]-'0')*1000L + (s[2]-'0')*100L + (s[3]-'0')*10L + (s[4]-'0');
        long b = (s[6]-'0')*10L   + (s[7]-'0');
        limit        = (unsigned int)a;
        offset_value = (unsigned char)b;
        mem_write(6,   (long)limit);
        mem_write(150, (long)offset_value);
        USART1_sendStr("OK\r\n"); return;
    }

    /* *CAL# */
    if (s[0]=='C' && s[1]=='A' && s[2]=='L' && s[3]=='#') {
        do_calibrate(); return;
    }

    /* *GET PARAMS# */
    if (strncmp(s, "GET PARAMS", 10) == 0) {
        send_params(); return;
    }

    /* *SET ANCAL <idx> <mV> <ppm>#  — edit analytical calib table */
    if (s[0]=='S' && s[1]=='E' && s[2]=='T' && s[3]==' ' &&
        s[4]=='A' && s[5]=='N' && s[6]=='C' && s[7]=='A' && s[8]=='L' && s[9]==' ') {
        char *ptr = (char*)&s[10];
        int   idx = (int)parse_long(&ptr);
        float mv  = parse_float(&ptr);
        long  ppm = parse_long(&ptr);
        if (idx >= 0 && idx < CALIB_N) {
            CALIB_AN[idx].p_mv = mv;
            CALIB_AN[idx].ppm  = ppm;
            calib_save_entry(AN_EE_MAGIC_ADDR, AN_EE_DATA_ADDR, CALIB_AN, (uint8_t)idx);
            USART1_sendStr("OK SET ANCAL\r\n");
        } else {
            USART1_sendStr("ERR_IDX\r\n");
        }
        return;
    }

    /* *SET CAL <idx> <mV> <ppm>#  — edit fast calib table */
    if (s[0]=='S' && s[1]=='E' && s[2]=='T' && s[3]==' ' &&
        s[4]=='C' && s[5]=='A' && s[6]=='L' && s[7]==' ') {
        char *ptr = (char*)&s[8];
        int   idx = (int)parse_long(&ptr);
        float mv  = parse_float(&ptr);
        long  ppm = parse_long(&ptr);
        if (idx >= 0 && idx < CALIB_N) {
            CALIB_FAST[idx].p_mv = mv;
            CALIB_FAST[idx].ppm  = ppm;
            calib_save_entry(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST, (uint8_t)idx);
            USART1_sendStr("OK SET CAL\r\n");
        } else {
            USART1_sendStr("ERR_IDX\r\n");
        }
        return;
    }

    /* *SET <KEY> <value># */
    if (s[0]=='S' && s[1]=='E' && s[2]=='T' && s[3]==' ') {
        char key[4] = {s[4], s[5], s[6], 0};
        char *ptr   = (char*)&s[8];
        float fval  = parse_float(&ptr);
        bool  ok    = true;

        if      (strcmp(key,"JMP")==0) P.jmp                  = fval;
        else if (strcmp(key,"ALP")==0) P.alp                  = fval;
        else if (strcmp(key,"UPG")==0) P.upG                  = fval;
        else if (strcmp(key,"ING")==0) P.inG                  = fval;
        else if (strcmp(key,"DNG")==0) P.dnG                  = fval;
        else if (strcmp(key,"DNI")==0) P.dnI                  = fval;
        else if (strcmp(key,"REC")==0) P.rec                  = fval;
        else if (strcmp(key,"DRF")==0) P.drf                  = fval;
        else if (strcmp(key,"NTH")==0) P.n_thresh             = fval;
        else if (strcmp(key,"OCP")==0) P.o_cap                = (uint16_t)fval;
        else if (strcmp(key,"RZP")==0) P.rec_zero_pct         = fval;
        else if (strcmp(key,"WRM")==0) P.warmup               = (uint16_t)fval;
        else if (strcmp(key,"ORT")==0) P.or_thresh            = fval;
        else if (strcmp(key,"ORX")==0) P.or_exit_mv           = fval;
        else if (strcmp(key,"ORS")==0) P.or_sd_stable         = fval;
        else if (strcmp(key,"DMP")==0) P.daughter_mother_prox = fval;
        else ok = false;

        if (ok) {
            USART1_sendStr("OK SET "); USART1_sendStr(key);
            USART1_sendChar('='); USART1_sendFloat(fval, 6);
            tx_newline();
        } else {
            USART1_sendStr("ERR_UNKNOWN_KEY\r\n");
        }
        return;
    }

    USART1_sendStr("ERR_CMD\r\n");
}

ISR(USART1_RXC_vect) {
    unsigned char c = USART1.RXDATAL;
    if (c == '*') { strt = 1; rxcntr = 0; }
    if (strt == 1) {
        if (rxcntr < CMD_BUF_LEN - 1) company[rxcntr++] = c;
        if (c == '#') {
            company[rxcntr] = '\0';
            cmd_ready = true; strt = 0;
        }
    }
}

