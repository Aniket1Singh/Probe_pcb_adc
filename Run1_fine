		USART1_sendChar(str3[i]); // actual sensor output after minus with reference voltage
	}
	
	USART1_sendChar(' ');
	USART1_sendChar(' ');

	/* ADDED: elapsed time column — 4 digits, milliseconds */
	USART1_sendChar((elapsed_ms / 1000) % 10 + '0');
	USART1_sendChar((elapsed_ms / 100)  % 10 + '0');
	USART1_sendChar((elapsed_ms / 10)   % 10 + '0');
	USART1_sendChar((elapsed_ms)        % 10 + '0');

	USART1_sendChar(' ');
	USART1_sendChar(' ');

	USART1_sendChar('D');
	USART1_sendChar(':');
	USART1_sendChar(dr + '0');
	USART1_sendChar(' ');
	USART1_sendChar(' ');

	/* PGABYP: 1=PGA bypassed/disabled, 0=PGA active */
	USART1_sendChar('P');
	USART1_sendChar('G');
	USART1_sendChar('A');
	USART1_sendChar('B');
	USART1_sendChar('Y');
	USART1_sendChar('P');
	USART1_sendChar(':');
	USART1_sendChar(pga + '0');
	USART1_sendChar(' ');
	USART1_sendChar(' ');

	/* G: gain register value 0=x1, 1=x2, 2=x4 ... 7=x128 */
	USART1_sendChar('G');
	USART1_sendChar(':');
	USART1_sendChar(gain + '0');
	USART1_sendChar(' ');
	USART1_sendChar(' ');

	USART1_sendChar(0x0D);
}


// readRawVoltage — NOT USED in this firmware.
// Actual measurement is done by read_sensor() which calls poll_and_read().
// This function is retained for reference only.
int32_t readRawVoltage(uint8_t rate)
{
	raw_voltage_union raw_v; // union to convert uint32_t to int32_t

	bool drdy = false; // DRDY (1 == new data is ready)
	// Start the conversion (assumes we are using single shot mode)
	start();

	
	do 
	{
		_delay_ms(10); // Don't pound the bus too hard
		drdy = checkDataReady();
	} while ((drdy == false));

	// Check if we timed out
	if (drdy == false)
	{
		return(0);
	}

	// Read the conversion result
	if(ADS122C04_getConversionData(&raw_v.UINT32) == false)
	{
		return(0);
	}

	if ((raw_v.UINT32 & 0x00800000) == 0x00800000)
	raw_v.UINT32 |= 0xFF000000;
	return(raw_v.INT32);
}

void filter_raw_sensor()
{
	if(sensor_final_output>=pub_adc_value)
	{
		diff_adc_value=sensor_final_output-pub_adc_value;
		
		if(diff_adc_value>limit)
		{
			pub_adc_value=sensor_final_output;
			
		}
		else
		{
			sensor_final_output=pub_adc_value;
			
		}
		
	}
	else
	{
		diff_adc_value=pub_adc_value-sensor_final_output;
		
		if(diff_adc_value>limit)
		{
			pub_adc_value=sensor_final_output;
			
		}
		else
		{
			sensor_final_output=pub_adc_value;
			
		}
		
	}
}


/* Poll DRDY with 1 ms spacing and read ADC. Returns 0 on timeout. */
uint32_t poll_and_read(void)
{
	bool drdy = 0;
	{ uint32_t t = millis_count;
	  do {
		drdy = checkDataReady();
		if (drdy == 0) { uint32_t w=millis_count; while((millis_count-w)<1){} }
	  } while ((drdy == 0) && ((millis_count - t) < drdy_timeout_ms)); }
	if (!drdy) { return 0; }
	uint32_t raw = readADC();
	if (raw >= 0x800000) { raw = 0; }
	return raw;
}

/* set_inter_sample_delay: call once after setDataRate() before run_mode().
   4x conversion period settle + 6x timeout for all 7 supported rates.  */
void set_inter_sample_delay(uint8_t dr)
{
	/* SPS:    20   45   90  175  330  600  1000
	   4x ms: 200   89   44   23   13    7     4
	   6x ms: 300  134   67   34   19   10     6  */
	/* Single-shot mode for all rates. Settle = 6x conversion period
	   for 330/600/1000 SPS to give solid margin against millis_count
	   1ms tick jitter. 4x used for 20-175 SPS (verified working).
	   SPS:   20   45   90  175  330  600  1000
	   4x:   200   89   44   23    -    -     -  ms
	   6x:     -    -    -    -   18   10     6  ms
	   timeout = 2x settle                        */
	switch(dr)
	{
		case ADS122C04_DATA_RATE_20SPS:
			inter_sample_delay_ms=200; drdy_timeout_ms=400; break;
		case ADS122C04_DATA_RATE_45SPS:
			inter_sample_delay_ms=89;  drdy_timeout_ms=178; break;
		case ADS122C04_DATA_RATE_90SPS:
			inter_sample_delay_ms=44;  drdy_timeout_ms=88;  break;
		case ADS122C04_DATA_RATE_175SPS:
			inter_sample_delay_ms=23;  drdy_timeout_ms=46;  break;
		case ADS122C04_DATA_RATE_330SPS:
			inter_sample_delay_ms=18;  drdy_timeout_ms=36;  break;
		case ADS122C04_DATA_RATE_600SPS:
			inter_sample_delay_ms=10;  drdy_timeout_ms=20;  break;
		case ADS122C04_DATA_RATE_1000SPS:
			inter_sample_delay_ms=6;   drdy_timeout_ms=12;  break;
		default:
			inter_sample_delay_ms=200; drdy_timeout_ms=400; break;
	}
}

void read_sensor()
{
	long long adc_data,adc_avg;
	unsigned int i;

		 adc_data=0;
		 adc_avg=0;

		 /* Dummy conversion to flush sinc3 filter pipeline.
		    After any config change the first result is corrupted.
		    Discard it, then collect 4 clean samples.             */
		 start();
		 poll_and_read();
		 { uint32_t t=millis_count; while((millis_count-t)<inter_sample_delay_ms){} }

		 /* 4 real samples */
		 for(i=0;i<4;i++)
		 {
			 start();
			 uint32_t raw = poll_and_read();
			 float volts = ((float)raw) / 4096;
			 adc_data=volts*1000;
			 adc_avg+=adc_data;
			 { uint32_t t=millis_count; while((millis_count-t)<inter_sample_delay_ms){} }
		 }
		 
		 adc_data=adc_avg/4;
		 
		 sensor_final_output=adc_data;
		 
		 if(sensor_final_output>2047999)//2047999
		 {
			 sensor_final_output=2047999;
		 }
		 
				 
		 filter_raw_sensor();
			 
		  str2[0]=(sensor_final_output/1000000)+0x30;
		  str2[1]=((sensor_final_output%1000000)/100000)+0x30;
		  str2[2]=(((sensor_final_output%1000000)%100000)/10000)+0x30;
		  str2[3]=((((sensor_final_output%1000000)%100000)%10000)/1000)+0x30;
		  str2[4]='.';
		  str2[5]=(((((sensor_final_output%1000000)%100000)%10000)%1000)/100)+0x30;
		  str2[6]=((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)/10)+0x30;
		  str2[7]=(((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)%10)/1)+0x30;
		 
		 sensor_final_output=sensor_final_output-Reference_Set_Value;
				 
		 if(sensor_final_output>=0)
		 {
			 str3[0]='+';
			 str3[1]=(sensor_final_output/1000000)+0x30;
			 str3[2]=((sensor_final_output%1000000)/100000)+0x30;
			 str3[3]=(((sensor_final_output%1000000)%100000)/10000)+0x30;
			 str3[4]=((((sensor_final_output%1000000)%100000)%10000)/1000)+0x30;
			 str3[5]='.';
			 str3[6]=(((((sensor_final_output%1000000)%100000)%10000)%1000)/100)+0x30;
			 str3[7]=((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)/10)+0x30;
			 str3[8]=((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)%10)+0x30;
			 
		 }
		else
		{
			sensor_final_output=(sensor_final_output)*(-1);
			str3[0]='-';
			str3[1]=(sensor_final_output/1000000)+0x30;
			str3[2]=((sensor_final_output%1000000)/100000)+0x30;
			str3[3]=(((sensor_final_output%1000000)%100000)/10000)+0x30;
			str3[4]=((((sensor_final_output%1000000)%100000)%10000)/1000)+0x30;
			str3[5]='.';
			str3[6]=(((((sensor_final_output%1000000)%100000)%10000)%1000)/100)+0x30;
			str3[7]=((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)/10)+0x30;
			str3[8]=((((((sensor_final_output%1000000)%100000)%10000)%1000)%100)%10)+0x30;
			sensor_final_output=(sensor_final_output)*(-1);
		}
}

void timer_init()
{
	TCA0.SINGLE.CTRLA   = TCA_SINGLE_CLKSEL_DIV64_gc;  // prescaler /64
	TCA0.SINGLE.PER     = 52;                           // ~1 ms at 3.333 MHz / 64
	TCA0.SINGLE.INTCTRL = TCA_SINGLE_OVF_bm;
	TCA0.SINGLE.CTRLA  |= TCA_SINGLE_ENABLE_bm;
}

/* ── ADDED: TCA0 overflow ISR — increments millis_count every ~1 ms ── */
ISR(TCA0_OVF_vect)
{
	millis_count++;
	TCA0.SINGLE.INTFLAGS = TCA_SINGLE_OVF_bm;
}


void run_mode()
{
	unsigned int sd_tx,txcounter,first_time,k;
	upflag=0;
	overrange=0;
	first_time=0;
	unsigned int addr;
	offset_value=mem_read(150);
	if(offset_value>100)
	{
		offset_value=30;
	}
	txcounter=0;

	while(1)
	{
		/* ADDED: snapshot millis before read_sensor, compute elapsed after */
		uint32_t start_time = millis_count;

		read_sensor();

		uint32_t elapsed = millis_count - start_time;

		home_online_tx(elapsed, diag_dr, diag_pga, diag_gain);
	}
}


int main(void)
{
	unsigned int addr;
	long int loc_data;
	unsigned char i;
		
		PORTA_DIR=0xFF;
		PORTA_OUTSET = ADC_RESET;
		PORTB_DIR=0xFF;
		_delay_ms(500);
		InitI2C();
		USART1_init();
		_delay_ms(100);

		/* ADDED: start timer before sei() so millis_count is running */
		timer_init();
		sei();
		
			limit=mem_read(6);
			_delay_ms(20);
			
			addr=160;
			i=eeprom_read_byte((uint8_t*)(1*addr));
			asm("nop");
								
			Reference_Set_Value=mem_read(220);
			if(Reference_Set_Value>2000000)
			{
				Reference_Set_Value=0;
			}
		
			USART1_sendChar('M');
			USART1_sendChar('N');
			USART1_sendChar('S');
			USART1_sendChar('T');
			USART1_sendChar(0x0D);
			USART1_sendChar(0x0A);

		 setInputMultiplexer(ADS122C04_MUX_AIN1_AIN0); // Route AIN1 and AIN0 to AINP and AINN
		 setGain(ADS122C04_GAIN_1); // Set the gain to 1
		 enablePGA(ADS122C04_PGA_DISABLED); // Disable the Programmable Gain Amplifier
		 setDataRate(ADS122C04_DATA_RATE_175SPS); // <-- change SPS here
		 setOperatingMode(ADS122C04_OP_MODE_NORMAL); // Disable turbo mode
		 setConversionMode(ADS122C04_CONVERSION_MODE_SINGLE_SHOT); // Use single shot mode
		 setVoltageReference(ADS122C04_VREF_INTERNAL); // Use the internal 2.048V reference
		 enableInternalTempSensor(ADS122C04_TEMP_SENSOR_OFF); // Disable the temperature sensor
		 setDataCounter(ADS122C04_DCNT_DISABLE); // Disable the data counter
		 setDataIntegrityCheck(ADS122C04_CRC_DISABLED); // Disable CRC checking
		 setBurnOutCurrent(ADS122C04_BURN_OUT_CURRENT_OFF); // Disable the burn-out current
		 setIDACcurrent(ADS122C04_IDAC_CURRENT_OFF); // Disable the IDAC current
		 setIDAC1mux(ADS122C04_IDAC1_DISABLED); // Disable IDAC1
		 setIDAC2mux(ADS122C04_IDAC2_DISABLED); // Disable IDAC2

		 
		 diag_dr   = ADS122C04_Reg.reg1.bit.DR;
		 diag_pga  = ADS122C04_Reg.reg0.bit.PGA_BYPASS;
		 diag_gain = ADS122C04_Reg.reg0.bit.GAIN;
		 set_inter_sample_delay(diag_dr);

		 reset();
		 _delay_ms(2);
		 setDataRate(ADS122C04_Reg.reg1.bit.DR);

		 {
			 uint8_t reg1_readback = 0;
			 ADS122C04_readReg(ADS122C04_CONFIG_1_REG, &reg1_readback);
			 uint8_t actual_dr = (reg1_readback >> 5) & 0x07;
			 USART1_sendChar('C');
			 USART1_sendChar('H');
			 USART1_sendChar('K');
			 USART1_sendChar(':');
			 USART1_sendChar('D');
			 USART1_sendChar('R');
			 USART1_sendChar('=');
			 USART1_sendChar(actual_dr + '0');
			 USART1_sendChar(' ');
			 USART1_sendChar('R');
			 USART1_sendChar('E');
			 USART1_sendChar('G');
			 USART1_sendChar('1');
			 USART1_sendChar('=');
			 /* print reg1 as 8 binary digits */
			 for (int8_t b=7; b>=0; b--) {
				 USART1_sendChar(((reg1_readback >> b) & 1) + '0');
			 }
			 USART1_sendChar(0x0D);
			 USART1_sendChar(0x0A);
			 /* Update diag_dr with ACTUAL chip value, not struct value */
			 diag_dr = actual_dr;
			 set_inter_sample_delay(diag_dr);
		 }

		 run_mode();
   
}
