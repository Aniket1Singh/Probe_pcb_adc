static float    N_accum = 0.0f;
static uint16_t O_roc   = 0;
static float    P_clip  = 0.0f;
static long     Q_ppm   = 0;
static long     R_ppm   = 0;
static long     S_ppm   = 0;
/* Latch: once analytical (R) overtakes fast (Q) during an UP event, keep
 * fast suppressed (Q displayed as 0) for the rest of that UP event, even
 * if analytical later falls back below the held fast value. Reset on
 * UP-entry (II goes 1 after being -1). See AN_RESET_THRESH_MV above. */
static bool     an_override    = false;
static float    peak_M         = 0.0f;
static float    rec_pct        = 100.0f;
