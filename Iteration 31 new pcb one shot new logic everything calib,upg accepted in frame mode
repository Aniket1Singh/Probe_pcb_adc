void set_sample_timing(uint8_t dr) {
    switch(dr) {
        case ADS122C04_DATA_RATE_20SPS:   inter_sample_ms=50;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_45SPS:   inter_sample_ms=22;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_90SPS:   inter_sample_ms=44;  drdy_timeout_ms=44;  break;
        case ADS122C04_DATA_RATE_175SPS:  inter_sample_ms=30;  drdy_timeout_ms=36;  break;
        case ADS122C04_DATA_RATE_330SPS:  inter_sample_ms=12;  drdy_timeout_ms=18;  break;
        case ADS122C04_DATA_RATE_600SPS:  inter_sample_ms=8;   drdy_timeout_ms=12;  break;
        case ADS122C04_DATA_RATE_1000SPS: inter_sample_ms=4;   drdy_timeout_ms=8;   break;
        default:                          inter_sample_ms=50;  drdy_timeout_ms=75;  break;
    }
}
static void filter_raw_sensor(void) {
    if (raw_sensor_uv >= pub_adc_value) {
        diff_adc_value = raw_sensor_uv - pub_adc_value;
        if (diff_adc_value > (long long)limit) pub_adc_value = raw_sensor_uv;
        else                                   raw_sensor_uv = pub_adc_value;
    } else {
        diff_adc_value = pub_adc_value - raw_sensor_uv;
        if (diff_adc_value > (long long)limit) pub_adc_value = raw_sensor_uv;
        else                                   raw_sensor_uv = pub_adc_value;
    }
}
static void read_sensor_slow(void) {
    long long adc_avg = 0;
    for (unsigned int i = 0; i < 4; i++) {
        bool drdy=0; uint16_t mc=0; start();
        do { mc++; _delay_ms(1); drdy=checkDataReady(); } while (!drdy && mc<drdy_timeout_ms);
       // uint32_t raw=readADC(); long long signed_raw = (raw >= 0x800000) ? (long long)raw - 0x1000000LL : (long long)raw;
	   uint32_t raw=readADC();
	   long long signed_raw = (raw >= 0x800000) ? (long long)raw - 0x1000000LL : (long long)raw;
        adc_avg += (long long)(((float)signed_raw)/4096.0f*1000.0f);
        for (uint16_t d=0; d<inter_sample_ms; d++) _delay_ms(1);
    }
    raw_sensor_uv = adc_avg / 4;
    if (raw_sensor_uv > 2047999) raw_sensor_uv = 2047999;
    filter_raw_sensor();
    sensor_final_output = raw_sensor_uv;
}
static void read_sensor_single(void) {
    bool drdy=0; uint32_t t=millis_count; start();
    do { drdy=checkDataReady(); } while (!drdy && (millis_count-t)<drdy_timeout_ms);
    //uint32_t raw=readADC(); long long signed_raw = (raw >= 0x800000) ? (long long)raw - 0x1000000LL : (long long)raw;
	uint32_t raw=readADC();
	long long signed_raw = (raw >= 0x800000) ? (long long)raw - 0x1000000LL : (long long)raw;
    raw_sensor_uv = (long long)(((float)signed_raw)/4096.0f*1000.0f);
    if (raw_sensor_uv > 2047999) raw_sensor_uv = 2047999;
    t=millis_count; while ((millis_count-t)<inter_sample_ms) {}
    filter_raw_sensor();
    sensor_final_output = raw_sensor_uv;
}
void read_sensor(void) {
    switch (diag_dr) {
        case ADS122C04_DATA_RATE_20SPS:
        case ADS122C04_DATA_RATE_45SPS: read_sensor_slow();   break;
        default:                        read_sensor_single(); break;
    }
}

/* ================================================================== */
/*  COMMAND PARSER                                                     */
/* ================================================================== */
static long parse_long(char **str) {
    char *p=*str; while (*p==' '||*p=='\t') p++;
    long sign=1;
    if (*p=='-'){sign=-1;p++;} else if (*p=='+') p++;
    long val=0;
    while (*p>='0'&&*p<='9') val=val*10+(*p++-'0');
    *str=p; return sign*val;
}
static float parse_float(char **str) {
    char *p=*str; while (*p==' '||*p=='\t') p++;
    float sign=1.0f;
    if (*p=='-'){sign=-1.0f;p++;} else if (*p=='+') p++;
    long int_part=0;
    while (*p>='0'&&*p<='9') int_part=int_part*10+(*p++-'0');
    float val=(float)int_part;
    if (*p=='.') {
        p++; float frac=0.0f, scale=0.1f;
        while (*p>='0'&&*p<='9') { frac+=(*p++-'0')*scale; scale*=0.1f; }
        val+=frac;
    }
    *str=p; return sign*val;
}

static void send_params(void) {
    /* Suppress in frame mode ? binary stream must not be interrupted */
    if (run_mode_state == MODE_FRAME) return;
/* Helper: flush TX, drain RS-485 loopback, re-disable RX for next line.
 * send_params() is called from inside process_cmd() which holds rx_disable().
 * At 9600 baud ~500 bytes takes ~500ms ? we must drain the loopback echo
 * after each line or the RX buffer stalls and the UART appears to freeze. */
#define PLE()  do { rx_enable(); rx_disable(); } while(0)
    USART1_sendStr("PARAMS:\r\n");                                        PLE();
    USART1_sendStr(" JMP="); USART1_sendFloat(P.jmp,5);                  tx_newline(); PLE();
    USART1_sendStr(" ALP="); USART1_sendFloat(P.alp,5);                  tx_newline(); PLE();
    USART1_sendStr(" UPG="); USART1_sendFloat(P.upG,2);                  tx_newline(); PLE();
    USART1_sendStr(" ING="); USART1_sendFloat(P.inG,4);                  tx_newline(); PLE();
    USART1_sendStr(" DNG="); USART1_sendFloat(P.dnG,2);                  tx_newline(); PLE();
    USART1_sendStr(" DNI="); USART1_sendFloat(P.dnI,4);                  tx_newline(); PLE();
    USART1_sendStr(" REC="); USART1_sendFloat(P.rec,4);                  tx_newline(); PLE();
    USART1_sendStr(" DRF="); USART1_sendFloat(P.drf,2);                  tx_newline(); PLE();
    USART1_sendStr(" NTH="); USART1_sendFloat(P.n_thresh,6);             tx_newline(); PLE();
    USART1_sendStr(" NTL="); USART1_sendFloat(P.n_thresh_low,6);        tx_newline(); PLE();
    USART1_sendStr(" NPT="); USART1_sendFloat(P.n_thresh_ppm_thresh,1); tx_newline(); PLE();
    USART1_sendStr(" OCP="); USART1_sendUInt(P.o_cap);                   tx_newline(); PLE();
    USART1_sendStr(" RZP="); USART1_sendFloat(P.rec_zero_pct,4);         tx_newline(); PLE();
    USART1_sendStr(" WRM="); USART1_sendUInt(P.warmup);                  tx_newline(); PLE();
    USART1_sendStr(" ORT="); USART1_sendFloat(P.or_thresh,2);            tx_newline(); PLE();
    USART1_sendStr(" ORX="); USART1_sendFloat(P.or_exit_mv,2);           tx_newline(); PLE();
    USART1_sendStr(" ORS="); USART1_sendFloat(P.or_sd_stable,8);         tx_newline(); PLE();
    USART1_sendStr(" DMP="); USART1_sendFloat(P.daughter_mother_prox,3); tx_newline(); PLE();
    USART1_sendStr(" PHT="); USART1_sendFloat(P.post_high_conc_thresh,1);    tx_newline(); PLE();
    USART1_sendStr(" PHL="); USART1_sendUInt(P.post_high_counter_limit);     tx_newline(); PLE();
    USART1_sendStr(" PHU="); USART1_sendFloat(P.post_high_upG,2);            tx_newline(); PLE();
    USART1_sendStr(" PHI="); USART1_sendFloat(P.post_high_inG,4);            tx_newline(); PLE();
    USART1_sendStr(" SFS="); USART1_sendFloat(P.sf_step,5);                 tx_newline(); PLE();
    USART1_sendStr(" ART="); USART1_sendFloat(P.an_reset_thresh_mv,1);      tx_newline(); PLE();
    USART1_sendStr("FAST_CALIB:\r\n"); PLE();
    for (uint8_t i=0; i<CALIB_N; i++) {
        USART1_sendStr(" ["); USART1_sendUInt(i); USART1_sendStr("] ");
        USART1_sendFloat(CALIB_FAST[i].p_mv,4);
        USART1_sendStr("mV -> "); USART1_sendLong(CALIB_FAST[i].ppm);
        USART1_sendStr("ppm band="); USART1_sendFloat(CALIB_FAST[i].band_mv,3);
        USART1_sendStr("mV sf="); USART1_sendFloat(CALIB_FAST[i].sf,2);
        USART1_sendStr(" eff="); USART1_sendFloat(calib_eff_mv(&CALIB_FAST[i]),4);
        USART1_sendStr("mV");
        USART1_sendStr("\r\n"); PLE();
    }
    USART1_sendStr("AN_CALIB:\r\n"); PLE();
    for (uint8_t i=0; i<CALIB_N; i++) {
        USART1_sendStr(" ["); USART1_sendUInt(i); USART1_sendStr("] ");
        USART1_sendFloat(CALIB_AN[i].p_mv,4);
        USART1_sendStr("mV -> "); USART1_sendLong(CALIB_AN[i].ppm);
        USART1_sendStr("ppm band="); USART1_sendFloat(CALIB_AN[i].band_mv,3);
        USART1_sendStr("mV sf="); USART1_sendFloat(CALIB_AN[i].sf,2);
        USART1_sendStr(" eff="); USART1_sendFloat(calib_eff_mv(&CALIB_AN[i]),4);
        USART1_sendStr("mV");
        USART1_sendStr("\r\n"); PLE();
    }
    if (mother_baseline_valid) {
        USART1_sendStr("STORED_MB="); USART1_sendFloat(stored_mother_baseline,3);
