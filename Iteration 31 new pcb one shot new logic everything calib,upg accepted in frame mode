/* EEPROM addresses ? updated for 10-byte CalibEntry (3 bytes p_mv/ppm/band_mv
 * + 1 byte sf).
 *
 * Each CalibEntry column uses 3 bytes (int24), scaled x100 for 2 decimal
 * places (except ppm which is stored raw as uint24). sf (scaling factor)
 * is 1 byte.
 *
 * CHANGE 7 (this revision) -- sf EEPROM encoding switched from a SIGNED
 * offset-from-1.00 (step 0.05, range ~ -5.4..7.35) to an UNSIGNED
 * direct-value encoding (step 0.02, range 0.00..5.10):
 *   raw = round(sf / 0.02)   ,   sf = raw * 0.02
 * Reasoning: sf is only ever produced by *1CAL's divisor math
 * (sf = sf_prev / (1 + steps*P.sf_step) or sf_prev * (1 + steps*P.sf_step)),
 * which starts from 1.00 and can only multiply/divide -- it can therefore
 * never legitimately become <= 0. Storing sf directly (instead of an
 * offset from 1.00) removes the need for a sign bit entirely, which
 * doubles the usable range at a given step size (old signed/0.05: max
 * 7.35, worst-case error +-0.025 -- new unsigned/0.02: max 5.10,
 * worst-case error +-0.01) using the SAME single EEPROM byte -- no
 * layout change, CALIB_ENTRY_EE_BYTES stays 10. This also fixes the
 * observed real-world symptom of *1CAL results like sf=0.93 rounding to
 * 0.95 (or worse) on every power cycle -- error is now capped at 0.01.
 *   p_mv   : int24,  stored as (int32)(p_mv * 100)   ? 2 decimal places
 *   ppm    : uint24, stored raw (max 100000 fits in 3 bytes)
 *   band_mv: int24,  stored as (int32)(band_mv * 100) ? 2 decimal places
 *   sf     : uint8,  stored as round(sf / 0.02); rows with ppm < 5000
 *            always stay at raw 50 (sf = 1.00, never scaled)
 *
 * Layout (ATtiny3224, 256 bytes EEPROM):
 *   0x08           FAST magic
 *   0x09..0x62     FAST data  (9 * 10 = 90 bytes)
 *   0x63           AN   magic
 *   0x64..0xBD     AN   data  (9 * 10 = 90 bytes)
 *   0xBE..0xC1     MB   data  (float, 4 bytes)
 *   0xC2           MB   magic
 *   0xC3           PARAMS magic
 *   0xC4..0xFE     PARAMS data (59 bytes)
 *   0xFF           unused (1 byte free)
 *
 * Magic values bumped so first boot after this firmware upgrade
 * invalidates old (smaller) EEPROM entries and rewrites defaults cleanly.
 */
#define FAST_EE_MAGIC_ADDR    0x08u
#define FAST_EE_DATA_ADDR     0x09u
#define AN_EE_MAGIC_ADDR      0x63u
#define AN_EE_DATA_ADDR       0x64u
#define MB_EE_DATA_ADDR       0xBEu
#define MB_EE_MAGIC_ADDR      0xC2u
#define PARAMS_EE_MAGIC_ADDR  0xC3u
#define PARAMS_EE_DATA_ADDR   0xC4u
#define CALIB_EE_MAGIC_VAL    0xAAu   /* CHANGE 7: bumped from 0xA9 ? sf byte reinterpreted as UNSIGNED direct-value (step 0.02), was SIGNED offset-from-1.00 (step 0.05) */
#define CALIB_EE_MAGIC_INVAL  0x00u
#define MB_EE_MAGIC_VAL       0xB3u
#define PARAMS_EE_MAGIC_VAL   0xCCu   /* bumped: several fields repacked to fixed-point to make room for calib sf column */
#define PARAMS_EE_MAGIC_INVAL 0x00u


/* SCALAR block ? ref_val, limit_val, offset_val stored SEPARATELY from the
 * main params block.  This is the fix for ref/offset becoming 0 after power
 * cycles:  the old design bundled them at the END of the 89-byte params block,
 * so every *RF# command had to rewrite all 89 bytes.  A power-loss during that
 * ~300 ms window left PARAMS_EE_MAGIC = INVAL, causing params_ee_load() to
 * reset everything including ref_val to DEFAULT (0).
 *
 * With a dedicated 8-byte block (magic + ref + limit + offset), the write
 * window is < 30 ms and they are loaded/saved independently of detection params.
 *
 * Layout:
 *   0x10C   SCALAR magic  (1 byte)
 *   0x10D   ref_val       (int32, 4 bytes)
 *   0x111   limit_val     (uint16, 2 bytes)
 *   0x113   offset_val    (uint8,  1 byte)
 *   0x114   (next free address)
 */
#define SCALAR_EE_MAGIC_ADDR  0x00u
#define SCALAR_EE_DATA_ADDR   0x01u
#define SCALAR_EE_MAGIC_VAL   0xD5u
#define SCALAR_EE_MAGIC_INVAL 0x00u

/* CalibEntry EEPROM encoding helpers.
 * p_mv, ppm, band_mv are each stored as a 3-byte little-endian integer.
 * p_mv and band_mv are scaled ?100 (2 decimal places, e.g. 8.40975 ? 841).
 * ppm is stored raw (unsigned, fits in uint24 for values up to 16,777,215).
 * sf (scaling factor) is stored as a single SIGNED byte (int8_t):
 * round((sf-1.0)/0.05), i.e. 0.05 steps starting at 1.00 (raw 0 = sf 1.00,
 * raw 127 = sf 7.35, raw -128 = sf -5.4). Signed so sf CAN drop below 1.00
 * -- *1CAL's cross-concentration adjustment can legitimately produce
 * sf < 1.0, and the old unsigned/clamped-to-0 scheme silently rounded that
 * back up to sf=1.00 on every EEPROM round-trip (i.e. it "reset" itself on
 * every power cycle). Rows with ppm < 5000 are never touched by *1CAL and
 * stay at raw 0 (sf=1.00).
 */
#define CALIB_ENTRY_EE_BYTES  10u   /* 3 bytes x 3 fields + 1 byte sf */

/* ------------------------------------------------------------------ */
/*  EEPROM primitives                                                  */
/* ------------------------------------------------------------------ */
static void ee_wb(uint16_t addr, uint8_t val) {
    eeprom_write_byte((uint8_t*)(uintptr_t)addr, val);
    while (!eeprom_is_ready()) {}
}
static uint8_t ee_rb(uint16_t addr) {
    return eeprom_read_byte((uint8_t*)(uintptr_t)addr);
}
static void ee_write_float(uint16_t addr, float v) {
    uint8_t *b = (uint8_t*)&v;
    for (uint8_t i = 0; i < 4; i++) ee_wb((uint16_t)(addr+i), b[i]);
}
static float ee_read_float(uint16_t addr) {
    float v; uint8_t *b = (uint8_t*)&v;
    for (uint8_t i = 0; i < 4; i++) b[i] = ee_rb((uint16_t)(addr+i));
    return v;
}
static void ee_write_long(uint16_t addr, long v) {
    uint8_t *b = (uint8_t*)&v;
    for (uint8_t i = 0; i < 4; i++) ee_wb((uint16_t)(addr+i), b[i]);
}
static long ee_read_long(uint16_t addr) {
    long v; uint8_t *b = (uint8_t*)&v;
    for (uint8_t i = 0; i < 4; i++) b[i] = ee_rb((uint16_t)(addr+i));
    return v;
}

/* ------------------------------------------------------------------ */
/*  CalibEntry EEPROM encode / decode (9 bytes per entry, 3 per field) */
/*                                                                      */
/*  p_mv  : signed int24, stored as round(p_mv * 100)   ? 2 dp        */
/*  ppm   : unsigned int24, stored raw (fits up to 16,777,215)         */
/*  band_mv: signed int24, stored as round(band_mv * 100) ? 2 dp      */
/*                                                                      */
/*  Value ranges accepted:                                              */
/*    p_mv    : ?83,886.07 mV  (needed: 0 .. 820 mV ?)                */
/*    ppm     : 0 .. 16,777,215 (needed: 0 .. 100,000 ?)              */
/*    band_mv : ?83,886.07 mV  (needed: 0 .. 25.5 mV ?)              */
/* ------------------------------------------------------------------ */
static void ee_write_int24(uint16_t addr, int32_t v) {
    /* Store little-endian 3-byte signed */
    ee_wb((uint16_t)(addr + 0u), (uint8_t)( v        & 0xFF));
    ee_wb((uint16_t)(addr + 1u), (uint8_t)((v >>  8) & 0xFF));
    ee_wb((uint16_t)(addr + 2u), (uint8_t)((v >> 16) & 0xFF));
}
static int32_t ee_read_int24(uint16_t addr) {
    /* Read little-endian 3-byte signed, sign-extend from bit 23 */
    int32_t v = (int32_t)ee_rb((uint16_t)(addr + 0u))
              | ((int32_t)ee_rb((uint16_t)(addr + 1u)) << 8)
              | ((int32_t)ee_rb((uint16_t)(addr + 2u)) << 16);
    if (v & 0x800000L) v |= (int32_t)0xFF000000L;   /* sign extend */
    return v;
}
static void ee_write_uint24(uint16_t addr, uint32_t v) {
    ee_wb((uint16_t)(addr + 0u), (uint8_t)( v        & 0xFF));
    ee_wb((uint16_t)(addr + 1u), (uint8_t)((v >>  8) & 0xFF));
    ee_wb((uint16_t)(addr + 2u), (uint8_t)((v >> 16) & 0xFF));
}
static uint32_t ee_read_uint24(uint16_t addr) {
    return (uint32_t)ee_rb((uint16_t)(addr + 0u))
         | ((uint32_t)ee_rb((uint16_t)(addr + 1u)) << 8)
         | ((uint32_t)ee_rb((uint16_t)(addr + 2u)) << 16);
}

static void calib_ee_write_entry(uint16_t base, const CalibEntry *e) {
    ee_write_int24 (base,                  (int32_t)(e->p_mv    * 100.0f + 0.5f));
    ee_write_uint24((uint16_t)(base + 3u), (uint32_t)e->ppm);
    ee_write_int24 ((uint16_t)(base + 6u), (int32_t)(e->band_mv * 100.0f + 0.5f));
    /* CHANGE 7: sf: round(sf/0.02), stored as an UNSIGNED uint8 (0..255),
     * i.e. sf range 0.00 .. 5.10 in 0.02 steps (was: SIGNED offset-from-1.0,
     * step 0.05, range ~ -5.4..7.35). sf is only ever produced by *1CAL's
     * divisor math starting from 1.00 and repeatedly multiplying/dividing
     * by (1 + steps*P.sf_step) -- it can therefore never legitimately go
     * <= 0, so storing sf DIRECTLY (no "-1.0" offset, no sign bit needed)
     * is safe and doubles the effective resolution at the same 1-byte
     * cost vs the old signed/0.05 scheme (worst-case round-trip error is
     * now +-0.01 instead of +-0.025). This is what fixes real-world *1CAL
     * results like sf=0.93 coming back as 0.95 (or worse) after a power
     * cycle -- previous scheme's coarser 0.05 grid. Old signed EEPROM data
     * is invalidated automatically by the CALIB_EE_MAGIC_VAL bump above,
     * so no misread of pre-CHANGE-7 data can occur. */
    { float raw_f = e->sf / 0.02f;
      long  raw_i = (long)(raw_f + 0.5f);
      if (raw_i < 0L)   raw_i = 0L;
      if (raw_i > 255L) raw_i = 255L;
      ee_wb((uint16_t)(base + 9u), (uint8_t)raw_i); }
}
static void calib_ee_read_entry(uint16_t base, CalibEntry *e) {
    e->p_mv    = (float)ee_read_int24 (base)                  / 100.0f;
    e->ppm     = (long) ee_read_uint24((uint16_t)(base + 3u));
    e->band_mv = (float)ee_read_int24 ((uint16_t)(base + 6u)) / 100.0f;
    /* CHANGE 7: sf: unsigned raw value * 0.02 -- see calib_ee_write_entry
     * for full rationale. (Was: 1.0 + signed_raw * 0.05.) */
    e->sf      = (float)ee_rb((uint16_t)(base + 9u)) * 0.02f;
}

static void calib_save_all(uint16_t magic_addr, uint16_t data_addr,
                            CalibEntry *tbl) {
    ee_wb(magic_addr, CALIB_EE_MAGIC_INVAL);
    for (uint8_t i = 0; i < CALIB_N; i++) {
        uint16_t base = (uint16_t)(data_addr + (uint16_t)i * CALIB_ENTRY_EE_BYTES);
        calib_ee_write_entry(base, &tbl[i]);
    }
    ee_wb(magic_addr, CALIB_EE_MAGIC_VAL);
}
static void calib_save_entry(uint16_t magic_addr, uint16_t data_addr,
                              CalibEntry *tbl, uint8_t idx) {
    ee_wb(magic_addr, CALIB_EE_MAGIC_INVAL);
    uint16_t base = (uint16_t)(data_addr + (uint16_t)idx * CALIB_ENTRY_EE_BYTES);
    calib_ee_write_entry(base, &tbl[idx]);
    ee_wb(magic_addr, CALIB_EE_MAGIC_VAL);
}
static void calib_load(uint16_t magic_addr, uint16_t data_addr,
                        CalibEntry *tbl, const CalibEntry *defaults) {
    if (ee_rb(magic_addr) != CALIB_EE_MAGIC_VAL) {
        for (uint8_t i = 0; i < CALIB_N; i++) tbl[i] = defaults[i];
        calib_save_all(magic_addr, data_addr, tbl);
    } else {
        for (uint8_t i = 0; i < CALIB_N; i++) {
            uint16_t base = (uint16_t)(data_addr + (uint16_t)i * CALIB_ENTRY_EE_BYTES);
            calib_ee_read_entry(base, &tbl[i]);
        }
    }
}

static float stored_mother_baseline = -999999.0f;
static bool  mother_baseline_valid  = false;

static void mb_ee_save(float mb) {
    ee_wb(MB_EE_MAGIC_ADDR, 0x00u);
    ee_write_float(MB_EE_DATA_ADDR, mb);
    ee_wb(MB_EE_MAGIC_ADDR, MB_EE_MAGIC_VAL);
}
static void mb_ee_load(void) {
    if (ee_rb(MB_EE_MAGIC_ADDR) == MB_EE_MAGIC_VAL) {
        stored_mother_baseline = ee_read_float(MB_EE_DATA_ADDR);
        mother_baseline_valid  = true;
    } else {
        mother_baseline_valid  = false;
    }
}

/* ee_write_u16/ee_read_u16: generic 2-byte little-endian helpers, used
 * below for the various fixed-point PARAMS fields. */
static void ee_write_u16(uint16_t addr, uint16_t v) {
    ee_wb(addr,              (uint8_t)(v & 0xFF));
    ee_wb((uint16_t)(addr+1),(uint8_t)(v >> 8));
}
static uint16_t ee_read_u16(uint16_t addr) {
    return (uint16_t)(ee_rb(addr) | ((uint16_t)ee_rb((uint16_t)(addr+1)) << 8));
}

static void params_ee_save(void) {
    uint16_t a = PARAMS_EE_DATA_ADDR;
    ee_wb(PARAMS_EE_MAGIC_ADDR, PARAMS_EE_MAGIC_INVAL);
    ee_write_float(a, P.jmp);            a += 4;
    ee_write_float(a, P.alp);            a += 4;
    /* upG/inG/dnG/dnI: uint16/int16 x10 (0.1 precision, range +-3276.7).
     * Saves 2 bytes each vs float (was 4B, now 2B). */
    { ee_write_u16(a, (uint16_t)(P.upG * 10.0f + 0.5f)); a += 2; }
    { ee_write_u16(a, (uint16_t)(P.inG * 10.0f + 0.5f)); a += 2; }
    { ee_write_u16(a, (uint16_t)(P.dnG * 10.0f + 0.5f)); a += 2; }
    { int16_t v = (int16_t)(P.dnI * 10.0f + (P.dnI >= 0.0f ? 0.5f : -0.5f));
      ee_write_u16(a, (uint16_t)v); a += 2; }
    ee_write_float(a, P.rec);            a += 4;
    ee_write_float(a, P.drf);            a += 4;
    /* n_thresh: uint16 x10000 (same style as n_thresh_low). Saves 2 bytes. */
    { ee_write_u16(a, (uint16_t)(P.n_thresh * 10000.0f + 0.5f)); a += 2; }
    ee_wb(a,     (uint8_t)(P.o_cap & 0xFF));
    ee_wb(a + 1, (uint8_t)(P.o_cap >> 8));   a += 2;
    ee_write_float(a, P.rec_zero_pct);   a += 4;
    ee_wb(a,     (uint8_t)(P.warmup & 0xFF));
    ee_wb(a + 1, (uint8_t)(P.warmup >> 8));  a += 2;
    /* or_thresh: uint16 x10 (0.1 mV precision, range 0..6553.5 mV). Saves 2 bytes. */
    { ee_write_u16(a, (uint16_t)(P.or_thresh * 10.0f + 0.5f)); a += 2; }
    ee_write_float(a, P.or_exit_mv);     a += 4;
    /* or_sd_stable: uint8 x1000000 saves 3 bytes vs float.
     * default 0.000020 -> stored as 20. range 0.000001..0.000255 */
    { ee_wb(a, (uint8_t)(P.or_sd_stable * 1000000.0f + 0.5f)); a += 1; }
    ee_write_float(a, P.daughter_mother_prox); a += 4;
    /* post_high_conc_thresh: uint24 raw ppm (exact value, up to 16,777,215).
     * Saves 1 byte vs float. */
    { ee_write_uint24(a, (uint32_t)(P.post_high_conc_thresh + 0.5f)); a += 3; }
    ee_wb(a,     (uint8_t)(P.post_high_counter_limit & 0xFF));
    ee_wb(a + 1, (uint8_t)(P.post_high_counter_limit >> 8)); a += 2;
    /* post_high_upG / post_high_inG: uint16 x10, same as upG/inG above. */
    { ee_write_u16(a, (uint16_t)(P.post_high_upG * 10.0f + 0.5f)); a += 2; }
    { ee_write_u16(a, (uint16_t)(P.post_high_inG * 10.0f + 0.5f)); a += 2; }
    /* Dynamic threshold fields -- stored as uint16 to save 4 bytes of EEPROM.
     * n_thresh_low: round(val*10000): 0.002->20, 0.1->1000 (fits uint16).
     * n_thresh_ppm_thresh: integer ppm, 0..65535 is sufficient. */
    { uint16_t ntl = (uint16_t)(P.n_thresh_low * 10000.0f + 0.5f);
      ee_wb(a, (uint8_t)(ntl & 0xFF)); ee_wb(a+1, (uint8_t)(ntl >> 8)); a += 2; }
    /* n_thresh_ppm_thresh stored as uint8 x100: 3000 -> 30, max 25500 ppm (uint8 max 255*100) */
    { ee_wb(a, (uint8_t)((uint16_t)P.n_thresh_ppm_thresh / 100u)); a += 1; }
    /* sf_step stored as uint8 x1000: 0.05 -> 50, range 0.001..0.255 */
    { ee_wb(a, (uint8_t)(P.sf_step * 1000.0f + 0.5f)); a += 1; }
    /* an_reset_thresh_mv stored as uint8 raw: range 1..99 mV (addr 0xE5) */
    { ee_wb(a, (uint8_t)(P.an_reset_thresh_mv + 0.5f)); a += 1; }
    /* ref_val / limit_val / offset_val are no longer part of this block.
     * They live in the dedicated SCALAR block (see scalar_ee_save/load). */
    (void)a;   /* suppress unused-variable warning */
    ee_wb(PARAMS_EE_MAGIC_ADDR, PARAMS_EE_MAGIC_VAL);
}

static void params_ee_load(void) {
    if (ee_rb(PARAMS_EE_MAGIC_ADDR) != PARAMS_EE_MAGIC_VAL) {
        P = DEFAULT_PARAMS;
        return;
    }
    uint16_t a = PARAMS_EE_DATA_ADDR;
    P.jmp                  = ee_read_float(a); a += 4;
    P.alp                  = ee_read_float(a); a += 4;
    /* upG/inG/dnG/dnI: uint16/int16 x10 (see params_ee_save) */
    { P.upG = (float)ee_read_u16(a) / 10.0f; a += 2; }
    { P.inG = (float)ee_read_u16(a) / 10.0f; a += 2; }
    { P.dnG = (float)ee_read_u16(a) / 10.0f; a += 2; }
    { int16_t v = (int16_t)ee_read_u16(a); P.dnI = (float)v / 10.0f; a += 2; }
    P.rec                  = ee_read_float(a); a += 4;
    P.drf                  = ee_read_float(a); a += 4;
    /* n_thresh: uint16 x10000 */
    { P.n_thresh = (float)ee_read_u16(a) / 10000.0f; a += 2; }
    P.o_cap  = (uint16_t)(ee_rb(a) | ((uint16_t)ee_rb(a+1) << 8)); a += 2;
    P.rec_zero_pct         = ee_read_float(a); a += 4;
    P.warmup = (uint16_t)(ee_rb(a) | ((uint16_t)ee_rb(a+1) << 8)); a += 2;
    /* or_thresh: uint16 x10 */
    { P.or_thresh = (float)ee_read_u16(a) / 10.0f; a += 2; }
    P.or_exit_mv           = ee_read_float(a); a += 4;
    /* or_sd_stable: uint8 x1000000 */
    { uint8_t sv = ee_rb(a); a += 1;
      P.or_sd_stable = (sv > 0u) ? ((float)sv / 1000000.0f) : DEFAULT_PARAMS.or_sd_stable; }
    P.daughter_mother_prox = ee_read_float(a); a += 4;
    /* post_high_conc_thresh: uint24 raw ppm */
    { P.post_high_conc_thresh = (float)ee_read_uint24(a); a += 3; }
    P.post_high_counter_limit =
        (uint16_t)(ee_rb(a) | ((uint16_t)ee_rb(a+1) << 8)); a += 2;
    /* post_high_upG / post_high_inG: uint16 x10 */
    { P.post_high_upG = (float)ee_read_u16(a) / 10.0f; a += 2; }
    { P.post_high_inG = (float)ee_read_u16(a) / 10.0f; a += 2; }
    /* Dynamic threshold fields -- loaded from uint16 (see params_ee_save) */
    { uint16_t ntl = (uint16_t)(ee_rb(a) | ((uint16_t)ee_rb(a+1) << 8)); a += 2;
      P.n_thresh_low = (float)ntl / 10000.0f; }
    /* n_thresh_ppm_thresh: uint8 x100 */
    { P.n_thresh_ppm_thresh = (float)((uint16_t)ee_rb(a) * 100u); a += 1; }
    /* sf_step: uint8 x1000 */
    { uint8_t sv = ee_rb(a); a += 1;
      P.sf_step = (sv > 0u) ? ((float)sv / 1000.0f) : DEFAULT_PARAMS.sf_step; }
    /* an_reset_thresh_mv: uint8 raw (addr 0xE5); range 1..99 mV */
    { uint8_t av = ee_rb(a); a += 1;
      P.an_reset_thresh_mv = (av >= 1u && av <= 99u) ? (float)av : DEFAULT_PARAMS.an_reset_thresh_mv; }
    (void)a;

    /* ref_val / limit_val / offset_val are loaded from the dedicated SCALAR
     * block (scalar_ee_load), NOT from this params block.  Do not read them
     * here ? they were removed to prevent the 89-byte rewrite hazard. */

    /* ----------------------------------------------------------------
     * Sanity-check detection parameters.
     * If any critical field is out of range, reset detection params to
     * defaults.  ref_val / limit_val / offset_val are unaffected because
     * they are no longer stored in this block.
     * ---------------------------------------------------------------- */
    if (P.o_cap == 0 || P.o_cap > 2000 ||
        P.n_thresh <= 0.0f || P.n_thresh > 1.0f ||
        P.warmup == 0 || P.warmup > 400) {
        P = DEFAULT_PARAMS;
    }
    /* Sanity-check new fields ? fall back to defaults if corrupt */
    if (P.n_thresh_low <= 0.0f || P.n_thresh_low > 1.0f)
        P.n_thresh_low = DEFAULT_PARAMS.n_thresh_low;
    if (P.n_thresh_ppm_thresh <= 0.0f || P.n_thresh_ppm_thresh > 25500.0f)
        P.n_thresh_ppm_thresh = DEFAULT_PARAMS.n_thresh_ppm_thresh;
    if (P.sf_step <= 0.0f || P.sf_step > 0.255f)
        P.sf_step = DEFAULT_PARAMS.sf_step;
    if (P.an_reset_thresh_mv < 1.0f || P.an_reset_thresh_mv > 99.0f)
        P.an_reset_thresh_mv = DEFAULT_PARAMS.an_reset_thresh_mv;
}

/* ------------------------------------------------------------------ */
/*  SCALAR EEPROM  ? ref_val / limit_val / offset_val                 */
/*                                                                      */
/*  Stored in their own 8-byte block with independent magic so that:   */
/*  1. Saving them writes only 7 data bytes (~30 ms) ? tiny power-loss */
/*     window versus the old ~300 ms full-params rewrite.              */
/*  2. Detection-param corruption / reset never touches these values.   */
/* ------------------------------------------------------------------ */
static void scalar_ee_save(void) {
    uint16_t a = SCALAR_EE_DATA_ADDR;
    ee_wb(SCALAR_EE_MAGIC_ADDR, SCALAR_EE_MAGIC_INVAL);
    ee_write_long(a, P.ref_val);                                      a += 4;
    ee_wb(a,     (uint8_t)(P.limit_val & 0xFF));
    ee_wb(a + 1, (uint8_t)(P.limit_val >> 8));                        a += 2;
    ee_wb(a,     P.offset_val);
    ee_wb(SCALAR_EE_MAGIC_ADDR, SCALAR_EE_MAGIC_VAL);
}
static void scalar_ee_load(void) {
    if (ee_rb(SCALAR_EE_MAGIC_ADDR) != SCALAR_EE_MAGIC_VAL) {
        /* First boot or EEPROM not yet written ? keep defaults (ref=0, offset=30) */
        return;
    }
    uint16_t a = SCALAR_EE_DATA_ADDR;
    P.ref_val   = ee_read_long(a);                                     a += 4;
    P.limit_val = (uint16_t)(ee_rb(a) | ((uint16_t)ee_rb(a+1) << 8)); a += 2;
    P.offset_val = ee_rb(a);
    if (P.offset_val > 100) P.offset_val = 30u;
}

/* ------------------------------------------------------------------ */
/* ------------------------------------------------------------------ */
static float vlu(float v, const RampEntry *tbl, uint8_t n) {
    float r = tbl[0].val;
    for (uint8_t i = 0; i < n; i++) {
        if (v >= tbl[i].key) r = tbl[i].val; else break;
    }
    return r;
}
static float vlu_sd(float v, const RampEntry *tbl, uint8_t n) {
    float r = tbl[0].val;
    for (uint8_t i = 0; i < n; i++) { if (v >= tbl[i].key) r = tbl[i].val; }
    return r;
}

/*
 * calib_eff_mv ? returns the EFFECTIVE centre EMF for a row, i.e. the
 * original table p_mv scaled dynamically by that row's sf.
 *
 * CHANGE 5 ? Dynamic SF application (replaces "bake sf into p_mv"):
 * Rows are NEVER pre-multiplied/stored scaled anymore; p_mv in RAM/EEPROM
 * always holds the original, un-scaled calibration point. sf (1.0 for
 * every row below CALIB_HIGH_PPM, adjustable via *1CAL for rows >=
 * CALIB_HIGH_PPM) is applied on the fly, here, every time it's needed.
 * This produces numerically identical results to the old "bake sf into
 * p_mv" approach, without ever overwriting the raw calibration point.
 */
static inline float calib_eff_mv(const CalibEntry *e) {
    return e->p_mv * e->sf;
}

/*
 * calib_interp ? band-aware calibration, mirrors Python calib_interp().
 *
 * Each CalibEntry: p_mv (centre EMF), ppm (target), band_mv (?tolerance).
 * band_mv == 0.0 ? pure interpolation breakpoint (original behaviour).
 * The effective centre used throughout is p_mv * sf (see calib_eff_mv) ?
 * band_mv itself is never scaled, exactly mirroring the old behaviour
 * where *1CAL only ever scaled p_mv and left band_mv untouched.
 *
 * Algorithm:
 *   1. Clamp low:  p_val <= eff0 - tbl[0].band_mv       ? return tbl[0].ppm
 *   2. Clamp high: p_val >= effN + tbl[N-1].band_mv      ? return tbl[N-1].ppm
 *   3. Snap:       for each row, if p_val in [eff-band, eff+band] ? return ppm
 *   4. Interpolate between adjacent band edges:
 *        seg_lo = eff_i     + tbl[i].band_mv     (upper edge of row i band)
 *        seg_hi = eff_{i+1} - tbl[i+1].band_mv   (lower edge of row i+1 band)
 *        if seg_lo <= p_val <= seg_hi:
 *            t = (p_val - seg_lo) / (seg_hi - seg_lo)
 *            return round(ppm_i + t * (ppm_{i+1} - ppm_i))
 */
static long calib_interp(float p_val, const CalibEntry *tbl) {
    /* Step 1/2: clamp at boundaries using band edges around the effective (sf-scaled) centre */
    float emf0  = calib_eff_mv(&tbl[0]),           band0  = tbl[0].band_mv;
    float emfN  = calib_eff_mv(&tbl[CALIB_N-1]),   bandN  = tbl[CALIB_N-1].band_mv;

    if (p_val <= emf0 - band0)  return tbl[0].ppm;
    if (p_val >= emfN + bandN)  return tbl[CALIB_N-1].ppm;

    /* Step 3: snap to ppm if inside any band */
    for (uint8_t i = 0; i < CALIB_N; i++) {
        float eff = calib_eff_mv(&tbl[i]);
        float lo = eff - tbl[i].band_mv;
        float hi = eff + tbl[i].band_mv;
        if (p_val >= lo && p_val <= hi)
            return tbl[i].ppm;
    }

    /* Step 4: interpolate between adjacent band edges */
    for (uint8_t i = 0; i < CALIB_N - 1u; i++) {
        float eff_i   = calib_eff_mv(&tbl[i]);
        float eff_ip1 = calib_eff_mv(&tbl[i+1]);
        float seg_lo = eff_i   + tbl[i].band_mv;     /* upper edge of row i   */
        float seg_hi = eff_ip1 - tbl[i+1].band_mv;   /* lower edge of row i+1 */
        if (p_val >= seg_lo && p_val <= seg_hi) {
            float span = seg_hi - seg_lo;
            if (span <= 0.0f) return tbl[i].ppm;
            float t = (p_val - seg_lo) / span;
            float interp = (float)tbl[i].ppm + t * (float)(tbl[i+1].ppm - tbl[i].ppm);
            return (long)(interp + 0.5f);
        }
    }

    return tbl[CALIB_N-1].ppm;
}

/* ------------------------------------------------------------------ */
/*  ENGINE RING BUFFERS                                                */
/* ------------------------------------------------------------------ */
#define C_WIN  7
static float   c_buf[C_WIN];
static uint8_t c_head   = 0;
static uint8_t c_filled = 0;

static void c_push(float v) {
    c_buf[c_head] = v;
    c_head = (c_head + 1) % C_WIN;
    if (c_filled < C_WIN) c_filled++;
}
static float c_get(uint8_t k) {
    int idx = (int)c_head - 1 - (int)k;
    while (idx < 0) idx += C_WIN;
    return c_buf[(uint8_t)idx];
}

#define SD_WIN  6
static float   sd_buf[SD_WIN];
static uint8_t sd_head = 0;

static float sd_push(float v) {
    sd_buf[sd_head] = v;
    sd_head = (sd_head + 1) % SD_WIN;
    float sum = 0.0f, mean, var = 0.0f;
    for (uint8_t i = 0; i < SD_WIN; i++) sum += sd_buf[i];
    mean = sum / SD_WIN;
    for (uint8_t i = 0; i < SD_WIN; i++) {
        float d = sd_buf[i] - mean; var += d * d;
    }
    return sqrtf(var / SD_WIN);
}

/*
 * Warmup ring buffer ? always sized at WARMUP_COLLECTION_SAMPLES (400).
 * P.warmup is no longer used to size this buffer.
 */
#define WARMUP_BUF_MAX  400
static float    wu_buf[WARMUP_BUF_MAX];
static uint16_t wu_head   = 0;
static uint16_t wu_filled = 0;
static float    wu_sum    = 0.0f;

static void wu_push(float v) {
    /* Always use the full 400-sample capacity */
    if (wu_filled < WARMUP_BUF_MAX) {
        wu_buf[wu_head] = v;
        wu_head = (wu_head + 1) % WARMUP_BUF_MAX;
        wu_filled++;
        wu_sum += v;
    } else {
        wu_sum -= wu_buf[wu_head];
        wu_buf[wu_head] = v;
        wu_head = (wu_head + 1) % WARMUP_BUF_MAX;
        wu_sum += v;
    }
}
static float wu_mean(void) {
    return (wu_filled > 0) ? wu_sum / (float)wu_filled : 0.0f;
}
static float wu_sd(void) __attribute__((unused));
static float wu_sd(void) {
    if (wu_filled < 2) return 999.0f;   /* not enough data ? force fail */
    float mean = wu_sum / (float)wu_filled, var = 0.0f;
    for (uint16_t i = 0; i < wu_filled; i++)
        var += (wu_buf[i] - mean) * (wu_buf[i] - mean);
    return sqrtf(var / (float)wu_filled);
}
static void wu_reset(void) { wu_head = 0; wu_filled = 0; wu_sum = 0.0f; }

/* ------------------------------------------------------------------
 * 50-sample rolling SD buffer used during WARMUP_CHECKING phase.
 * Separate from wu_buf so the 400-sample mean stays intact for prox
 * check and baseline seeding.
 * ------------------------------------------------------------------ */
static float    wu_chk_buf[WARMUP_CHECK_SAMPLES];
static uint8_t  wu_chk_head   = 0;
static uint8_t  wu_chk_filled = 0;
static float    wu_chk_sum    = 0.0f;

static void wu_chk_push(float v) {
    /* Non-overlapping window: only accept samples until the 50-slot buffer
     * is full. Caller must call wu_chk_reset() to start the next window. */
    if (wu_chk_filled < WARMUP_CHECK_SAMPLES) {
        wu_chk_buf[wu_chk_head] = v;
        wu_chk_head = (wu_chk_head + 1) % WARMUP_CHECK_SAMPLES;
        wu_chk_filled++;
        wu_chk_sum += v;
    }
    /* If already full: silently ignore until reset ? window is evaluated first. */
}
static float wu_chk_sd(void) {
    if (wu_chk_filled < 2) return 999.0f;   /* not enough data ? force fail */
    float mean = wu_chk_sum / (float)wu_chk_filled, var = 0.0f;
    for (uint8_t i = 0; i < wu_chk_filled; i++) {
        float d = wu_chk_buf[i] - mean; var += d * d;
    }
    return sqrtf(var / (float)wu_chk_filled);
}
static void wu_chk_reset(void) { wu_chk_head = 0; wu_chk_filled = 0; wu_chk_sum = 0.0f; }

/* ------------------------------------------------------------------ */
/*  DETECTION ENGINE STATE                                             */
/* ------------------------------------------------------------------ */

/*
 * WarmupPhase:
 *
 *   WARMUP_COLLECTING : first 400 samples fill wu_buf. Col 8 = 0.
 *                       SD not evaluated during this phase.
 *
 *   WARMUP_CHECKING   : >= 400 samples collected. A separate 50-sample
 *                       non-overlapping window (wu_chk_buf) is started.
 *                       Samples accumulate silently until exactly 50 are in,
 *                       then both conditions are evaluated ONCE:
 *                         cond_sd   = wu_chk_sd() < WARMUP_SD_THRESH
 *                         cond_prox = ignore_prox
 *                                     OR !mother_baseline_valid
 *                                     OR |wu_mean() - stored_MB| <= WARMUP_PROX_MV
 *                       Both true  -> _full_reset_state(wu_mean()) -> WARMUP_RUNNING
 *                       Either false -> wu_chk_reset(), next 50-sample window begins
 *
 *   WARMUP_RUNNING    : engine active. Col 8 = 4.
 *
 * Two ways to reach WARMUP_RUNNING:
 *   1. Both SD + prox conditions pass -> _full_reset_state(wu_mean())
 *   2. User sends *TARE# at any point -> _full_reset_state(C_leaky)
 */
typedef enum {
    WARMUP_COLLECTING = 0,   /* gathering 400 samples     -> Col 8 = 0 */
    WARMUP_CHECKING   = 1,   /* SD/prox failing, looping  -> Col 8 = 1 */
    WARMUP_RUNNING    = 4,   /* engine active             -> Col 8 = 4 */
} WarmupPhase;

typedef enum { OR_NORMAL=0, OR_OVERRANGE, OR_WAIT_DROP, OR_STABLE } OrState;

static uint32_t sample_count      = 0;
static float    C_leaky           = 0.0f;
