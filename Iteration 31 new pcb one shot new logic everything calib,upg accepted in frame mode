/*  UART                                                               */
/* ================================================================== */
void USART1_sendChar(char c) {
    while (!(USART1.STATUS & USART_DREIF_bm)) {} USART1.TXDATAL = c;
}
void USART1_sendStr(const char *s) { while (*s) USART1_sendChar(*s++); }
void tx_newline(void) { USART1_sendChar(0x0D); USART1_sendChar(0x0A); }
void USART1_sendUInt(uint32_t v) {
    char buf[11]; uint8_t i=0;
    if (v==0) { USART1_sendChar('0'); return; }
    while (v>0) { buf[i++]='0'+(v%10); v/=10; }
    while (i--) USART1_sendChar(buf[i]);
}
void USART1_sendLong(long v) {
    if (v<0) { USART1_sendChar('-'); v=-v; }
    USART1_sendUInt((uint32_t)v);
}
void USART1_sendFloat(float v, uint8_t decimals) {
    if (v < 0.0f) { USART1_sendChar('-'); v = -v; }
    float mult = 1.0f;
    for (uint8_t i = 0; i < decimals; i++) mult *= 10.0f;
    long full = (long)(v * mult + 0.5f);
    long iv   = full / (long)mult;
    long frac = full % (long)mult;
    USART1_sendUInt((uint32_t)iv); USART1_sendChar('.');
    long fmult = (long)mult / 10;
    while (fmult > 1 && frac < fmult) { USART1_sendChar('0'); fmult /= 10; }
    if (frac > 0) USART1_sendUInt((uint32_t)frac); else USART1_sendChar('0');
}
static void tx_flush(void) {
    /* Wait for TX shift register to drain after a transmission.
     * Only call this when you know at least one byte was sent. */
    while (!(USART1.STATUS & USART_TXCIF_bm)) {}
    USART1.STATUS = USART_TXCIF_bm;
}

/* rx_enable_no_flush() ? re-enable the RX ISR without waiting for TX
 * completion. Used after command processing where no TX bytes were sent
 * (e.g. frame-mode commands that produce no ACK). Calling tx_flush() in
 * that case hangs forever because TXCIF is never set with no transmission. */
static inline void rx_enable_no_flush(void) {
    (void)USART1.RXDATAL;               /* drain any loopback byte */
    USART1.STATUS = USART_RXCIF_bm;    /* clear RX complete flag   */
    USART1.CTRLA |= USART_RXCIE_bm;    /* re-enable RX interrupt   */
}

/*
 * RS-485 loopback guard.
 * With RS485 mode enabled, every TX byte loops back into RX and fires the
 * RXC ISR. Binary frame bytes can contain 0x2A ('*') and 0x23 ('#'),
 * causing the ISR to falsely parse a command, corrupt company[], set
 * cmd_ready, and trigger process_cmd() with garbage ? which resets engine
 * state mid-run. Fix: disable RX interrupt for the duration of each TX
 * burst, then drain the loopback byte and re-enable.
 */
static inline void rx_disable(void) {
    USART1.CTRLA &= ~USART_RXCIE_bm;
}
static inline void rx_enable(void) {
    tx_flush();                          /* wait until last bit has left */
    (void)USART1.RXDATAL;               /* drain any loopback byte in RX buf */
    USART1.STATUS = USART_RXCIF_bm;    /* clear RX complete flag            */
    USART1.CTRLA |= USART_RXCIE_bm;    /* re-enable RX interrupt            */
}

/*
 * tx_ack() ? send an ASCII acknowledgement string only in continuous mode.
 * In frame mode, ACK strings corrupt the binary frame stream on the host,
 * so they are silently suppressed. do_stop() uses this for OK_STOPPED too;
 * the binary stopped-frame is the implicit ack in frame mode.
 */
static inline void tx_ack(const char *s) {
    if (run_mode_state != MODE_FRAME) USART1_sendStr(s);
}

