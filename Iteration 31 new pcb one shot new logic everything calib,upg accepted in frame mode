/* ================================================================== */
/*  FULL STATE RESET                                                   */
/* ================================================================== */
static void _full_reset_state(float new_base) {
    daughter_baseline = new_base;
    mother_baseline   = new_base;
    baseline_seeded   = true;
    peak_M            = 0.0f;
    M_prev            = 0.0f;
    force_recovered   = true;
    warmup_phase      = WARMUP_RUNNING;
    tare_blank_count  = TARE_BLANK_SAMPLES;

    for (uint8_t i = 0; i < C_WIN;  i++) c_buf[i]  = new_base;
    for (uint8_t i = 0; i < SD_WIN; i++) sd_buf[i]  = new_base;
    c_head = 0; c_filled = C_WIN;
    sd_head = 0;
    J_sd = 0.0f;
    wu_reset();
    wu_chk_reset();

    cnt_D = 0;  acc_E = 0.0f;
    cnt_F = 0;  acc_G = 0.0f;
    II      = -1.0f;
    II_prev = -1.0f;
    N_accum = 0.0f;
    O_roc   = 0;
    P_clip  = 0.0f;
    Q_ppm   = 0; R_ppm = 0; S_ppm = 0;
    an_override = false;
    rec_pct = 100.0f;
    M_delta = 0.0f;

    or_state          = OR_NORMAL;
    or_seen_overrange = false;
    or_armed          = false;
    or_high_count     = 0;
    tare_count++;

    post_high_active   = false;
    post_high_counter  = 0;
    post_high_saw_high = false;

    mb_ee_save(new_base);
    stored_mother_baseline = new_base;
    mother_baseline_valid  = true;
}

static void do_calibrate(void) { _full_reset_state(C_leaky); tx_ack("OK_CAL\r\n"); }

/* ================================================================== */
/*  ONE-SHOT CALIBRATION  (*1CAL <ppm>#)                              */
/*                                                                     */
/*  Mirrors Python _compute_calibration_preview() + _apply_calibration().*/
/*                                                                     */
/*  Algorithm:                                                         */
/*   1. Use current P_clip (fast DELTA-EMF) and N_accum (anal DELTA-EMF).*/
/*   2. Look up the existing table EMF at the user-supplied ref ppm.  */
/*   3. Compute base SF = measured_emf / table_emf_at_ref_ppm.        */
/*   4. For every row with ppm >= 5000: adjust SF per cross-conc table*/
/*      using P.sf_step:                                               */
/*        N steps ABOVE ref -> SF /= (1 + N*sf_step)                  */
/*        N steps BELOW ref -> SF *= (1 + N*sf_step)                  */
/*   5. Store adjusted SF into that row's .sf field ONLY -- p_mv is    */
/*      NEVER modified/baked. calib_interp() multiplies p_mv * sf      */
/*      dynamically on every lookup instead (see calib_eff_mv()).      */
/*      Save both tables to EEPROM.                                    */
/*                                                                     */
/*  Valid ref ppm tiers: 5000, 10000, 20000, 100000.                  */
/*  Does NOT alter rows with ppm < 5000 (sub-5k anchor rows: sf stays  */
/*  pinned at 1.00 always -- see do_reset_cal() for how to force it    */
/*  back to 1.00 on the high-ppm rows too).                            */
/*  Does NOT do _full_reset_state() -- this is purely a table update. */
/*  The old *CAL# command is COMPLETELY UNCHANGED.                     */
/* ================================================================== */

/* Tier table: 5000, 10000, 20000, 100000 in ascending order */
static const long CALIB_TIERS[4] = { 5000L, 10000L, 20000L, 100000L };
#define CALIB_TIERS_N  4
#define CALIB_HIGH_PPM 5000L   /* rows below this ppm are not scaled */

/* Return tier index (0-3) for ppm, or -1 if not a tier */
static int8_t tier_idx(long ppm) {
    for (uint8_t i = 0; i < CALIB_TIERS_N; i++)
        if (ppm == CALIB_TIERS[i]) return (int8_t)i;
    return -1;
}

/* Return the p_mv from a table at the exact ref_ppm breakpoint, or -1.0 if not found */
static float table_emf_at_ppm(const CalibEntry *tbl, long ref_ppm) {
    for (uint8_t i = 0; i < CALIB_N; i++)
        if (tbl[i].ppm == ref_ppm) return tbl[i].p_mv;
    return -1.0f;
}

static void do_oneshot_calib(long ref_ppm) {
    /* Allowed in both continuous and frame mode.
     * In frame mode the calibration executes normally; ASCII responses
     * are suppressed via tx_ack() so the binary stream is not corrupted. */

    /* Validate ref ppm is one of the four tiers */
    int8_t ref_i = tier_idx(ref_ppm);
    if (ref_i < 0) {
        tx_ack("ERR_1CAL: ppm must be 5000/10000/20000/100000\r\n");
        return;
    }

    /* Read current measured DELTA-EMF values:
     *   P_clip  = fast path (clipped accumulator)  -> mirrors Python P
     *   N_accum = analytical path (bulk accumulator) -> mirrors Python N
     * These are valid only when engine is running and signal is UP.
     * If probe is in AIR (II==-1, rec==100), both will be ~0; warn user.
     */
    float fast_emf = P_clip;
    float anal_emf = N_accum;

    if (fast_emf <= 0.0f || anal_emf <= 0.0f) {
        tx_ack("ERR_1CAL: no valid DELTA-EMF (expose sensor to ref gas first)\r\n");
        return;
    }

    /* Look up existing table EMF at ref ppm */
    float fast_ref_emf = table_emf_at_ppm(CALIB_FAST, ref_ppm);
    float anal_ref_emf = table_emf_at_ppm(CALIB_AN,   ref_ppm);

    if (fast_ref_emf <= 0.0f) {
        tx_ack("ERR_1CAL: ref ppm not in FAST table\r\n");
        return;
    }
    if (anal_ref_emf <= 0.0f) {
        tx_ack("ERR_1CAL: ref ppm not in AN table\r\n");
        return;
    }

    /* Base scale factors */
    float sf_fast_base = fast_emf / fast_ref_emf;
    float sf_anal_base = anal_emf / anal_ref_emf;

    /* Apply cross-concentration SF adjustment and scale tables.
     * CALIB_FAST and CALIB_AN share the same ppm layout, so one loop
     * covers both tables.  AN rows are looked up by ppm, not by index,
     * to be safe against any future layout divergence.
     */
    for (uint8_t i = 0; i < CALIB_N; i++) {
        /* ---- Fast table row i ---- */
        if (CALIB_FAST[i].ppm >= CALIB_HIGH_PPM) {
            int8_t tgt_i = tier_idx(CALIB_FAST[i].ppm);
            float sf_f;
            if (tgt_i < 0) {
                sf_f = sf_fast_base;  /* non-tier row: use base SF */
            } else {
                int8_t steps = tgt_i - ref_i;
                float steps_abs = (steps < 0) ? -(float)steps : (float)steps;
                float divisor = 1.0f + steps_abs * P.sf_step;
                sf_f = (steps > 0) ? sf_fast_base / divisor
                      :(steps < 0) ? sf_fast_base * divisor
                      : sf_fast_base;
            }
            /* CHANGE 5: do NOT bake sf into p_mv anymore -- p_mv stays the
             * original, un-scaled calibration point forever. Only sf is
             * updated; calib_interp() applies it dynamically at lookup
             * time (p_mv * sf). Net effect on predicted ppm is identical. */
            CALIB_FAST[i].sf    = sf_f;
        }
        /* ---- Analytical table row i ---- */
        if (CALIB_AN[i].ppm >= CALIB_HIGH_PPM) {
            int8_t tgt_i = tier_idx(CALIB_AN[i].ppm);
            float sf_a;
            if (tgt_i < 0) {
                sf_a = sf_anal_base;
            } else {
                int8_t steps = tgt_i - ref_i;
                float steps_abs = (steps < 0) ? -(float)steps : (float)steps;
                float divisor = 1.0f + steps_abs * P.sf_step;
                sf_a = (steps > 0) ? sf_anal_base / divisor
                      :(steps < 0) ? sf_anal_base * divisor
                      : sf_anal_base;
            }
            /* CHANGE 5: p_mv left untouched -- see FAST-table comment above. */
            CALIB_AN[i].sf    = sf_a;
        }
    }

    /* Save both tables to EEPROM atomically */
    calib_save_all(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST);
    calib_save_all(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN);

    /* Report result.
     * Called from inside process_cmd() which already holds rx_disable().
     * Do NOT call rx_disable()/rx_enable() here -- the caller owns them. */
    if (run_mode_state != MODE_FRAME) {
        USART1_sendStr("OK_1CAL ref="); USART1_sendLong(ref_ppm);
        USART1_sendStr("ppm SFf="); USART1_sendFloat(sf_fast_base, 5);
        USART1_sendStr(" SFa="); USART1_sendFloat(sf_anal_base, 5);
        USART1_sendStr(" step="); USART1_sendFloat(P.sf_step, 4);
        USART1_sendStr("\r\n");
    }
}

/* ================================================================== */
/*  RESET CALIBRATION SCALING FACTOR  (*RESETCAL#)                    */
/*                                                                     */
/*  Sets sf = 1.00 on every row of BOTH CALIB_FAST and CALIB_AN, then  */
/*  saves both tables to EEPROM. p_mv, ppm, band_mv are left           */
/*  completely untouched (they are never altered by *1CAL either).     */
/*  Since calib_interp() always multiplies p_mv * sf on the fly, this  */
/*  instantly and fully undoes every *1CAL scaling adjustment without  */
/*  needing to know or restore any original p_mv values.               */
/* ================================================================== */
static void do_reset_cal(void) {
    for (uint8_t i = 0; i < CALIB_N; i++) {
        CALIB_FAST[i].sf = 1.0f;
        CALIB_AN[i].sf   = 1.0f;
    }
    calib_save_all(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST);
    calib_save_all(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN);
    tx_ack("OK_RESETCAL\r\n");
}

/* ================================================================== */
/*  10 PPM ONE-SHOT CALIBRATION  (*10CAL#)                           */
/*                                                                     */
/*  Updates ONLY the 10 ppm row in both CALIB_FAST and CALIB_AN.     */
/*  No scaling factor, no cross-concentration adjustment, nothing     */
/*  else is touched.                                                   */
/*                                                                     */
/*  Algorithm:                                                         */
/*   1. Use current P_clip (fast DELTA-EMF) and N_accum (anal DELTA-EMF).*/
/*   2. Find the row with ppm == 10 in each table.                    */
/*   3. Set that row's p_mv = measured DELTA-EMF directly.            */
/*   4. Save only those two rows to EEPROM.  All other rows, band_mv, */
/*      ppm values, and parameters are COMPLETELY UNCHANGED.           */
/* ================================================================== */
static void do_10ppm_calib(void) {
    /* Allowed in both continuous and frame mode.
     * In frame mode the calibration executes normally; ASCII responses
     * are suppressed via tx_ack() so the binary stream is not corrupted. */

    /* Read current measured DELTA-EMF values */
    float fast_emf = P_clip;
    float anal_emf = N_accum;

    if (fast_emf <= 0.0f || anal_emf <= 0.0f) {
        tx_ack("ERR_10CAL: no valid DELTA-EMF (expose sensor to 10ppm gas first)\r\n");
        return;
    }

    /* Find the 10 ppm row in each table */
    int8_t fast_idx = -1, an_idx = -1;
    for (uint8_t i = 0; i < CALIB_N; i++) {
        if (CALIB_FAST[i].ppm == 10L) fast_idx = (int8_t)i;
        if (CALIB_AN[i].ppm   == 10L) an_idx   = (int8_t)i;
    }

    if (fast_idx < 0) {
        tx_ack("ERR_10CAL: 10ppm row not found in FAST table\r\n");
        return;
    }
    if (an_idx < 0) {
        tx_ack("ERR_10CAL: 10ppm row not found in AN table\r\n");
        return;
    }

    /* Store old values for the report */
    float old_fast_mv = CALIB_FAST[fast_idx].p_mv;
    float old_an_mv   = CALIB_AN[an_idx].p_mv;

    /* Update ONLY the p_mv of the 10 ppm row -- ppm and band_mv stay unchanged */
    CALIB_FAST[fast_idx].p_mv = fast_emf;
    CALIB_AN[an_idx].p_mv     = anal_emf;

    /* Save ONLY these two individual rows to EEPROM */
    calib_save_entry(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST, (uint8_t)fast_idx);
    calib_save_entry(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN,   (uint8_t)an_idx);

    /* Report result (suppressed in frame mode to protect binary stream) */
    if (run_mode_state != MODE_FRAME) {
        USART1_sendStr("OK_10CAL fast_old="); USART1_sendFloat(old_fast_mv, 4);
        USART1_sendStr("mV fast_new=");       USART1_sendFloat(fast_emf, 4);
        USART1_sendStr("mV an_old=");         USART1_sendFloat(old_an_mv, 4);
        USART1_sendStr("mV an_new=");         USART1_sendFloat(anal_emf, 4);
        USART1_sendStr("mV\r\n");
    }
}

/*
 * do_tear() ? exits warmup immediately regardless of phase,
 * forces WARMUP_RUNNING via _full_reset_state().
 */
static void do_tear(void)      { _full_reset_state(C_leaky); tx_ack("OK_TEAR\r\n"); }

/* ================================================================== */
/*  DETECTION ENGINE  ?  one sample step                              */
/* ================================================================== */
static void engine_step(float emf_val) {
    sample_count++;

    if (sample_count == 1) {
        C_leaky = emf_val;
        for (uint8_t i = 0; i < C_WIN;  i++) c_buf[i]  = emf_val;
        for (uint8_t i = 0; i < SD_WIN; i++) sd_buf[i]  = emf_val;
        c_head = 0; c_filled = C_WIN; sd_head = 0;
        if (!baseline_seeded) { daughter_baseline = emf_val; mother_baseline = emf_val; }
        M_delta = emf_val - daughter_baseline;
        M_prev  = 0.0f; II_prev = II;
        wu_push(emf_val);
        return;
    }

    /* Leaky integrator */
    float C_prev = C_leaky;
    if (fabsf(emf_val - C_prev) > P.jmp)
        C_leaky = emf_val;
    else
        C_leaky = (emf_val - C_prev) * P.alp + C_prev;

    c_push(C_leaky);
    J_sd = sd_push(C_leaky);

    /* OR state machine */
    if (or_state != OR_NORMAL) {
        if (tare_count_at_or != tare_count) {
            or_state = OR_NORMAL; or_seen_overrange = false;
            or_armed = false; or_high_count = 0;
        }
    }
    if (emf_val > P.or_thresh) {
        or_high_count++;
        if (or_high_count >= OR_HIGH_REQ) or_armed = true;
    } else {
        or_high_count = 0;
    }
    switch (or_state) {
        case OR_NORMAL:
            or_seen_overrange = false;
            if (emf_val > P.or_thresh && or_armed) {
                or_state = OR_OVERRANGE; or_seen_overrange = true;
                tare_count_at_or = tare_count;
            }
            break;
        case OR_OVERRANGE:
            if (emf_val < P.or_exit_mv) or_state = OR_WAIT_DROP;
            break;
        case OR_WAIT_DROP:
            if (!or_armed) { /* blocked */ }
            else if (emf_val > P.or_thresh) {
                or_state = OR_OVERRANGE; or_seen_overrange = true;
                tare_count_at_or = tare_count;
            } else if (emf_val < P.or_exit_mv) {
                if (J_sd < P.or_sd_stable && or_seen_overrange && or_armed)
                    or_state = OR_STABLE;
            }
            break;
        case OR_STABLE:
            if (emf_val > P.or_thresh) {
                or_state = OR_OVERRANGE; or_seen_overrange = true;
                tare_count_at_or = tare_count;
            }
            break;
    }
    bool in_or = (or_state != OR_NORMAL);

    /* ----------------------------------------------------------------
     * WARMUP STATE MACHINE ? two-phase
     *
     * Phase 1: WARMUP_COLLECTING
     *   Push every clean (non-OR) sample into wu_buf (400-sample ring).
     *   Stay here until wu_filled reaches WARMUP_COLLECTION_SAMPLES.
     *   Col 8 = 0 throughout.
     *
     * Phase 2: WARMUP_CHECKING  (entered once 400 samples collected)
     *   A fresh 50-sample non-overlapping window (wu_chk_buf) is started.
     *   Samples accumulate silently until wu_chk_filled == 50.
     *   At exactly 50 samples both conditions are evaluated ONCE:
     *     cond_sd   = wu_chk_sd() < WARMUP_SD_THRESH   (SD of those 50)
     *     cond_prox = ignore_prox
     *                 OR !mother_baseline_valid
     *                 OR |wu_mean() - stored_MB| <= WARMUP_PROX_MV
     *   Both true  -> _full_reset_state(wu_mean()) -> WARMUP_RUNNING
     *   Either false -> wu_chk_reset() starts the NEXT 50-sample window
     *                   (samples 450-500, 500-550, etc.)
     *
     * Windows:  400-450 ? eval ? fail ? 450-500 ? eval ? pass ? RUNNING
     *
     * *TARE# at ANY phase -> _full_reset_state(C_leaky) -> WARMUP_RUNNING.
     * ---------------------------------------------------------------- */
    if (!baseline_seeded && !in_or) {
        wu_push(C_leaky);   /* always keep the 400-sample mean up to date */

        if (warmup_phase == WARMUP_COLLECTING) {
            /* Stay collecting until 400 samples gathered */
            if (wu_filled >= WARMUP_COLLECTION_SAMPLES) {
                warmup_phase = WARMUP_CHECKING;
                wu_chk_reset();   /* start the 50-sample check window fresh */
                /* fall through to WARMUP_CHECKING this same sample */
            }
        }

        if (warmup_phase == WARMUP_CHECKING) {
            wu_chk_push(C_leaky);   /* accumulate into current 50-sample window */

            /* Only evaluate once the window is exactly full */
            if (wu_chk_filled == WARMUP_CHECK_SAMPLES) {
                float sd_now   = wu_chk_sd();
                float mean_now = wu_mean();

                bool cond_sd   = (sd_now < WARMUP_SD_THRESH);
                bool cond_prox = ignore_prox
                                 || !mother_baseline_valid
                                 || (fabsf(mean_now - stored_mother_baseline) <= WARMUP_PROX_MV);

                if (cond_sd && cond_prox) {
                    /* Both conditions met ? transition to RUNNING */
                    _full_reset_state(mean_now);
                } else {
                    /* Fail ? discard this window, start collecting the next 50 */
                    wu_chk_reset();
                }
            }
            /* While wu_chk_filled < 50: accumulating silently, no evaluation. */
        }
    }

    bool in_warmup_phase = (warmup_phase != WARMUP_RUNNING);

    /* Gate ? same as before */
    if (in_or || sample_count < 7 || in_warmup_phase) {
        II_prev = II;
        M_delta = C_leaky - daughter_baseline;
        return;
    }

    /* c6, cp1 */
    float c6  = (c_filled >= 7) ? c_get(6) : c_get(c_filled - 1);
    float cp1 = c_get(1);

    /* D, E */
    float ru_thr = vlu(C_leaky, RAMP_UP, RAMP_UP_N);
    if ((C_leaky - cp1) > ru_thr) { cnt_D++; acc_E += (C_leaky - c6); }
    else { cnt_D = 0; acc_E = 0.0f; }

    /* FF, G */
    float rd_thr = vlu(C_leaky, RAMP_DN, RAMP_DN_N);
    if ((C_leaky - c6) < rd_thr) { cnt_F++; acc_G += (C_leaky - c6); }
    else { cnt_F = 0; acc_G = 0.0f; }

    /* H vote ? II */
    float eff_upG = post_high_active ? P.post_high_upG : P.upG;
    float eff_inG = post_high_active ? P.post_high_inG : P.inG;

    int8_t h = 0;
    if ((float)cnt_D > eff_upG && acc_E > eff_inG) h += 1;
    /* Down trigger suppressed when previous N_accum (analytical) >=
     * AN_RESET_THRESH_MV -- mirrors Excel col H change (N<20 condition). */
    if ((float)cnt_F > P.dnG   && acc_G < P.dnI && N_accum < AN_RESET_THRESH_MV) h -= 1;
    II_prev = II;
    if (h != 0) II = (float)h;

    /* K */
    K_stab = (II == 1.0f) ? 0.0f : vlu_sd(J_sd, STAB_REC, STAB_REC_N);

    /* Baseline update */
    {
        float c_now = C_leaky, l;
        if (c_now < mother_baseline) { mother_baseline = c_now; l = c_now; }
        else {
            if (K_stab >= P.rec && fabsf(c_now - mother_baseline) < P.drf) l = c_now;
            else l = daughter_baseline;
        }
        if (fabsf(l - mother_baseline) <= P.daughter_mother_prox) mother_baseline = l;
        daughter_baseline = l;
    }
    M_delta = C_leaky - daughter_baseline;

    /* peak_M */
    if (II == -1.0f && II_prev == 1.0f) peak_M = fabsf(M_prev);

    /* N accumulator */
    /* Dynamic threshold: use n_thresh_low when the previous displayed ppm is below
     * n_thresh_ppm_thresh (default 3000 ppm), else use the normal n_thresh.
     * S_ppm holds the previous sample's displayed ppm (updated later this step). */
    float eff_n_thresh = (S_ppm < (long)P.n_thresh_ppm_thresh) ? P.n_thresh_low : P.n_thresh;
    float n_val;
    if (II == 1.0f && II_prev == -1.0f) {
        n_val = M_delta;
    } else if (II == 1.0f) {
        float delta_m = M_delta - M_prev;
        n_val = (M_delta > 0.0f && fabsf(delta_m) > eff_n_thresh * M_delta) ? M_delta : N_accum;
    } else {
        n_val = 0.0f;
    }
    N_accum = n_val;

    /* O ROC counter */
    uint16_t O_prev = O_roc;
    if (II > 0.0f)
        O_roc = (O_prev >= P.o_cap) ? P.o_cap : (uint16_t)(O_prev + 1u);
    else
        O_roc = 0;

    /* P_clip */
    float pv;
    if      (O_roc == 0)       pv = 0.0f;
    else if (O_roc == O_prev)  pv = P_clip;
    else                       pv = N_accum;
    P_clip = pv;

    /* Q, R, S */
    long q_val = calib_interp(P_clip,  CALIB_FAST);
    long r_val = calib_interp(N_accum, CALIB_AN);

    /* Latch: once analytical (r_val) overtakes fast (q_val) during an UP
     * event, display r_val only for the rest of that UP event -- even if
     * r_val later falls back below q_val. Latch resets on DOWN (II==-1)
     * so the next UP event starts fresh. q_val is never zeroed; only the
     * display variable s_val is switched. Mirrors Python v15 logic. */
    if (II == -1.0f) {
        an_override = false;          /* reset latch when DOWN state reached */
    }
    if (II == 1.0f && (float)r_val > (float)q_val) {
        an_override = true;           /* latch on first crossover in UP event */
    }
    long s_val = an_override ? r_val : q_val;

    /* Blanking window after TARE */
    if (tare_blank_count > 0) {
        tare_blank_count--;
        N_accum = 0.0f; O_roc = 0; P_clip = 0.0f;
        q_val = 0; r_val = 0; s_val = 0;
    }
    Q_ppm = q_val; R_ppm = r_val; S_ppm = s_val;

    /* Recovery % */
    if (force_recovered) {
        rec_pct = 100.0f; force_recovered = false; peak_M = 0.0f;
    } else if (II == -1.0f && II_prev == 1.0f) {
        peak_M = fabsf(M_prev); rec_pct = 100.0f;
    } else if (II == -1.0f && peak_M > 0.0f) {
        float abs_m = fabsf(M_delta);
        if (abs_m < P.rec_zero_pct * peak_M) { rec_pct = 100.0f; }
        else {
            float r = (1.0f - abs_m / peak_M) * 100.0f;
            if (r < 0.0f) r = 0.0f; if (r > 99.9f) r = 99.9f;
            rec_pct = r;
        }
    } else if (II == 1.0f) { rec_pct = 0.0f; }

    /* Post-high-concentration limiting */
    {
        int8_t disp_flag;
        if      (II == 1.0f)                            disp_flag =  1;
        else if (II == -1.0f && II_prev == 1.0f)        disp_flag = -2;
        else if (II == -1.0f && rec_pct < 100.0f)       disp_flag = -3;
        else                                             disp_flag = -1;

        if (post_high_active) {
            if (disp_flag == 1 && S_ppm >= (long)P.post_high_conc_thresh)
                post_high_saw_high = true;
            if (post_high_saw_high &&
                (disp_flag == -2 || disp_flag == -3 || disp_flag == -1)) {
                post_high_counter  = 0;
                post_high_saw_high = false;
            }
            post_high_counter++;
            if (post_high_counter >= P.post_high_counter_limit) {
                post_high_active   = false;
                post_high_counter  = 0;
                post_high_saw_high = false;
            }
        } else {
            if (disp_flag == 1 && S_ppm >= (long)P.post_high_conc_thresh)
                post_high_saw_high = true;
            if (post_high_saw_high &&
                (disp_flag == -2 || disp_flag == -3 || disp_flag == -1)) {
                post_high_active   = true;
                post_high_counter  = 0;
                post_high_saw_high = false;
            }
        }
    }

    M_prev = M_delta;
}

/* ================================================================== */
/*  I2C DRIVER                                                         */
/* ================================================================== */
bool I2C_RawStart(uint8_t deviceAddr, uint8_t Direction) {
    volatile uint16_t timeout;
    deviceAddr = deviceAddr | Direction;
    if (I2C_BUS_NOT_BUSY) {
        for (volatile uint16_t arbLoop = 0x04; arbLoop > 0; arbLoop--) {
            TWI0.MADDR = deviceAddr;
            if (Direction)
            { for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_RIF_bm)&&(timeout>0); timeout--){} }
            else
            { for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_WIF_bm)&&(timeout>0); timeout--){} }
            if (I2C_ARBLOST) continue;
            if (I2C_BUSERR)  return(RETURN_BUS_ERROR);
            if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
            else                                return(RETURN_NO_SLAVE);
        }
    } else return(RETURN_BUS_BUSY);
    return(RETURN_BUS_ARBLOST);
}
bool I2C_RawStop(void) {
    volatile uint16_t timeout;
    for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm)&&(timeout>0); timeout--){}
    if (timeout==0) return(RETURN_FAILED);
    TWI0.MCTRLB = TWI_ACKACT_NACK_gc | TWI_MCMD_STOP_gc;
    for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm)&&(timeout>0); timeout--){}
    if (I2C_BUSERR) TWI0.MSTATUS = TWI_BUSERR_bm;
    return(RETURN_OK);
}
void I2C_RawForceStop(void) {
    I2C_RawStop(); TWI0.MSTATUS |= TWI_BUSSTATE_IDLE_gc; TWI0.MCTRLB |= TWI_FLUSH_bm;
}
bool I2C_RawWrite(uint8_t write_data) {
    volatile uint16_t timeout;
    if (I2C_BUS_OWNER) {
        for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm)&&(timeout>0); timeout--){}
        if (timeout==0) return(RETURN_FAILED);
        TWI0.MDATA = write_data;
        for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_WIF_bm)&&(timeout>0); timeout--){}
        if (I2C_BUSERR) return(RETURN_BUS_ERROR);
        if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
        else return(RETURN_NO_SLAVE);
    }
    return(RETURN_FAILED);
}
bool I2C_RawRead(uint8_t ACK) {
    volatile uint16_t timeout;
    if (I2C_BUS_OWNER) {
        for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm)&&(timeout>0); timeout--){}
        if (timeout==0) return(RETURN_FAILED);
        if (ACK==1) TWI0.MCTRLB &= ~(1<<TWI_ACKACT_bp);
        else        TWI0.MCTRLB |=  (1<<TWI_ACKACT_bp);
        for (timeout=I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_RIF_bm)&&(timeout>0); timeout--){}
        if (timeout==0) return(RETURN_FAILED);
        memdata = TWI0.MDATA;
        if (I2C_BUSERR) return(RETURN_FAILED);
        if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
        else return(RETURN_FAILED);
    }
    return(RETURN_FAILED);
}
void I2C_StartMaster(void) {
    PORTB.DIRSET = I2C_SCL; PORTB.DIRSET = I2C_SDA;
    TWI0.CTRLA   = TWI_SDAHOLD_500NS_gc | TWI_SDASETUP_8CYC_gc;
    TWI0.MBAUD   = (uint8_t)TWI0_BAUD(100000, 1000);
    TWI0.MCTRLA  = 1<<TWI_ENABLE_bp | 0<<TWI_QCEN_bp | 0<<TWI_RIEN_bp
                 | 1<<TWI_SMEN_bp | TWI_TIMEOUT_DISABLED_gc | 0<<TWI_WIEN_bp;
    TWI0.MSTATUS = TWI_BUSSTATE_IDLE_gc;
    TWI0.MSTATUS = (TWI_RIF_bm | TWI_WIF_bm);
    TWI0.MCTRLB  = TWI_FLUSH_bm;
}
void InitI2C(void) { I2C_StartMaster(); }
bool start_transmission(char device_address) { return(I2C_RawStart(device_address, I2C_WRITE)); }
bool stop_transmission(void)                 { return(I2C_RawStop()); }
void write_on_bus(unsigned char ch)          { I2C_RawWrite(ch); }
void ADS122C04_sendCommand(uint8_t command) {
    start_transmission(ADS122C04_ADDR); write_on_bus(command); stop_transmission();
}
void start(void)         { ADS122C04_sendCommand(ADS122C04_START_CMD);     }
void reset(void)         { ADS122C04_sendCommand(ADS122C04_RESET_CMD);     }
void ADC_powerdown(void) { ADS122C04_sendCommand(ADS122C04_POWERDOWN_CMD); }
void ADS122C04_sendCommandWithValue(uint8_t command, uint8_t value) {
    start_transmission(ADS122C04_ADDR); write_on_bus(command);
    write_on_bus(value); stop_transmission();
}
void ADS122C04_writeReg(uint8_t reg, uint8_t writeValue) {
    ADS122C04_sendCommandWithValue(ADS122C04_WRITE_CMD(reg), writeValue);
}
bool ADS122C04_readReg(uint8_t reg, uint8_t *readValue) {
    uint8_t command = ADS122C04_READ_CMD(reg);
    start_transmission(ADS122C04_ADDR); write_on_bus(command); stop_transmission();
    if (I2C_RawStart(ADS122C04_ADDR, I2C_READ)) { I2C_RawStop(); }
    if (I2C_RawRead(1)) { I2C_RawStop(); return(false); }
    else { *readValue=memdata; I2C_RawStop(); return(true); }
}
bool ADS122C04_getConversionData(uint32_t *conversionData) {
    uint8_t RXByte[3]={0};
    start_transmission(ADS122C04_ADDR); write_on_bus(ADS122C04_RDATA_CMD); stop_transmission();
    if (I2C_RawStart(ADS122C04_ADDR, I2C_READ)) { I2C_RawStop(); }
    if (I2C_RawRead(1)) { I2C_RawStop(); } RXByte[0]=memdata;
    if (I2C_RawRead(1)) { I2C_RawStop(); } RXByte[1]=memdata;
    if (I2C_RawRead(1)) { I2C_RawStop(); } RXByte[2]=memdata;
    *conversionData=((uint32_t)RXByte[2])|((uint32_t)RXByte[1]<<8)|((uint32_t)RXByte[0]<<16);
    return(true);
}
uint32_t readADC(void) { uint32_t r; ADS122C04_getConversionData(&r); return r; }
bool checkDataReady(void) {
    ADS122C04_readReg(ADS122C04_CONFIG_2_REG, &ADS122C04_Reg.reg2.all);
    return(ADS122C04_Reg.reg2.bit.DRDY > 0);
}
void setInputMultiplexer(uint8_t m) { ADS122C04_Reg.reg0.bit.MUX=m;       ADS122C04_writeReg(0,ADS122C04_Reg.reg0.all); }
void setGain(uint8_t g)             { ADS122C04_Reg.reg0.bit.GAIN=g;      ADS122C04_writeReg(0,ADS122C04_Reg.reg0.all); }
void enablePGA(uint8_t e)           { ADS122C04_Reg.reg0.bit.PGA_BYPASS=e;ADS122C04_writeReg(0,ADS122C04_Reg.reg0.all); }
void setDataRate(uint8_t r)         { ADS122C04_Reg.reg1.bit.DR=r;        ADS122C04_writeReg(1,ADS122C04_Reg.reg1.all); }
void setOperatingMode(uint8_t m)    { ADS122C04_Reg.reg1.bit.MODE=m;      ADS122C04_writeReg(1,ADS122C04_Reg.reg1.all); }
void setConversionMode(uint8_t m)   { ADS122C04_Reg.reg1.bit.CMBIT=m; ADS122C04_writeReg(1,ADS122C04_Reg.reg1.all); }
void setVoltageReference(uint8_t r) { ADS122C04_Reg.reg1.bit.VVREF=r;     ADS122C04_writeReg(1,ADS122C04_Reg.reg1.all); }
void enableInternalTempSensor(uint8_t e){ ADS122C04_Reg.reg1.bit.TS=e;    ADS122C04_writeReg(1,ADS122C04_Reg.reg1.all); }
void setDataCounter(uint8_t e)      { ADS122C04_Reg.reg2.bit.DCNT=e;      ADS122C04_writeReg(2,ADS122C04_Reg.reg2.all); }
void setDataIntegrityCheck(uint8_t s){ ADS122C04_Reg.reg2.bit.CRCbits=s;  ADS122C04_writeReg(2,ADS122C04_Reg.reg2.all); }
void setBurnOutCurrent(uint8_t e)   { ADS122C04_Reg.reg2.bit.BCS=e;       ADS122C04_writeReg(2,ADS122C04_Reg.reg2.all); }
void setIDACcurrent(uint8_t c)      { ADS122C04_Reg.reg2.bit.IDAC=c;      ADS122C04_writeReg(2,ADS122C04_Reg.reg2.all); }
void setIDAC1mux(uint8_t s)         { ADS122C04_Reg.reg3.bit.I1MUX=s;     ADS122C04_writeReg(3,ADS122C04_Reg.reg3.all); }
void setIDAC2mux(uint8_t s)         { ADS122C04_Reg.reg3.bit.I2MUX=s;     ADS122C04_writeReg(3,ADS122C04_Reg.reg3.all); }

