    PLE();
    USART1_sendStr("REF="); USART1_sendLong((long)Reference_Set_Value); USART1_sendStr("\r\n"); PLE();
    USART1_sendStr("LIMIT="); USART1_sendUInt((uint32_t)limit); USART1_sendStr("\r\n"); PLE();
    USART1_sendStr("OFFSET="); USART1_sendUInt((uint32_t)offset_value); USART1_sendStr("\r\n"); PLE();
    USART1_sendStr("END\r\n");
    /* Final flush + loopback drain done by rx_enable() in run_mode() after process_cmd() returns */
#undef PLE
}

/* Forward declarations ? defined after frame_crc16 below */
static void tx_stopped_continuous(void);
static void tx_stopped_frame(void);

/*
 * do_stop() ? one-shot check for safe power-off.
 *
 * Conditions for a clean stop:
 *   - Engine is running (warmup complete)
 *   - OR state is normal (not in overrange)
 *   - II == -1 (not detecting UP)
 *   - rec_pct == 100 (fully recovered / baseline)
 *
 * Met  ? save mother_baseline to EEPROM (same MB_EE_DATA_ADDR location),
 *         emit one stopped output (all cols 0, Col 10 = 9),
 *         print OK_STOPPED, go idle.
 * Not met ? print BRING PROBE TO AIR / WAIT once, return,
 *            normal data output resumes on next sample.
 */
static void do_stop(void) {
    /* NOTE: called from process_cmd() which is already inside rx_disable().
     * Do NOT call rx_disable()/rx_enable() here ? the caller owns them.
     * Just send directly; the caller's rx_enable() will drain the loopback. */

    bool safe = (warmup_phase == WARMUP_RUNNING)
             && (or_state    == OR_NORMAL)
             && (II          == -1.0f)
             && (rec_pct     >= 100.0f);

    if (!safe) {
        /* Conditions not met ? print warning once, then return so normal
         * data output resumes immediately on the next loop iteration.
         * Do NOT set MODE_IDLE here. */
        if (run_mode_state != MODE_FRAME) USART1_sendStr("BRING PROBE TO AIR / WAIT\r\n");
        return;
    }

    /* Conditions met ? save baseline to EEPROM */
    mb_ee_save(mother_baseline);
    stored_mother_baseline = mother_baseline;
    mother_baseline_valid  = true;

    /* Emit one stopped output: all cols 0, Col 10 = 9 */
    if (run_mode_state == MODE_CONTINUOUS) {
        USART1_sendChar(0x0A);
        tx_stopped_continuous();
    } else {
        tx_stopped_frame();   /* binary frame IS the ack in frame mode */
    }
    if (run_mode_state != MODE_FRAME) USART1_sendStr("OK_STOPPED\r\n");

    run_mode_state = MODE_IDLE;
    /* run_mode() loop will now fall into the MODE_IDLE branch
       and wait silently for *start# or *frame# again. */
}

static void process_cmd(void) {
    /* Normalize to uppercase ? all commands work regardless of case.
     * Essential in frame mode where the user has no ACK feedback. */
    for (uint8_t i = 1; i < rxcntr; i++) {
        if (company[i] >= 'a' && company[i] <= 'z')
            company[i] = (unsigned char)(company[i] - 32u);
    }
    const char *s = (const char*)&company[1];

    /* *START# ? enter continuous ASCII output mode */
    if (s[0]=='S'&&s[1]=='T'&&s[2]=='A'&&s[3]=='R'&&s[4]=='T'&&s[5]=='#') {
        /* If switching from frame mode, emit one all-zero continuous line
         * (ST=9) so the host sees a clean mode-switch sentinel before the
         * first real data line. Mirrors what *stop# does on the way out. */
        if (run_mode_state == MODE_FRAME) {
            rx_disable();
            USART1_sendChar(0x0A);
            tx_stopped_continuous();
            rx_enable();
        }
        run_mode_state = MODE_CONTINUOUS;
        frame_cn       = 0;
        tx_ack("OK_START\r\n");
        tx_ack("COLS: RefR EMF_mV DispPPM Type H2_Flag Rec_Status OR_Status Warmup PostCnt ProbeState NthMode\r\n");
        return;
    }

    /* *FRAME# ? enter binary frame mode (data frame by default) */
    if (s[0]=='F'&&s[1]=='R'&&s[2]=='A'&&s[3]=='M'&&s[4]=='E'&&s[5]=='#') {
        run_mode_state = MODE_FRAME;
        frame_type     = FRAME_DATA;
        frame_cn       = 0;
        tx_ack("OK_FRAME_DATA\r\n");
        return;
    }

    /* *DIG# ? switch to diagnostic frame (only effective in frame mode) */
    if (s[0]=='D'&&s[1]=='I'&&s[2]=='G'&&s[3]=='#') {
        frame_type = FRAME_DIAG;
        tx_ack("OK_FRAME_DIAG\r\n");
        return;
    }

    /* *DATA# ? switch back to data frame (only effective in frame mode) */
    if (s[0]=='D'&&s[1]=='A'&&s[2]=='T'&&s[3]=='A'&&s[4]=='#') {
        frame_type = FRAME_DATA;
        tx_ack("OK_FRAME_DATA\r\n");
        return;
    }

    /* *STOP# ? one-shot safe-stop check */
    if (s[0]=='S'&&s[1]=='T'&&s[2]=='O'&&s[3]=='P'&&s[4]=='#') {
        do_stop();
        return;
    }

    /* *TEAR# / *TARE# ? force exit from warmup / reset (both spellings accepted) */
    if ((s[0]=='T'&&s[1]=='E'&&s[2]=='A'&&s[3]=='R'&&s[4]=='#') ||
        (s[0]=='T'&&s[1]=='A'&&s[2]=='R'&&s[3]=='E'&&s[4]=='#')) { do_tear(); return; }

    /* *SET UPG <value># / *SET ING <value># ? allowed in frame mode too.
     * Handled here (above the frame-mode gate) so these two specific keys
     * are not silently discarded while streaming binary frames. Parsing
     * and assignment are IDENTICAL to the generic *SET <KEY> handler
     * further below (same key layout, same params_ee_save(), same ACK
     * format) -- this block only lets UPG/ING through earlier so they
     * also work in frame mode; behaviour in continuous mode is unchanged.
     * ACK text uses the same run_mode_state guard every other frame-safe
     * command in this file already uses to avoid corrupting the binary
     * frame stream. */
    if (s[0]=='S'&&s[1]=='E'&&s[2]=='T'&&s[3]==' '&&
        ((s[4]=='U'&&s[5]=='P'&&s[6]=='G') || (s[4]=='I'&&s[5]=='N'&&s[6]=='G')) &&
        s[7]==' ') {
        char key[4]={s[4],s[5],s[6],0};
        char *ptr=(char*)&s[8];
        float fval=parse_float(&ptr);

        if (strcmp(key,"UPG")==0) P.upG = fval;
        else                      P.inG = fval;

        params_ee_save();
        if (run_mode_state != MODE_FRAME) {
            USART1_sendStr("OK SET "); USART1_sendStr(key);
            USART1_sendChar('='); USART1_sendFloat(fval,6); tx_newline();
        }
        return;
    }

    /* *1CAL <ppm># -- one-shot calibration using current DELTA-EMF snapshot.
     * Moved above the frame-mode gate: do_oneshot_calib() already guards
     * all of its ASCII output with run_mode_state != MODE_FRAME internally
     * (tx_ack() + its own explicit guard), so it was already frame-safe --
     * it just needed to be reachable before the gate discarded it. */
    if (s[0]=='1'&&s[1]=='C'&&s[2]=='A'&&s[3]=='L'&&s[4]==' ') {
        char *ptr = (char*)&s[5];
        long ppm_val = parse_long(&ptr);
        do_oneshot_calib(ppm_val);
        return;
    }

    /* *10CAL# -- one-shot 10 ppm calibration. Same reasoning as *1CAL above:
     * do_10ppm_calib() already guards its ASCII report with
     * run_mode_state != MODE_FRAME, so moving the dispatch above the gate
     * makes it usable in frame mode without touching its internals. */
    if (s[0]=='1'&&s[1]=='0'&&s[2]=='C'&&s[3]=='A'&&s[4]=='L'&&s[5]=='#') {
        do_10ppm_calib();
        return;
    }

    /* *RESETCAL# -- reset the *1CAL scaling factor (sf) back to 1.00 on
     * every row of both calibration tables. p_mv/ppm/band_mv untouched.
     * do_reset_cal() already reports via tx_ack(), which is frame-safe. */
    if (s[0]=='R'&&s[1]=='E'&&s[2]=='S'&&s[3]=='E'&&s[4]=='T'&&
        s[5]=='C'&&s[6]=='A'&&s[7]=='L'&&s[8]=='#') {
        do_reset_cal();
        return;
    }

    /* ----------------------------------------------------------------
     * FRAME MODE GATE ? commands below this point are continuous-mode
     * only.  In frame mode silently discard them so frames keep flowing.
     * Allowed in frame mode (handled above): START, FRAME, DIG, DATA,
     * STOP, TEAR/TARE, SET UPG, SET ING, 1CAL, 10CAL, RESETCAL.
     * Everything else: ignore, no reply, no side effect.
     * ---------------------------------------------------------------- */
    if (run_mode_state == MODE_FRAME) return;
    if (s[0]=='I'&&s[1]=='G'&&s[2]=='N'&&s[3]=='O'&&s[4]=='R'&&s[5]=='E'
        &&s[6]=='_'&&s[7]=='P'&&s[8]=='R'&&s[9]=='O'&&s[10]=='X'&&s[11]=='#') {
        ignore_prox = true;
        /*
         * If currently stuck in WARMUP_CHECKING due to prox fail,
         * re-evaluate immediately with ignore_prox now true.
         */
        if (!baseline_seeded && warmup_phase == WARMUP_CHECKING) {
            /* Only re-evaluate if the current window is already full;
             * otherwise the next completed window will catch it automatically. */
            if (wu_chk_filled == WARMUP_CHECK_SAMPLES) {
                float mean_now = wu_mean();
                float sd_now   = wu_chk_sd();
                if (sd_now < WARMUP_SD_THRESH) {
                    _full_reset_state(mean_now);
                } else {
                    wu_chk_reset(); /* discard stale window, start fresh */
                }
            }
        }
        tx_ack("OK_IGNORE_PROX\r\n"); return;
    }

    /* *RF<7-digit># */
    if (s[0]=='R'&&s[1]=='F'&&rxcntr==12) {
        long long a=((s[2]-'0')*1000000LL)+((s[3]-'0')*100000LL)
                   +((s[4]-'0')*10000LL) +((s[5]-'0')*1000LL)
                   +((s[6]-'0')*100LL)   +((s[7]-'0')*10LL)
                   +((s[8]-'0')*1LL);
        Reference_Set_Value=a; P.ref_val=(long)a; scalar_ee_save();
        tx_ack("OK\r\n"); return;
    }
    /* *T<4-digit><2-digit># */
    if (s[0]=='T'&&rxcntr==10) {
        long a=(s[1]-'0')*1000L+(s[2]-'0')*100L+(s[3]-'0')*10L+(s[4]-'0');
        long b=(s[6]-'0')*10L+(s[7]-'0');
        limit=(unsigned int)a; offset_value=(unsigned char)b;
        P.limit_val=(uint16_t)a; P.offset_val=(uint8_t)b; scalar_ee_save();
        tx_ack("OK\r\n"); return;
    }
    /* *CAL# */
    if (s[0]=='C'&&s[1]=='A'&&s[2]=='L'&&s[3]=='#') { do_calibrate(); return; }

    /* *GET PARAMS# ? dump all parameters (continuous mode only; suppressed in frame mode) */
    if (strncmp(s,"GET PARAMS",10)==0) {
        /* send_params() only in continuous mode ? it outputs ASCII that
         * would corrupt the binary frame stream in frame mode. */
        if (run_mode_state != MODE_FRAME) send_params();
        return;
    }

    /* *SET ANCAL <idx> <mV> <ppm> [band_mV]# */
    if (s[0]=='S'&&s[1]=='E'&&s[2]=='T'&&s[3]==' '&&
        s[4]=='A'&&s[5]=='N'&&s[6]=='C'&&s[7]=='A'&&s[8]=='L'&&s[9]==' ') {
        char *ptr=(char*)&s[10];
        int idx=(int)parse_long(&ptr); float mv=parse_float(&ptr); long ppm=parse_long(&ptr);
        /* Optional band_mv ? default 0.0 if not supplied */
        float band_mv = 0.0f;
        while (*ptr == ' ' || *ptr == '\t') ptr++;
        if (*ptr >= '0' && *ptr <= '9') band_mv = parse_float(&ptr);
        if (idx>=0&&idx<CALIB_N) {
            CALIB_AN[idx].p_mv   = mv;
            CALIB_AN[idx].ppm    = ppm;
            CALIB_AN[idx].band_mv= band_mv;
            calib_save_entry(AN_EE_MAGIC_ADDR,AN_EE_DATA_ADDR,CALIB_AN,(uint8_t)idx);
            tx_ack("OK SET ANCAL\r\n");
        } else tx_ack("ERR_IDX\r\n");
        return;
    }
    /* *SET CAL <idx> <mV> <ppm> [band_mV]# */
    if (s[0]=='S'&&s[1]=='E'&&s[2]=='T'&&s[3]==' '&&
        s[4]=='C'&&s[5]=='A'&&s[6]=='L'&&s[7]==' ') {
        char *ptr=(char*)&s[8];
        int idx=(int)parse_long(&ptr); float mv=parse_float(&ptr); long ppm=parse_long(&ptr);
        /* Optional band_mv ? default 0.0 if not supplied */
        float band_mv = 0.0f;
        while (*ptr == ' ' || *ptr == '\t') ptr++;
        if (*ptr >= '0' && *ptr <= '9') band_mv = parse_float(&ptr);
        if (idx>=0&&idx<CALIB_N) {
            CALIB_FAST[idx].p_mv   = mv;
            CALIB_FAST[idx].ppm    = ppm;
            CALIB_FAST[idx].band_mv= band_mv;
            calib_save_entry(FAST_EE_MAGIC_ADDR,FAST_EE_DATA_ADDR,CALIB_FAST,(uint8_t)idx);
            tx_ack("OK SET CAL\r\n");
        } else tx_ack("ERR_IDX\r\n");
        return;
    }
    /* *SET SFSTEP <value># -- set sf_step for one-shot calibration */
    if (s[0]=='S'&&s[1]=='E'&&s[2]=='T'&&s[3]==' '&&
        s[4]=='S'&&s[5]=='F'&&s[6]=='S'&&s[7]=='T'&&s[8]=='E'&&s[9]=='P'&&s[10]==' ') {
        char *ptr = (char*)&s[11];
        float v = parse_float(&ptr);
        if (v > 0.0f && v < 1.0f) {
            P.sf_step = v;
            params_ee_save();
            USART1_sendStr("OK SET SFSTEP="); USART1_sendFloat(v, 5);
            tx_newline();
        } else {
            tx_ack("ERR_SFSTEP: must be 0 < step < 1 (e.g. 0.05)\r\n");
        }
        return;
    }

    /* *SET <KEY> <value># */
    if (s[0]=='S'&&s[1]=='E'&&s[2]=='T'&&s[3]==' ') {
        char key[4]={s[4],s[5],s[6],0};
        char *ptr=(char*)&s[8];
        float fval=parse_float(&ptr);
        bool ok=true;

        if      (strcmp(key,"JMP")==0) P.jmp                     = fval;
        else if (strcmp(key,"ALP")==0) P.alp                     = fval;
        else if (strcmp(key,"UPG")==0) P.upG                     = fval;
        else if (strcmp(key,"ING")==0) P.inG                     = fval;
        else if (strcmp(key,"DNG")==0) P.dnG                     = fval;
        else if (strcmp(key,"DNI")==0) P.dnI                     = fval;
        else if (strcmp(key,"REC")==0) P.rec                     = fval;
        else if (strcmp(key,"DRF")==0) P.drf                     = fval;
        else if (strcmp(key,"NTH")==0) P.n_thresh                = fval;
        else if (strcmp(key,"OCP")==0) P.o_cap                   = (uint16_t)fval;
        else if (strcmp(key,"RZP")==0) P.rec_zero_pct            = fval;
        else if (strcmp(key,"WRM")==0) P.warmup                  = (uint16_t)fval;
        else if (strcmp(key,"ORT")==0) P.or_thresh               = fval;
        else if (strcmp(key,"ORX")==0) P.or_exit_mv              = fval;
        else if (strcmp(key,"ORS")==0) P.or_sd_stable            = fval;
        else if (strcmp(key,"DMP")==0) P.daughter_mother_prox    = fval;
        else if (strcmp(key,"PHT")==0) P.post_high_conc_thresh   = fval;
        else if (strcmp(key,"PHL")==0) P.post_high_counter_limit = (uint16_t)fval;
        else if (strcmp(key,"PHU")==0) P.post_high_upG           = fval;
        else if (strcmp(key,"PHI")==0) P.post_high_inG           = fval;
        else if (strcmp(key,"NTL")==0) P.n_thresh_low            = fval;
        else if (strcmp(key,"NPT")==0) P.n_thresh_ppm_thresh     = fval;
        else if (strcmp(key,"ART")==0) P.an_reset_thresh_mv      = fval;
        else ok = false;

        if (ok) {
            params_ee_save();
            if (run_mode_state != MODE_FRAME) {
                USART1_sendStr("OK SET "); USART1_sendStr(key);
                USART1_sendChar('='); USART1_sendFloat(fval,6); tx_newline();
            }
        } else { tx_ack("ERR_UNKNOWN_KEY\r\n"); }
        return;
    }

    tx_ack("ERR_CMD\r\n");
}

ISR(USART1_RXC_vect) {
    unsigned char c = USART1.RXDATAL;
    if (c=='*') { strt=1; rxcntr=0; }
    if (strt==1) {
        if (rxcntr < CMD_BUF_LEN-1) company[rxcntr++]=c;
        if (c=='#') { company[rxcntr]='\0'; cmd_ready=true; strt=0; }
    }
}

void USART1_init(void) {
    PORTA.DIR &= ~PIN2_bm; PORTA.DIR |= PIN1_bm;
    USART1.BAUD  = (uint16_t)USART1_BAUD_RATE(9600);
    USART1.CTRLA = 0<<USART_ABEIE_bp | 0<<USART_DREIE_bp | 0<<USART_LBME_bp
                 | 1<<USART_RS485_bp  | 1<<USART_RXCIE_bp | 0<<USART_RXSIE_bp
                 | 0<<USART_TXCIE_bp;
    USART1.CTRLB |= USART_RXEN_bm | USART_TXEN_bm;
}

/* ================================================================== */
/*  PROBE STATE HELPER  (shared by continuous and frame output)        */
/*                                                                     */
/*  Returns the Col-10 / ST byte value:                                */
/*   0 = WarmUp Collecting   1 = WarmUp Checking                      */
/*   2 = Small Leaks         3 = Large Leaks                          */
/*   4 = Leak Detected       5 = Recovery                             */
/*   6 = Overrange           7 = Recovery from OR                     */
/*   8 = ZeroCal after OR                                             */
/* ================================================================== */
static uint8_t get_probe_state(void) {
    if (warmup_phase == WARMUP_COLLECTING) return 0;
    if (warmup_phase == WARMUP_CHECKING)   return 1;
    if (or_state == OR_OVERRANGE)          return 6;
    if (or_state == OR_WAIT_DROP)          return 7;
    if (or_state == OR_STABLE)             return 8;
    if (II == 1.0f)                        return 4;
    if (II == -1.0f && (II_prev == 1.0f || rec_pct < 100.0f)) return 5;
    /* II == -1, rec_pct == 100, OR_NORMAL, warmup running */
    uint8_t rp = (uint8_t)(rec_pct + 0.5f);
    if (rp >= 100) {
        bool near = (fabsf(daughter_baseline - mother_baseline) <= P.daughter_mother_prox);
        return (near && !post_high_active) ? 2u : 3u;
    }
    return 5;
}

/* ================================================================== */
/*  tx_send_int32_be ? helper used outside tx_frame (kept for reuse)  */
/* ================================================================== */
static void tx_send_int32_be(int32_t v) __attribute__((unused));
static void tx_send_int32_be(int32_t v) {
    USART1_sendChar((char)((v >> 24) & 0xFF));
    USART1_sendChar((char)((v >> 16) & 0xFF));
    USART1_sendChar((char)((v >>  8) & 0xFF));
    USART1_sendChar((char)( v        & 0xFF));
}

/* ================================================================== */
/*  CRC-16/IBM (same algorithm as Modbus reference)                    */
/*  Calculates over `count` bytes in `buf`.                            */
/*  Caller sends: lo byte first, then hi byte (swapped).              */
/* ================================================================== */
static uint16_t frame_crc16(const uint8_t *buf, uint8_t count)
{
    uint16_t crc = 0xFFFF;
    for (uint8_t pos = 0; pos < count; pos++) {
        crc ^= buf[pos];
        for (uint8_t j = 8; j > 0; j--) {
            if (crc & 0x0001) {
                crc = (crc >> 1) ^ 0xA001;
            } else {
                crc >>= 1;
            }
        }
    }
    return crc;
}

/* ================================================================== */
/*  STOPPED OUTPUT ? emitted once when *stop# conditions are met.     */
/*  All columns = 0 except Col 10 (ProbeState) = 9.                  */
/*  Frame mode: ST = 9, H2 = 0, RC = 0, CRC computed normally.       */
/* ================================================================== */
static void tx_stopped_continuous(void) {
    /* Stopped output: all data cols = 0/neutral, Col 10 = 9 (stopped).
     * String columns must match expected format so host parser stays aligned.
     * Col 1 sends actual RefR so column widths remain predictable. */
    /* Col 1:  RefR        */ USART1_sendLong((long)Reference_Set_Value); USART1_sendChar(' ');
    /* Col 2:  EMF_mV      */ USART1_sendStr("0.000"); USART1_sendChar(' ');
    /* Col 3:  PPM         */ USART1_sendChar('0'); USART1_sendChar(' ');
    /* Col 4:  Type        */ USART1_sendChar('F'); USART1_sendChar(' ');
    /* Col 5:  H2_Flag     */ USART1_sendStr("AIR"); USART1_sendChar(' ');
    /* Col 6:  Rec_Status  */ USART1_sendStr("100_L"); USART1_sendChar(' ');
    /* Col 7:  OR_Status   */ USART1_sendStr("NORMAL"); USART1_sendChar(' ');
    /* Col 8:  Warmup      */ USART1_sendChar('4'); USART1_sendChar(' ');
    /* Col 9:  PostCnt     */ USART1_sendChar('0'); USART1_sendChar(' ');
    /* Col 10: ProbeState  */ USART1_sendChar('9'); USART1_sendChar(' ');
    /* Col 11: NthMode     */ USART1_sendChar('F');
    USART1_sendChar(0x0D); USART1_sendChar(0x0A);
}

static void tx_stopped_frame(void) {
    /* Data frame: ST=9, H2=0, RC=0. Diag frame: same + MV/MB/DB=0. */
    frame_cn++;   /* keep counter incrementing */

    if (frame_type == FRAME_DATA) {
        uint8_t buf[7];
        buf[0] = frame_cn;
        buf[1] = 9u;                                       /* ST = 9 */
        buf[2] = 0; buf[3] = 0; buf[4] = 0; buf[5] = 0;  /* H2 = 0 */
        buf[6] = 0;                                        /* RC = 0 */
        uint16_t crc = frame_crc16(buf, 7);
        USART1_sendChar((char)0x0A);
        for (uint8_t i = 0; i < 7; i++) USART1_sendChar((char)buf[i]);
        USART1_sendChar((char)(crc & 0xFF));
        USART1_sendChar((char)((crc >> 8) & 0xFF));
        USART1_sendChar((char)0x0D);
    } else {
        uint8_t buf[19];
        buf[0]  = frame_cn;
        buf[1]  = 9u;          /* ST = 9 */
        buf[2]  = 0; buf[3]  = 0; buf[4]  = 0; buf[5]  = 0;  /* H2 = 0 */
        buf[6]  = 0;           /* RC = 0 */
        buf[7]  = 0; buf[8]  = 0; buf[9]  = 0; buf[10] = 0;  /* MV = 0 */
        buf[11] = 0; buf[12] = 0; buf[13] = 0; buf[14] = 0;  /* MB = 0 */
        buf[15] = 0; buf[16] = 0; buf[17] = 0; buf[18] = 0;  /* DB = 0 */
        uint16_t crc = frame_crc16(buf, 19);
        USART1_sendChar((char)0x0A);
        for (uint8_t i = 0; i < 19; i++) USART1_sendChar((char)buf[i]);
        USART1_sendChar((char)(crc & 0xFF));
        USART1_sendChar((char)((crc >> 8) & 0xFF));
        USART1_sendChar((char)0x0D);
    }
}

/* ================================================================== */
/*  FRAME OUTPUT                                                        */
/*                                                                     */
/*  Data frame  (11 bytes):                                            */
/*   B01      0x0A  Start byte                                         */
/*   B02      Cn    Counter (0-255, increments each frame)             */
/*   B03      ST    ProbeState (same as Col 10)                        */
/*   B04-B07  H2    H2 concentration ppm, big-endian int32            */
/*   B08      RC    Recovery % (0-100, clamped)                        */
/*   B09      CRC-lo  CRC-16/IBM over B02..B08, low byte first        */
/*   B10      CRC-hi  high byte                                        */
/*   B11      0x0D  End byte                                           */
/*                                                                     */
/*  Diagnostic frame  (23 bytes):                                      */
/*   B01      0x0A  Start byte                                         */
/*   B02      Cn    Counter                                            */
/*   B03      ST    ProbeState                                         */
/*   B04-B07  H2    H2 ppm, big-endian int32                          */
/*   B08      RC    Recovery %                                         */
/*   B09-B12  MV    EMF mV * 1000 as int32, big-endian               */
/*   B13-B16  MB    Mother baseline mV * 1000 as int32, big-endian   */
/*   B17-B20  DB    Daughter baseline mV * 1000 as int32, big-endian */
/*   B21      CRC-lo  CRC-16/IBM over B02..B20, low byte first        */
/*   B22      CRC-hi  high byte                                        */
/*   B23      0x0D  End byte                                           */
/* ================================================================== */
static void tx_frame(float emf_mv) {
    rx_disable();                        /* block loopback into RX ISR */
    uint8_t st = get_probe_state();

    /* H2 ppm ? show 0 if not running normally (same rule as Col 3) */
    long h2_ppm = (warmup_phase == WARMUP_RUNNING && or_state == OR_NORMAL) ? S_ppm : 0L;

    /* Recovery % clamped to 0-100 */
    uint8_t rc = (uint8_t)(rec_pct + 0.5f);
    if (rc > 100) rc = 100;

    /* Advance counter ? wraps naturally at 256 */
    frame_cn++;

    if (frame_type == FRAME_DATA) {
        /* --- 11-byte data frame ---
         * Assemble payload bytes B02..B08 into buffer, compute CRC, then transmit. */
        uint8_t buf[7];
        buf[0] = frame_cn;
        buf[1] = st;
        buf[2] = (uint8_t)(((int32_t)h2_ppm >> 24) & 0xFF);
        buf[3] = (uint8_t)(((int32_t)h2_ppm >> 16) & 0xFF);
        buf[4] = (uint8_t)(((int32_t)h2_ppm >>  8) & 0xFF);
        buf[5] = (uint8_t)( (int32_t)h2_ppm        & 0xFF);
        buf[6] = rc;

        uint16_t crc = frame_crc16(buf, 7);

        USART1_sendChar((char)0x0A);                     /* B01 Start   */
        USART1_sendChar((char)buf[0]);                   /* B02 Cn      */
        USART1_sendChar((char)buf[1]);                   /* B03 ST      */
        USART1_sendChar((char)buf[2]);                   /* B04 H2 MSB  */
        USART1_sendChar((char)buf[3]);                   /* B05         */
        USART1_sendChar((char)buf[4]);                   /* B06         */
        USART1_sendChar((char)buf[5]);                   /* B07 H2 LSB  */
        USART1_sendChar((char)buf[6]);                   /* B08 RC      */
        USART1_sendChar((char)(crc & 0xFF));             /* B09 CRC-lo  */
        USART1_sendChar((char)((crc >> 8) & 0xFF));      /* B10 CRC-hi  */
        USART1_sendChar((char)0x0D);                     /* B11 End     */

    } else {
        /* --- 23-byte diagnostic frame ---
         * EMF, MB, DB encoded as int32 of (value * 1000) for 3 decimal places.
         * Assemble payload bytes B02..B20 into buffer, compute CRC, then transmit. */
        int32_t mv_i = (int32_t)(emf_mv            * 1000.0f);
        int32_t mb_i = (int32_t)(mother_baseline   * 1000.0f);
        int32_t db_i = (int32_t)(daughter_baseline * 1000.0f);

        uint8_t buf[19];
        buf[0]  = frame_cn;
        buf[1]  = st;
        buf[2]  = (uint8_t)(((int32_t)h2_ppm >> 24) & 0xFF);
        buf[3]  = (uint8_t)(((int32_t)h2_ppm >> 16) & 0xFF);
        buf[4]  = (uint8_t)(((int32_t)h2_ppm >>  8) & 0xFF);
        buf[5]  = (uint8_t)( (int32_t)h2_ppm        & 0xFF);
        buf[6]  = rc;
        buf[7]  = (uint8_t)((mv_i >> 24) & 0xFF);
        buf[8]  = (uint8_t)((mv_i >> 16) & 0xFF);
        buf[9]  = (uint8_t)((mv_i >>  8) & 0xFF);
        buf[10] = (uint8_t)( mv_i        & 0xFF);
        buf[11] = (uint8_t)((mb_i >> 24) & 0xFF);
        buf[12] = (uint8_t)((mb_i >> 16) & 0xFF);
        buf[13] = (uint8_t)((mb_i >>  8) & 0xFF);
        buf[14] = (uint8_t)( mb_i        & 0xFF);
        buf[15] = (uint8_t)((db_i >> 24) & 0xFF);
        buf[16] = (uint8_t)((db_i >> 16) & 0xFF);
        buf[17] = (uint8_t)((db_i >>  8) & 0xFF);
        buf[18] = (uint8_t)( db_i        & 0xFF);

        uint16_t crc = frame_crc16(buf, 19);

        USART1_sendChar((char)0x0A);                     /* B01 Start   */
        for (uint8_t i = 0; i < 19; i++)
            USART1_sendChar((char)buf[i]);               /* B02-B20     */
        USART1_sendChar((char)(crc & 0xFF));             /* B21 CRC-lo  */
        USART1_sendChar((char)((crc >> 8) & 0xFF));      /* B22 CRC-hi  */
        USART1_sendChar((char)0x0D);                     /* B23 End     */
    }
    rx_enable();                         /* restore RX ISR after TX burst */
}

/* ================================================================== */
/*  OUTPUT LINE ? continuous ASCII columns                             */
/* ================================================================== */
static void tx_output_line(float emf_mv) {
    rx_disable();                        /* block loopback into RX ISR */
    /* Col 1: RefR */
    USART1_sendLong((long)Reference_Set_Value);
    USART1_sendChar(' ');

    /* Col 2: EMF_mV */
    USART1_sendFloat(emf_mv, 3);
    USART1_sendChar(' ');

    /* Col 3: DispPPM */
    {
        long d = (warmup_phase == WARMUP_RUNNING && or_state == OR_NORMAL) ? S_ppm : 0L;
        USART1_sendLong(d);
    }
    USART1_sendChar(' ');

    /* Col 4: Type */
    USART1_sendChar((Q_ppm >= R_ppm) ? 'F' : 'A');
    USART1_sendChar(' ');

    /* Col 5: H2_Flag */
    {
        const char *flag;
        bool in_or = (or_state != OR_NORMAL);
        if (in_or || warmup_phase != WARMUP_RUNNING) {
            flag = "AIR";
        } else if (II == 1.0f) {
            flag = "UP";
        } else if (II == -1.0f && II_prev == 1.0f) {
            flag = "DOWN";
        } else if (II == -1.0f && rec_pct < 100.0f) {
            flag = "REC";
        } else {
            flag = "AIR";
        }
        USART1_sendStr(flag);
    }
    USART1_sendChar(' ');

    /* Col 6: Rec_Status */
    {
        uint8_t rp = (uint8_t)(rec_pct + 0.5f);
        if (rp > 100) rp = 100;
        if (rp == 100) {
            if (post_high_active) {
                USART1_sendStr("100_H");
            } else {
                bool near = (fabsf(daughter_baseline - mother_baseline) <= P.daughter_mother_prox);
                USART1_sendStr(near ? "100_L" : "100_H");
            }
        } else {
            USART1_sendUInt(rp);
        }
    }
    USART1_sendChar(' ');

    /* Col 7: OR_Status */
    {
        const char *ors;
        switch (or_state) {
            case OR_OVERRANGE: ors = "OVERRANGE";  break;
            case OR_WAIT_DROP: ors = "WAIT_DROP";  break;
            case OR_STABLE:    ors = "PRESS_TARE"; break;
            default:           ors = "NORMAL";     break;
        }
        USART1_sendStr(ors);
    }
    USART1_sendChar(' ');

    /* Col 8: Warmup
     *   WARMUP_COLLECTING = 0  -> output 0
     *   WARMUP_CHECKING   = 1  -> output 1
     *   WARMUP_RUNNING    = 4  -> output 4
     * The enum values ARE the output values -- cast directly.
     */
    USART1_sendUInt((uint32_t)warmup_phase);
    USART1_sendChar(' ');

    /* Col 9: PostCnt */
    USART1_sendUInt(post_high_active ? (uint32_t)post_high_counter : 0u);
    USART1_sendChar(' ');

    /* Col 10: ProbeState ? computed by shared helper */
    USART1_sendUInt((uint32_t)get_probe_state());
    USART1_sendChar(' ');

    /* Col 11: NthMode ? 'F' = low-ppm threshold active (ppm < NPT),
     *                   'T' = normal threshold active  (ppm >= NPT) */
    USART1_sendChar((S_ppm < (long)P.n_thresh_ppm_thresh) ? 'F' : 'T');

    USART1_sendChar(0x0D); USART1_sendChar(0x0A);
    rx_enable();                         /* restore RX ISR after TX burst */
}

/* ================================================================== */
/*  RUN MODE                                                           */
/* ================================================================== */
/*
 * TARGET_LOOP_MS ? fixed sample period for both continuous and frame modes.
 *
 * Continuous mode TX (ASCII, worst case ~53 bytes) takes ~55ms at 9600 baud.
 * Frame mode TX (11 bytes binary) takes only ~11.5ms.
 * Without this governor, frame mode runs ~35% faster than continuous,
 * causing smaller per-sample C_leaky deltas that fail to sustain the
 * cnt_D streak (needs >upG=6 consecutive) required for detection.
 * Setting a common floor of 90ms makes both modes run at ~11 sps,
 * matching worst-case continuous speed ? identical detection sensitivity.
 */
#define TARGET_LOOP_MS   90u

void run_mode(void) {
    uint32_t loop_start = 0;

    while (1) {
        if (cmd_ready) {
            cmd_ready = false;
            rx_disable();
            bool was_frame = (run_mode_state == MODE_FRAME);
            process_cmd();
            /* If we were in frame mode when the command arrived, no ACK bytes
             * were sent (all suppressed), so TXCIF is never set and tx_flush()
             * inside rx_enable() would hang forever. Use rx_enable_no_flush().
             * Exception: *START# switches mode to CONTINUOUS and does send an
             * ACK ? but tx_ack() checks run_mode_state AFTER the switch, so it
             * sends. In that case we need the full rx_enable(). Detect this by
             * checking if mode changed away from FRAME. */
            if (was_frame && run_mode_state == MODE_FRAME) rx_enable_no_flush();
            else                                           rx_enable();
        }

        if (run_mode_state == MODE_IDLE) {
            /* Idle only after *stop# ? wait silently for *start# or *frame# */
            _delay_ms(100);
            continue;
        }

        /* Pace both modes to the same loop period so detection sensitivity
         * is identical regardless of output format. */
        while ((millis_count - loop_start) < TARGET_LOOP_MS) {
            if (cmd_ready) {
                cmd_ready = false;
                rx_disable();
                bool was_frame = (run_mode_state == MODE_FRAME);
                process_cmd();
                if (was_frame && run_mode_state == MODE_FRAME) rx_enable_no_flush();
                else                                           rx_enable();
            }
        }
        loop_start = millis_count;

        read_sensor();
        float emf_mv = (float)sensor_final_output / 1000.0f;

        engine_step(emf_mv);

        if (run_mode_state == MODE_CONTINUOUS) {
            rx_disable();
            USART1_sendChar(0x0A);
            tx_output_line(emf_mv);   /* rx_enable() called inside */
        } else {
            /* MODE_FRAME ? binary frame, no extra delay */
            tx_frame(emf_mv);         /* rx_enable() called inside */
        }
    }
}

/* ================================================================== */
/*  MAIN                                                               */
/* ================================================================== */
int main(void) {
    PORTA_DIR    = 0xFF;
    PORTA_OUTSET = ADC_RESET;
    PORTB_DIR    = 0xFF;
    _delay_ms(500);

    InitI2C();
    USART1_init();
    _delay_ms(100);
    timer_init();
    sei();

    calib_load(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST, CALIB_FAST_DEFAULT);
    calib_load(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN,   CALIB_AN_DEFAULT);
    mb_ee_load();
    params_ee_load();
    scalar_ee_load();   /* loads ref_val / limit_val / offset_val independently */

    /* Restore runtime scalars from the unified Params block */
    Reference_Set_Value = P.ref_val;
    limit               = P.limit_val;
    offset_value        = P.offset_val;

   /* Boot message: 0x0A + "MNST" + 0x0D, repeated continuously for 5 seconds */
   {
	   uint32_t boot_start = millis_count;
	   while ((millis_count - boot_start) < 5000u) {
		   rx_disable();
		   USART1_sendChar(0x0A);
		   USART1_sendStr("MNST");
		   USART1_sendChar(0x0D);
		   rx_enable();
		   _delay_ms(200);   /* ~5 transmissions per second */
	   }
   }
    run_mode_state = MODE_FRAME;
    frame_type     = FRAME_DATA;
    frame_cn       = 0;

    setInputMultiplexer(ADS122C04_MUX_AIN1_AIN0);
    setGain(ADS122C04_GAIN_1);
    enablePGA(ADS122C04_PGA_DISABLED);
    setDataRate(ADS122C04_DATA_RATE_175SPS);
    setOperatingMode(ADS122C04_OP_MODE_NORMAL);
    setConversionMode(ADS122C04_CONVERSION_MODE_SINGLE_SHOT);
    setVoltageReference(ADS122C04_VREF_INTERNAL);
    enableInternalTempSensor(ADS122C04_TEMP_SENSOR_OFF);
    setDataCounter(ADS122C04_DCNT_DISABLE);
    setDataIntegrityCheck(ADS122C04_CRC_DISABLED);
    setBurnOutCurrent(ADS122C04_BURN_OUT_CURRENT_OFF);
    setIDACcurrent(ADS122C04_IDAC_CURRENT_OFF);
    setIDAC1mux(ADS122C04_IDAC1_DISABLED);
    setIDAC2mux(ADS122C04_IDAC2_DISABLED);
    _delay_ms(5);

    uint8_t rb0=0, rb1=0;
    ADS122C04_readReg(ADS122C04_CONFIG_0_REG, &rb0);
    ADS122C04_readReg(ADS122C04_CONFIG_1_REG, &rb1);
    diag_dr   = (rb1 >> 5) & 0x07;
    diag_pga  = rb0 & 0x01;
    diag_gain = (rb0 >> 1) & 0x07;
    set_sample_timing(diag_dr);

    reset();
    _delay_ms(2);
    setDataRate(ADS122C04_Reg.reg1.bit.DR);

    run_mode();
}
