/* ─── RAMP TABLE TYPE ────────────────────────────────────────────────────── */
typedef struct { float key; float val; } RampEntry;

static const RampEntry RAMP_UP[] = {
    {-100.0f,  0.0001f}, {  40.0f,  0.1f   }, { 200.0f,  0.1f   }, { 400.0f,  0.1f   },
};
#define RAMP_UP_N  4

static const RampEntry RAMP_DN[] = {
    {-100.0f, -0.00001f}, {  40.0f, -0.1f    }, { 200.0f, -0.2f    }, { 400.0f, -1.0f    },
};
#define RAMP_DN_N  4

static const RampEntry STAB_REC[] = {
    {0.0f,    1.00f}, {0.00001f,1.00f}, {0.001f,  1.00f}, {0.01f,   0.90f},
    {0.1f,    0.85f}, {0.25f,   0.67f}, {0.5f,    0.50f}, {0.8f,    0.25f},
};
#define STAB_REC_N  8

/* Calibration table (Editable via Serial) */
typedef struct { float p_mv; long ppm; } CalibEntry;
static CalibEntry CALIB[] = {
    {  0.00f,      0},
    {  0.12f,      5},
    {  0.30f,     10},
    {  4.20f,    100},
    { 60.00f,   1000},
    {260.00f,   5000},
    {368.00f,  10000},
    {430.00f,  20000},
    {720.00f, 100000},
};
#define CALIB_N  9

/* ═══════════════════════════════════════════════════════════════════════════
   TABLE LOOKUP HELPERS
   ═══════════════════════════════════════════════════════════════════════════ */
static float vlu(float v, const RampEntry *tbl, uint8_t n) {
    float r = tbl[0].val;
    for (uint8_t i = 0; i < n; i++) {
        if (v >= tbl[i].key) r = tbl[i].val;
        else break;
    }
    return r;
}

static float vlu_sd(float v, const RampEntry *tbl, uint8_t n) {
    float r = tbl[0].val;
    for (uint8_t i = 0; i < n; i++) {
        if (v >= tbl[i].key) r = tbl[i].val;
    }
    return r;
}

static long calib_interp(float p_val) {
    if (p_val <= CALIB[0].p_mv)        return CALIB[0].ppm;
    if (p_val >= CALIB[CALIB_N-1].p_mv) return CALIB[CALIB_N-1].ppm;
    for (uint8_t i = 0; i < CALIB_N - 1; i++) {
        float x0 = CALIB[i].p_mv,   x1 = CALIB[i+1].p_mv;
        long  y0 = CALIB[i].ppm,    y1 = CALIB[i+1].ppm;
        if (p_val >= x0 && p_val <= x1) {
            float t = (p_val - x0) / (x1 - x0);
            return (long)(y0 + t * (float)(y1 - y0) + 0.5f);
        }
    }
    return CALIB[CALIB_N-1].ppm;
}

/* ═══════════════════════════════════════════════════════════════════════════
   INCREMENTAL DETECTION ENGINE STATE
   ═══════════════════════════════════════════════════════════════════════════ */
#define SD_WIN 6
static float sd_buf[SD_WIN];
static uint8_t sd_idx = 0;

static float sd_push(float v) {
    sd_buf[sd_idx] = v;
    sd_idx = (sd_idx + 1) % SD_WIN;
    float sum = 0.0f;
    for (uint8_t i = 0; i < SD_WIN; i++) sum += sd_buf[i];
    float mean = sum / SD_WIN;
    float var  = 0.0f;
    for (uint8_t i = 0; i < SD_WIN; i++) {
        float d = sd_buf[i] - mean;
        var += d * d;
    }
    return sqrtf(var / SD_WIN);
}

#define C_WIN 7
static float   c_buf[C_WIN]; 
static uint8_t c_buf_idx = 0;
static uint8_t c_buf_filled = 0;

static void c_push(float v) {
    c_buf[c_buf_idx] = v;
    c_buf_idx = (c_buf_idx + 1) % C_WIN;
    if (c_buf_filled < C_WIN) c_buf_filled++;
}

static float c_get_back(uint8_t k) {
    int idx = (int)c_buf_idx - 1 - (int)k;
    while (idx < 0) idx += C_WIN;
    return c_buf[idx];
}

/* ─── Engine state (all promoted to file scope so do_calibrate can reset) ── */
static uint32_t sample_count    = 0;
static float    C_leaky          = 0.0f;
static float    baseline_L       = 0.0f;
static float    floor_baseline   = 0.0f;
static bool     baseline_seeded  = false;

/* D/E/F/G counters */
static uint16_t cnt_D  = 0;   
static float    acc_E  = 0.0f; 
static uint16_t cnt_F  = 0;   
static float    acc_G  = 0.0f; 

/* Direction indicator */
static float    II = -1.0f;
static float    II_prev = -1.0f;

/* N accumulator and ROC counter */
static float    N_accum  = 0.0f;
static uint16_t O_roc    = 0;
static float    P_clip   = 0.0f;

/* ppm output */
static long     Q_ppm    = 0;
static bool     ppm_locked = false;
static long     locked_ppm = 0;

/* Recovery */
static float    peak_M   = 0.0f;
static float    rec_pct  = 100.0f;

/*
 * FIX 4: M_prev is now a proper engine-level variable (not a local static
 * inside engine_step) so do_calibrate() can reset it cleanly.
 */
static float    M_prev   = 0.0f;

/* Warmup accumulator */
#define WARMUP_ACC_MAX 400
static float warmup_acc[WARMUP_ACC_MAX];
static uint16_t warmup_acc_n = 0;

typedef enum { OR_NORMAL=0, OR_OVERRANGE, OR_WAIT_DROP, OR_STABLE } OrState;
static OrState or_state = OR_NORMAL;

typedef enum { FLAG_AIR=0, FLAG_UP, FLAG_DOWN, FLAG_REC, FLAG_OVERRANGE, FLAG_WAIT, FLAG_STABLE } FlagState;
static FlagState disp_flag = FLAG_AIR;

/* ─── Forward declarations ────────────────────────────────────────────────── */
void USART1_sendChar(char c);
void USART1_sendStr(const char *s);
void USART1_sendFloat(float v, uint8_t decimals);
void USART1_sendLong(long v);
void USART1_sendUInt(uint32_t v);
