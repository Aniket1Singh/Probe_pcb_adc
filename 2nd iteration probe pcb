    USART1_sendStr(" DNI="); USART1_sendFloat(P.dnI,    4); tx_newline();
    USART1_sendStr(" REC="); USART1_sendFloat(P.rec,    4); tx_newline();
    USART1_sendStr(" DRF="); USART1_sendFloat(P.drf,    2); tx_newline();
    USART1_sendStr(" NTH="); USART1_sendFloat(P.n_thresh,6); tx_newline();
    USART1_sendStr(" OCP="); USART1_sendUInt(P.o_cap);       tx_newline();
    USART1_sendStr(" RZP="); USART1_sendFloat(P.rec_zero_pct,4); tx_newline();
