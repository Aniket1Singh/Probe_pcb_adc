/* ═══════════════════════════════════════════════════════════════════════════
   WARMUP MEAN
   ═══════════════════════════════════════════════════════════════════════════ */
static float warmup_mean(void) {
    float s = 0.0f;
    for (uint16_t i = 0; i < warmup_acc_n; i++) s += warmup_acc[i];
    return (warmup_acc_n > 0) ? s / warmup_acc_n : 0.0f;
}

/* ═══════════════════════════════════════════════════════════════════════════
   CALIBRATE — Master Reset
   ═══════════════════════════════════════════════════════════════════════════ */
static void do_calibrate(void) {
    float new_base = C_leaky;
    baseline_L      = new_base;
    floor_baseline  = new_base;
    baseline_seeded = true;

    peak_M     = 0.0f;
    M_prev     = 0.0f;     /* FIX 4: reset M_prev so recovery math is clean */
    ppm_locked = false;
    locked_ppm = 0;

    cnt_D  = 0; acc_E = 0.0f;
    cnt_F  = 0; acc_G = 0.0f;
    II      = -1.0f;
    II_prev = -1.0f;
    N_accum = 0.0f;
    O_roc   = 0;
    P_clip  = 0.0f;
    Q_ppm   = 0;
    rec_pct = 100.0f;

    /* do NOT reset or_state here — let the OR state machine run naturally */
    disp_flag = FLAG_AIR;

    USART1_sendStr("OK_CAL\r\n");
}

/* ═══════════════════════════════════════════════════════════════════════════
   DETECTION ENGINE — one sample step
   Mirrors Python IncrementalCompute.step() exactly.
   ═══════════════════════════════════════════════════════════════════════════ */
static void engine_step(float emf_mv) {
    sample_count++;

    /* ── Sample 1: seed everything ───────────────────────────────────────── */
    float C_prev = C_leaky;
    if (sample_count == 1) {
        C_leaky = emf_mv;
        for (uint8_t i = 0; i < SD_WIN; i++) sd_buf[i] = emf_mv;
        for (uint8_t i = 0; i < C_WIN;  i++) c_buf[i]  = emf_mv;
        c_buf_filled = C_WIN;
        if (!baseline_seeded) {
            baseline_L     = emf_mv;
            floor_baseline = emf_mv;
        }
        M_prev  = 0.0f;
        II_prev = II;
        return;
    }

    /* ── Leaky integrator ────────────────────────────────────────────────── */
    if (fabsf(emf_mv - C_prev) > P.jmp)
        C_leaky = emf_mv;
    else
        C_leaky = (emf_mv - C_prev) * P.alp + C_prev;

    c_push(C_leaky);
    float J_sd = sd_push(C_leaky);

    /* ── Overrange state machine ──────────────────────────────────────────
     *  FIX 3 (CRITICAL): or_state is NEVER reset here.  It is a persistent
     *  state variable — only the transitions inside this switch may change it.
     * ──────────────────────────────────────────────────────────────────── */
    switch (or_state) {
        case OR_NORMAL:
            if (emf_mv > P.or_thresh)           or_state = OR_OVERRANGE;
            break;
        case OR_OVERRANGE:
            if (emf_mv < P.or_exit_mv)          or_state = OR_WAIT_DROP;
            break;
        case OR_WAIT_DROP:
            if (emf_mv > P.or_thresh)           { or_state = OR_OVERRANGE; break; }
            if (J_sd < P.or_sd_stable && emf_mv < P.or_exit_mv)
                                                or_state = OR_STABLE;
            break;
        case OR_STABLE:
            if (emf_mv > P.or_thresh)           or_state = OR_OVERRANGE;
            break;
    }

    bool in_or = (or_state != OR_NORMAL);

    /* ── Warmup baseline seeding ─────────────────────────────────────────── */
    if (!baseline_seeded) {
        if (warmup_acc_n < P.warmup && warmup_acc_n < WARMUP_ACC_MAX)
            warmup_acc[warmup_acc_n++] = C_leaky;

        if (sample_count == (uint32_t)P.warmup) {
            float seed = warmup_mean();
            baseline_L     = seed;
            floor_baseline = seed;
            baseline_seeded = true;
        }
    }

    bool in_warmup = (!baseline_seeded);

    /* ── Gate: skip H2 logic during overrange / first 8 samples ─────────── */
    if (in_or || sample_count < 8) {
        switch (or_state) {
            case OR_OVERRANGE: disp_flag = FLAG_OVERRANGE; break;
            case OR_WAIT_DROP: disp_flag = FLAG_WAIT;      break;
            case OR_STABLE:    disp_flag = FLAG_STABLE;    break;
            default:                                       break;
        }
        II_prev = II;
        /* M_prev is NOT updated during the gated period — matches Python */
        return;
    }

    /* ── Ring buffer lookbacks ───────────────────────────────────────────── */
    float c6  = (c_buf_filled >= 7) ? c_get_back(6) : c_get_back(c_buf_filled - 1);
    float cp1 = c_get_back(1);

    /* ── D/E up counters ─────────────────────────────────────────────────── */
    float ru_thresh = vlu(C_leaky, RAMP_UP, RAMP_UP_N);
    if ((C_leaky - cp1) > ru_thresh) { cnt_D++; acc_E += (C_leaky - c6); }
    else                             { cnt_D = 0; acc_E = 0.0f; }

    /* ── F/G down counters ───────────────────────────────────────────────── */
    float rd_thresh = vlu(C_leaky, RAMP_DN, RAMP_DN_N);
    if ((C_leaky - c6) < rd_thresh)  { cnt_F++; acc_G += (C_leaky - c6); }
    else                             { cnt_F = 0; acc_G = 0.0f; }

    /* ── Direction vote ──────────────────────────────────────────────────── */
    int8_t h = 0;
    if ((float)cnt_D > P.upG && acc_E > P.inG)  h += 1;
    if ((float)cnt_F > P.dnG && acc_G < P.dnI)  h -= 1;

    II_prev = II;
    if (h != 0) II = (float)h;

    /* ── Stability / recovery factor K ──────────────────────────────────── */
    float K = 0.0f;
    if (!in_warmup && II != 1.0f)
        K = vlu_sd(J_sd, STAB_REC, STAB_REC_N);

    /* ── Baseline update (downward ratchet + upward drift cap) ──────────── */
    if (!in_warmup) {
        if (C_leaky < floor_baseline) {
            floor_baseline = C_leaky;
            baseline_L     = C_leaky;
        } else {
            if (K >= P.rec && fabsf(C_leaky - floor_baseline) < P.drf)
                baseline_L = C_leaky;
        }
    }

    float M_delta = C_leaky - baseline_L;

    /* ── Peak capture: take M from the PREVIOUS sample at the UP→DOWN edge ─
     *  FIX 3: Python does  peak_m = abs(self.M[-1])  which is the M that was
     *  appended in the PREVIOUS call (i.e. M_prev here), not M_delta of the
     *  current sample.  For low concentrations the baseline has already moved
     *  by the time II flips, so using M_delta gives a near-zero peak and
     *  breaks the recovery percentage.
     * ──────────────────────────────────────────────────────────────────── */
    if (II == -1.0f && II_prev == 1.0f)
        peak_M = fabsf(M_prev);

    /* ── Recovery % ──────────────────────────────────────────────────────── */
    if (II == -1.0f && peak_M > 0.0f) {
        float abs_m = fabsf(M_delta);
        if (abs_m < P.rec_zero_pct * peak_M)
            rec_pct = 100.0f;
        else {
            float r = (1.0f - abs_m / peak_M) * 100.0f;
            if (r < 0.0f)   r = 0.0f;
            if (r > 99.9f)  r = 99.9f;
            rec_pct = r;
        }
    } else if (II == 1.0f) {
        rec_pct = 0.0f;
    }
    /* else: II still -1 but peak_M==0 → leave rec_pct as is (stay at 100) */

    /* ── N accumulator & ppm lock ────────────────────────────────────────
     *  FIX 1+2 (CRITICAL):
     *   • When II is NOT +1 → break the ppm lock immediately, and zero N.
     *     Python does this unconditionally in the `else: n_val = 0.0` branch
     *     of IncrementalCompute.step(), and the lock is also broken there.
     *   • The lock is only SET when O_roc first hits o_cap (exactly as Python).
     *   • ppm output drops to 0 as soon as gas leaves UP state.
     * ──────────────────────────────────────────────────────────────────── */
    if (II == 1.0f && II_prev == -1.0f) {
        /* Fresh UP event — restart accumulator, clear any old lock */
        N_accum    = M_delta;
        ppm_locked = false;
        locked_ppm = 0;
    } else if (II == 1.0f) {
        /* Continuing UP — accumulate significant steps */
        float delta_m = M_delta - M_prev;
        if (M_delta > 0.0f && delta_m > P.n_thresh * M_delta)
            N_accum += delta_m;
    } else {
        /*
         * FIX 2: Gas is NOT in UP state anymore (DOWN / AIR / REC).
         * Break the ppm lock right now — do not wait for rec_pct == 100.
         * This matches Python exactly and makes ppm drop to 0 immediately.
         */
        N_accum    = 0.0f;
        ppm_locked = false;
        locked_ppm = 0;
    }

    /* ── ROC counter O ───────────────────────────────────────────────────── */
    uint16_t O_prev = O_roc;
    if (II > 0.0f) {
        O_roc = (O_prev >= P.o_cap) ? P.o_cap : O_prev + 1;
    } else {
        O_roc = 0;
    }

    /* ── P clip & lock ───────────────────────────────────────────────────── */
    if (O_roc == O_prev) {
        /* O unchanged — P_clip unchanged */
    } else if (O_roc == P.o_cap) {
        P_clip = N_accum;
    } else {
        P_clip = 0.0f;
    }

    /* Lock fires exactly once when O first reaches o_cap */
    if (O_roc == P.o_cap && O_prev < P.o_cap) {
        ppm_locked = true;
        locked_ppm = calib_interp(P_clip);
    }

    /* ── Q ppm output ────────────────────────────────────────────────────── */
    if (ppm_locked) {
        Q_ppm = locked_ppm;
    } else {
        float q_src = (O_roc >= P.o_cap) ? P_clip : N_accum;
        Q_ppm = calib_interp(q_src);
    }

    /* ── Display flag ────────────────────────────────────────────────────── */
    if (II == 1.0f)                                    disp_flag = FLAG_UP;
    else if (II == -1.0f && II_prev == 1.0f)           disp_flag = FLAG_DOWN;
    else if (II == -1.0f && rec_pct >= 100.0f)         disp_flag = FLAG_AIR;
    else if (II == -1.0f && rec_pct <  100.0f)         disp_flag = FLAG_REC;
    else                                               disp_flag = FLAG_AIR;

    /* ── Advance M_prev for next sample ──────────────────────────────────── */
    M_prev = M_delta;
}

/* ═══════════════════════════════════════════════════════════════════════════
   I2C DRIVER
   ═══════════════════════════════════════════════════════════════════════════ */
bool I2C_RawStart(uint8_t deviceAddr, uint8_t Direction) {
    volatile uint16_t timeout;
    deviceAddr = deviceAddr | Direction;
    if (I2C_BUS_NOT_BUSY) {
        for (volatile uint16_t arbLoop = 0x04; arbLoop > 0; arbLoop--) {
            TWI0.MADDR = deviceAddr;
            if (Direction)
            { for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_RIF_bm) && (timeout > 0); timeout--){} }
            else
            { for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_WIF_bm) && (timeout > 0); timeout--){} }
            if (I2C_ARBLOST) continue;
            if (I2C_BUSERR)  return(RETURN_BUS_ERROR);
            if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
            else                                return(RETURN_NO_SLAVE);
        }
    } else return(RETURN_BUS_BUSY);
    return(RETURN_BUS_ARBLOST);
}

bool I2C_RawStop(void) {
    volatile uint16_t timeout;
    for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm) && (timeout > 0); timeout--){}
    if (timeout == 0) return(RETURN_FAILED);
    TWI0.MCTRLB = TWI_ACKACT_NACK_gc | TWI_MCMD_STOP_gc;
    for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm) && (timeout > 0); timeout--){}
    if (I2C_BUSERR) TWI0.MSTATUS = TWI_BUSERR_bm;
    return(RETURN_OK);
}

void I2C_RawForceStop(void) {
    I2C_RawStop();
    TWI0.MSTATUS |= TWI_BUSSTATE_IDLE_gc;
    TWI0.MCTRLB  |= TWI_FLUSH_bm;
}

bool I2C_RawWrite(uint8_t write_data) {
    volatile uint16_t timeout;
    if (I2C_BUS_OWNER) {
        for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm) && (timeout > 0); timeout--){}
        if (timeout == 0) return(RETURN_FAILED);
        TWI0.MDATA = write_data;
        for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_WIF_bm) && (timeout > 0); timeout--){}
        if (I2C_BUSERR) return(RETURN_BUS_ERROR);
        if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
        else return(RETURN_NO_SLAVE);
    }
    return(RETURN_FAILED);
}

bool I2C_RawRead(uint8_t ACK) {
    volatile uint16_t timeout;
    if (I2C_BUS_OWNER) {
        for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_CLKHOLD_bm) && (timeout > 0); timeout--){}
        if (timeout == 0) return(RETURN_FAILED);
        if (ACK == 1) TWI0.MCTRLB &= ~(1 << TWI_ACKACT_bp);
        else          TWI0.MCTRLB |=  (1 << TWI_ACKACT_bp);
        for (timeout = I2C_WAIT_TIMEOUT; I2C_STATE_IS_LOW(TWI_RIF_bm) && (timeout > 0); timeout--){}
        if (timeout == 0) return(RETURN_FAILED);
        memdata = TWI0.MDATA;
        if (I2C_BUSERR) return(RETURN_FAILED);
        if (I2C_STATE_IS_LOW(TWI_RXACK_bm)) return(RETURN_OK);
        else return(RETURN_FAILED);
    }
    return(RETURN_FAILED);
}

void I2C_StartMaster(void) {
    PORTB.DIRSET = I2C_SCL;
    PORTB.DIRSET = I2C_SDA;
    TWI0.CTRLA   = TWI_SDAHOLD_500NS_gc | TWI_SDASETUP_8CYC_gc;
    TWI0.MBAUD   = (uint8_t)TWI0_BAUD(100000, 1000);
    TWI0.MCTRLA  = 1 << TWI_ENABLE_bp | 0 << TWI_QCEN_bp | 0 << TWI_RIEN_bp
                 | 1 << TWI_SMEN_bp | TWI_TIMEOUT_DISABLED_gc | 0 << TWI_WIEN_bp;
    TWI0.MSTATUS = TWI_BUSSTATE_IDLE_gc;
    TWI0.MSTATUS = (TWI_RIF_bm | TWI_WIF_bm);
    TWI0.MCTRLB  = TWI_FLUSH_bm;
}
void InitI2C(void) { I2C_StartMaster(); }

bool start_transmission(char device_address) { return(I2C_RawStart(device_address, I2C_WRITE)); }
bool stop_transmission(void)                 { return(I2C_RawStop()); }
