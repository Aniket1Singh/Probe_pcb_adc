static void process_cmd(void) {
    const char *s = (const char*)&company[1];

    if (s[0]=='R' && s[1]=='F' && rxcntr==12) {
        long long a=((s[2]-'0')*1000000LL)  + ((s[3]-'0')*100000LL)
                  + ((s[4]-'0')*10000LL)    + ((s[5]-'0')*1000LL)
                  + ((s[6]-'0')*100LL)      + ((s[7]-'0')*10LL)
                  + ((s[8]-'0')*1LL);
        Reference_Set_Value = a;
        mem_write(220, (long)Reference_Set_Value);
        USART1_sendStr("OK\r\n"); return;
    }

    if (s[0]=='T' && rxcntr==10) {
        long a = (s[1]-'0')*1000L + (s[2]-'0')*100L + (s[3]-'0')*10L + (s[4]-'0');
        long b = (s[6]-'0')*10L + (s[7]-'0');
        limit = (unsigned int)a;
        offset_value = (unsigned char)b;
        mem_write(6,   (long)limit);
        mem_write(150, (long)offset_value);
        USART1_sendStr("OK\r\n"); return;
    }

    if (s[0]=='C' && s[1]=='A' && s[2]=='L' && s[3]=='#') {
        do_calibrate(); return;
    }

    if (strncmp(s, "GET PARAMS", 10)==0) {
        send_params(); return;
    }

    /* ── *SET CAL <idx> <mV> <ppm># ── */
    if (s[0]=='S' && s[1]=='E' && s[2]=='T' && s[3]==' ' && s[4]=='C' && s[5]=='A' && s[6]=='L' && s[7]==' ') {
        char *ptr = (char*)&s[8];
        int idx = atoi(ptr);
        while(*ptr && *ptr != ' ') ptr++;
        if (*ptr == ' ') ptr++;
        float mv = atof(ptr);
        while(*ptr && *ptr != ' ') ptr++;
        if (*ptr == ' ') ptr++;
        long ppm = atol(ptr);

        if (idx >= 0 && idx < CALIB_N) {
            CALIB[idx].p_mv = mv;
            CALIB[idx].ppm = ppm;
            USART1_sendStr("OK SET CAL\r\n");
        } else {
            USART1_sendStr("ERR_IDX\r\n");
        }
        return;
    }

    if (s[0]=='S' && s[1]=='E' && s[2]=='T' && s[3]==' ') {
        char key[4] = {s[4], s[5], s[6], 0};
        float fval = atof((const char*)&s[8]);
        bool  ok   = true;

        if      (strcmp(key,"JMP")==0) P.jmp          = fval;
        else if (strcmp(key,"ALP")==0) P.alp          = fval;
        else if (strcmp(key,"UPG")==0) P.upG          = fval;
        else if (strcmp(key,"ING")==0) P.inG          = fval;
        else if (strcmp(key,"DNG")==0) P.dnG          = fval;
        else if (strcmp(key,"DNI")==0) P.dnI          = fval;
        else if (strcmp(key,"REC")==0) P.rec          = fval;
        else if (strcmp(key,"DRF")==0) P.drf          = fval;
        else if (strcmp(key,"NTH")==0) P.n_thresh     = fval;
        else if (strcmp(key,"OCP")==0) P.o_cap        = (uint16_t)fval;
        else if (strcmp(key,"RZP")==0) P.rec_zero_pct = fval;
        else if (strcmp(key,"WRM")==0) P.warmup       = (uint16_t)fval;
        else if (strcmp(key,"ORT")==0) P.or_thresh    = fval;
        else if (strcmp(key,"ORX")==0) P.or_exit_mv   = fval;
        else if (strcmp(key,"ORS")==0) P.or_sd_stable = fval;
        else ok = false;

        if (ok) {
            USART1_sendStr("OK SET "); USART1_sendStr(key);
            USART1_sendChar('='); USART1_sendFloat(fval, 6);
            tx_newline();
        } else {
            USART1_sendStr("ERR_UNKNOWN_KEY\r\n");
        }
        return;
    }

    USART1_sendStr("ERR_CMD\r\n");
}

ISR(USART1_RXC_vect) {
    unsigned char c = USART1.RXDATAL;
    if (c == '*') { strt = 1; rxcntr = 0; }
    if (strt == 1) {
        if (rxcntr < CMD_BUF_LEN - 1) company[rxcntr++] = c;
        if (c == '#') { 
            company[rxcntr] = '\0'; 
            cmd_ready = true; strt = 0; 
        }
    }
}

void USART1_init(void) {
    PORTA.DIR &= ~PIN2_bm;
    PORTA.DIR |=  PIN1_bm;
    USART1.BAUD  = (uint16_t)USART1_BAUD_RATE(9600);
    USART1.CTRLA = 0 << USART_ABEIE_bp | 0 << USART_DREIE_bp | 0 << USART_LBME_bp
                 | 1 << USART_RS485_bp  | 1 << USART_RXCIE_bp | 0 << USART_RXSIE_bp
                 | 0 << USART_TXCIE_bp;
    USART1.CTRLB |= USART_RXEN_bm | USART_TXEN_bm;
}

/* ═══════════════════════════════════════════════════════════════════════════
   OUTPUT LINE
   ═══════════════════════════════════════════════════════════════════════════ */
static void tx_output_line(long long int raw_milli_mv,
                            long long int ref_delta_mv)
{
    tx_raw_emf(raw_milli_mv);
    USART1_sendStr("  ");

    tx_ref_delta(ref_delta_mv);
    USART1_sendStr("  ");

    USART1_sendLong(Q_ppm);
    USART1_sendStr("  ");

    USART1_sendStr(flag_str(disp_flag));
    USART1_sendStr("  ");

    USART1_sendUInt((uint32_t)(rec_pct + 0.5f));
    USART1_sendChar('%');

    USART1_sendChar(0x0D); USART1_sendChar(0x0A);
}

/* ═══════════════════════════════════════════════════════════════════════════
   RUN MODE — purely counter-based (FIX 5)
   ─────────────────────────────────────────────────────────────────────────
   No time-gating.  The ADC read itself takes a fixed amount of time
   (determined by the data rate + inter-sample delay configured in
   read_sensor).  One call to read_sensor() = one engine sample.
   This is exactly how the Python simulator works (sample-indexed, not
   wall-clock-indexed) and removes any dependency on the millis timer
   for the engine cadence.
   ═══════════════════════════════════════════════════════════════════════════ */
void run_mode(void) {
    while (1) {
        /* ── Check for serial commands ──────────────────────────────────── */
        if (cmd_ready) {
            cmd_ready = false;
            process_cmd();
        }

        /* ── One ADC sample → one engine step ───────────────────────────── */
        read_sensor();

        float raw_mv_milli_f   = sensor_final_output;
        float delta_mv_milli_f = raw_mv_milli_f - (float)Reference_Set_Value;

        /*
         * emf_mv fed into engine is the REFERENCE-SUBTRACTED value in
         * millivolts-of-milli-volts (i.e. the raw ADC number divided by
         * 1000 to bring it to the same mV scale the Python uses).
         */
        float emf_mv = delta_mv_milli_f / 1000.0f;

        engine_step(emf_mv);

        long long int raw_milli_mv  = (long long int)raw_mv_milli_f;
        long long int delta_mv_milli = (long long int)delta_mv_milli_f;

        USART1_sendChar(0x0A);
        tx_output_line(raw_milli_mv, delta_mv_milli);
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
   MAIN
   ═══════════════════════════════════════════════════════════════════════════ */
int main(void) {
    PORTA_DIR    = 0xFF;
    PORTA_OUTSET = ADC_RESET;
    PORTB_DIR    = 0xFF;
    _delay_ms(500);

    InitI2C();
    USART1_init();
    _delay_ms(100);

    timer_init();
    sei();

    limit = (unsigned int)mem_read(6);
    _delay_ms(20);

    Reference_Set_Value = mem_read(220);
    if (Reference_Set_Value > 2000000) Reference_Set_Value = 0;

    offset_value = mem_read(150);
    if (offset_value > 100) offset_value = 30;

    USART1_sendStr("MNST\r\n");
    USART1_sendStr("T5-H2-V2 READY\r\n");
    USART1_sendStr("COLS: raw_mV  ref_delta  ppm  flag  rec%\r\n");

    setInputMultiplexer(ADS122C04_MUX_AIN1_AIN0);
    setGain(ADS122C04_GAIN_1);
    enablePGA(ADS122C04_PGA_DISABLED);
    setDataRate(ADS122C04_DATA_RATE_175SPS);
    setOperatingMode(ADS122C04_OP_MODE_NORMAL);
    setConversionMode(ADS122C04_CONVERSION_MODE_SINGLE_SHOT);
    setVoltageReference(ADS122C04_VREF_INTERNAL);
    enableInternalTempSensor(ADS122C04_TEMP_SENSOR_OFF);
    setDataCounter(ADS122C04_DCNT_DISABLE);
    setDataIntegrityCheck(ADS122C04_CRC_DISABLED);
    setBurnOutCurrent(ADS122C04_BURN_OUT_CURRENT_OFF);
    setIDACcurrent(ADS122C04_IDAC_CURRENT_OFF);
    setIDAC1mux(ADS122C04_IDAC1_DISABLED);
    setIDAC2mux(ADS122C04_IDAC2_DISABLED);
    _delay_ms(5);

    uint8_t rb0 = 0, rb1 = 0;
    ADS122C04_readReg(ADS122C04_CONFIG_0_REG, &rb0);
    ADS122C04_readReg(ADS122C04_CONFIG_1_REG, &rb1);
    diag_dr   = (rb1 >> 5) & 0x07;
    diag_pga  = rb0 & 0x01;
    diag_gain = (rb0 >> 1) & 0x07;
    set_sample_timing(diag_dr);

    reset();
    _delay_ms(2);
    setDataRate(ADS122C04_Reg.reg1.bit.DR);

    run_mode();
}
