/* ================================================================== */
/*  EEPROM HELPERS — original mem_write/mem_read format               */
/* ================================================================== */
void mem_write(unsigned int addr, long int val) {
    unsigned int r=(unsigned int)(val/10000), s=(unsigned int)(val%10000);
    eeprom_write_byte((uint8_t*)(1*addr),(uint8_t)r);         while(!eeprom_is_ready());
    addr++; eeprom_write_byte((uint8_t*)(1*addr),(uint8_t)(s/256)); while(!eeprom_is_ready());
    addr++; eeprom_write_byte((uint8_t*)(1*addr),(uint8_t)(s%256)); while(!eeprom_is_ready());
}
long int mem_read(uint8_t addr) {
    long int l=eeprom_read_byte((uint8_t*)(1*addr)); asm("nop"); addr++;
    unsigned int m=eeprom_read_byte((uint8_t*)(1*addr)); asm("nop"); addr++;
    unsigned int n=eeprom_read_byte((uint8_t*)(1*addr));
    _delay_ms(30);
    return (l*10000+m*256+n);
}

/* ================================================================== */
/*  UART                                                               */
/* ================================================================== */
void USART1_sendChar(char c) {
    while (!(USART1.STATUS & USART_DREIF_bm)) {} USART1.TXDATAL = c;
}
void USART1_sendStr(const char *s) { while (*s) USART1_sendChar(*s++); }
void tx_newline(void) { USART1_sendChar(0x0D); USART1_sendChar(0x0A); }
void USART1_sendUInt(uint32_t v) {
    char buf[11]; uint8_t i=0;
    if (v==0) { USART1_sendChar('0'); return; }
    while (v>0) { buf[i++]='0'+(v%10); v/=10; }
    while (i--) USART1_sendChar(buf[i]);
}
void USART1_sendLong(long v) {
    if (v<0) { USART1_sendChar('-'); v=-v; }
    USART1_sendUInt((uint32_t)v);
}
void USART1_sendFloat(float v, uint8_t decimals) {
    if (v < 0.0f) { USART1_sendChar('-'); v = -v; }
    float mult = 1.0f;
    for (uint8_t i = 0; i < decimals; i++) mult *= 10.0f;
    long full = (long)(v * mult + 0.5f);
    long iv   = full / (long)mult;
    long frac = full % (long)mult;
    USART1_sendUInt((uint32_t)iv); USART1_sendChar('.');
    long fmult = (long)mult / 10;
    while (fmult > 1 && frac < fmult) { USART1_sendChar('0'); fmult /= 10; }
    if (frac > 0) USART1_sendUInt((uint32_t)frac); else USART1_sendChar('0');
}
static void tx_flush(void) {
    while (!(USART1.STATUS & USART_TXCIF_bm)) {}
    USART1.STATUS = USART_TXCIF_bm;
}

/* ================================================================== */
/*  SENSOR READ                                                        */
/*                                                                     */
/*  Matches original Smart_Probe.cpp exactly (integer µV arithmetic). */
/*  raw_sensor_uv       = ADC/4096*1000  (filtered, integer µV)      */
/*  sensor_final_output = raw_sensor_uv − Reference_Set_Value (µV)   */
/*  emf_mv fed to engine = sensor_final_output / 1000.0f  (µV → mV) */
/* ================================================================== */
void set_sample_timing(uint8_t dr) {
    switch(dr) {
        case ADS122C04_DATA_RATE_20SPS:   inter_sample_ms=50;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_45SPS:   inter_sample_ms=22;  drdy_timeout_ms=75;  break;
        case ADS122C04_DATA_RATE_90SPS:   inter_sample_ms=44;  drdy_timeout_ms=44;  break;
        case ADS122C04_DATA_RATE_175SPS:  inter_sample_ms=30;  drdy_timeout_ms=36;  break;
        case ADS122C04_DATA_RATE_330SPS:  inter_sample_ms=12;  drdy_timeout_ms=18;  break;
        case ADS122C04_DATA_RATE_600SPS:  inter_sample_ms=8;   drdy_timeout_ms=12;  break;
        case ADS122C04_DATA_RATE_1000SPS: inter_sample_ms=4;   drdy_timeout_ms=8;   break;
        default:                          inter_sample_ms=50;  drdy_timeout_ms=75;  break;
    }
}
static void filter_raw_sensor(void) {
    if (raw_sensor_uv >= pub_adc_value) {
        diff_adc_value = raw_sensor_uv - pub_adc_value;
        if (diff_adc_value > (long long)limit) pub_adc_value = raw_sensor_uv;
        else                                   raw_sensor_uv = pub_adc_value;
    } else {
        diff_adc_value = pub_adc_value - raw_sensor_uv;
        if (diff_adc_value > (long long)limit) pub_adc_value = raw_sensor_uv;
        else                                   raw_sensor_uv = pub_adc_value;
    }
}
static void read_sensor_slow(void) {
    long long adc_avg = 0;
    for (unsigned int i = 0; i < 4; i++) {
        bool drdy=0; uint16_t mc=0; start();
        do { mc++; _delay_ms(1); drdy=checkDataReady(); } while (!drdy && mc<drdy_timeout_ms);
        uint32_t raw=readADC(); if (raw>=0x800000) raw=0;
        adc_avg += (long long)(((float)raw)/4096.0f*1000.0f);
        for (uint16_t d=0; d<inter_sample_ms; d++) _delay_ms(1);
    }
    raw_sensor_uv = adc_avg / 4;
    if (raw_sensor_uv > 2047999) raw_sensor_uv = 2047999;
    filter_raw_sensor();
    sensor_final_output = raw_sensor_uv - Reference_Set_Value;
}
static void read_sensor_single(void) {
    bool drdy=0; uint32_t t=millis_count; start();
    do { drdy=checkDataReady(); } while (!drdy && (millis_count-t)<drdy_timeout_ms);
    uint32_t raw=readADC(); if (raw>=0x800000) raw=0;
    raw_sensor_uv = (long long)(((float)raw)/4096.0f*1000.0f);
    if (raw_sensor_uv > 2047999) raw_sensor_uv = 2047999;
    t=millis_count; while ((millis_count-t)<inter_sample_ms) {}
    filter_raw_sensor();
    sensor_final_output = raw_sensor_uv - Reference_Set_Value;
}
void read_sensor(void) {
    switch (diag_dr) {
        case ADS122C04_DATA_RATE_20SPS:
        case ADS122C04_DATA_RATE_45SPS: read_sensor_slow();   break;
        default:                        read_sensor_single(); break;
    }
}

/* ================================================================== */
/*  COMMAND PARSER                                                     */
/* ================================================================== */
static long parse_long(char **str) {
    char *p=*str; while (*p==' '||*p=='\t') p++;
    long sign=1;
    if (*p=='-'){sign=-1;p++;} else if (*p=='+') p++;
    long val=0;
    while (*p>='0'&&*p<='9') val=val*10+(*p++-'0');
    *str=p; return sign*val;
}
static float parse_float(char **str) {
    char *p=*str; while (*p==' '||*p=='\t') p++;
    float sign=1.0f;
    if (*p=='-'){sign=-1.0f;p++;} else if (*p=='+') p++;
    long int_part=0;
    while (*p>='0'&&*p<='9') int_part=int_part*10+(*p++-'0');
    float val=(float)int_part;
    if (*p=='.') {
        p++; float frac=0.0f, scale=0.1f;
        while (*p>='0'&&*p<='9') { frac+=(*p++-'0')*scale; scale*=0.1f; }
        val+=frac;
    }
    *str=p; return sign*val;
}

