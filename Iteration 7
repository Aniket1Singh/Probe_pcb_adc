/* ================================================================== */
/*  OUTPUT LINE — 9 columns                                            */
/*  Python log parser reads col-2 as EMF → that is emf_mv here.      */
/* ================================================================== */
static void tx_output_line(float emf_mv) {
    /* Col 1: RefR */
    USART1_sendLong((long)Reference_Set_Value);
    USART1_sendChar(' ');

    /* Col 2: EMF_mV — ref-subtracted, matches Python col-2 (str3) */
    USART1_sendFloat(emf_mv, 3);
    USART1_sendChar(' ');

    /* Col 3: DispPPM */
    {
        long d = (warmup_phase == WARMUP_RUNNING && or_state == OR_NORMAL) ? S_ppm : 0L;
        USART1_sendLong(d);
    }
    USART1_sendChar(' ');

    /* Col 4: Type */
    USART1_sendChar((Q_ppm >= R_ppm) ? 'F' : 'A');
    USART1_sendChar(' ');

    /* Col 5: H2_Flag */
    {
        const char *flag;
        bool in_or = (or_state != OR_NORMAL);
        bool near  = (fabsf(daughter_baseline - mother_baseline) <= P.daughter_mother_prox);
        if (in_or || warmup_phase != WARMUP_RUNNING) {
            flag = near ? "AIR_L" : "AIR_H";
        } else if (II == 1.0f) {
            flag = "UP";
        } else if (II == -1.0f && II_prev == 1.0f) {
            flag = "DOWN";
        } else if (II == -1.0f && rec_pct < 100.0f) {
            flag = "REC";
        } else {
            flag = near ? "AIR_L" : "AIR_H";
        }
        USART1_sendStr(flag);
    }
    USART1_sendChar(' ');

    /* Col 6: Rec_Status — 100_L / 100_H / integer % */
    {
        uint8_t rp = (uint8_t)(rec_pct + 0.5f);
        if (rp > 100) rp = 100;
        if (rp == 100) {
            bool near = (fabsf(daughter_baseline - mother_baseline) <= P.daughter_mother_prox);
            USART1_sendStr(near ? "100_L" : "100_H");
        } else {
            USART1_sendUInt(rp);
        }
    }
    USART1_sendChar(' ');

    /* Col 7: OR_Status */
    {
        const char *ors;
        switch (or_state) {
            case OR_OVERRANGE: ors = "OVERRANGE";  break;
            case OR_WAIT_DROP: ors = "WAIT_DROP";  break;
            case OR_STABLE:    ors = "PRESS_TARE"; break;
            default:           ors = "NORMAL";     break;
        }
        USART1_sendStr(ors);
    }
    USART1_sendChar(' ');

    /* Col 8: Warmup */
    {
        uint8_t ws;
        if      (warmup_phase == WARMUP_RUNNING)    ws = 4;
        else if (warmup_phase == WARMUP_READY_TARE) ws = 3;
        else if (warmup_phase == WARMUP_PROX_FAIL)  ws = 2;
        else ws = ((uint32_t)sample_count < (uint32_t)P.warmup) ? 0 : 1;
        USART1_sendUInt(ws);
    }
    USART1_sendChar(' ');

    /* Col 9: PostCnt */
    USART1_sendUInt(post_high_active ? (uint32_t)post_high_counter : 0u);

    USART1_sendChar(0x0D); USART1_sendChar(0x0A);
}

/* ================================================================== */
/*  RUN MODE                                                           */
/* ================================================================== */
void run_mode(void) {
    while (1) {
        if (cmd_ready) { cmd_ready = false; process_cmd(); }

        if (!is_running) {
            USART1_sendStr("WAITING_FOR_START\r\n");
            _delay_ms(500);
            continue;
        }

        /*
         * FIX 1 — EMF scaling (THE primary ppm bug):
         *
         * read_sensor() produces (integer µV):
         *   raw_sensor_uv       = ADC/4096*1000  (filtered)
         *   sensor_final_output = raw_sensor_uv - Reference_Set_Value
         *
         * Python reads this as str3 printed as mV with 3 decimal places,
         * i.e. the numeric value = sensor_final_output / 1000.0
         * That is exactly what we feed to engine_step() here.
         *
         * Old (WRONG): emf_mv = (sensor_final_output - Ref) / 1000
         *   → subtracted reference TWICE → completely wrong EMF value
         * New (CORRECT): emf_mv = sensor_final_output / 1000.0f
         *   → one subtraction already done inside read_sensor()
         */
        read_sensor();
        float emf_mv = (float)sensor_final_output / 1000.0f;

        engine_step(emf_mv);

        USART1_sendChar(0x0A);
        tx_output_line(emf_mv);
    }
}

/* ================================================================== */
/*  MAIN                                                               */
/* ================================================================== */
int main(void) {
    PORTA_DIR    = 0xFF;
    PORTA_OUTSET = ADC_RESET;
    PORTB_DIR    = 0xFF;
    _delay_ms(500);

    InitI2C();
    USART1_init();
    _delay_ms(100);
    timer_init();
    sei();

    limit = (unsigned int)mem_read(6);
    _delay_ms(20);
    Reference_Set_Value = mem_read(220);
    if (Reference_Set_Value > 2000000) Reference_Set_Value = 0;
    offset_value = (unsigned char)mem_read(150);
    if (offset_value > 100) offset_value = 30;

    calib_load(FAST_EE_MAGIC_ADDR, FAST_EE_DATA_ADDR, CALIB_FAST, CALIB_FAST_DEFAULT);
    calib_load(AN_EE_MAGIC_ADDR,   AN_EE_DATA_ADDR,   CALIB_AN,   CALIB_AN_DEFAULT);
    mb_ee_load();

    /*
     * FIX 4 — params_ee_load() now falls back to DEFAULT_PARAMS if
     * EEPROM magic is missing or sanity check fails, guaranteeing
     * o_cap=80 and n_thresh=0.002 on first boot.
     */
    params_ee_load();

    USART1_sendStr("MNST\r\n");
    USART1_sendStr("T5-H2-V2-FIXED READY\r\n");
    USART1_sendStr("Send *start# to begin.\r\n");
    USART1_sendStr("Cmds: *SET *CAL *TEAR *IGNORE_PROX *GET PARAMS "
                   "*RF *T *SET CAL *SET ANCAL\r\n");
    USART1_sendStr("Keys: JMP ALP UPG ING DNG DNI REC DRF NTH OCP "
                   "RZP WRM ORT ORX ORS DMP PHT PHL PHU PHI\r\n");

    setInputMultiplexer(ADS122C04_MUX_AIN1_AIN0);
    setGain(ADS122C04_GAIN_1);
    enablePGA(ADS122C04_PGA_DISABLED);
    setDataRate(ADS122C04_DATA_RATE_175SPS);
    setOperatingMode(ADS122C04_OP_MODE_NORMAL);
    setConversionMode(ADS122C04_CONVERSION_MODE_SINGLE_SHOT);
    setVoltageReference(ADS122C04_VREF_INTERNAL);
    enableInternalTempSensor(ADS122C04_TEMP_SENSOR_OFF);
    setDataCounter(ADS122C04_DCNT_DISABLE);
    setDataIntegrityCheck(ADS122C04_CRC_DISABLED);
    setBurnOutCurrent(ADS122C04_BURN_OUT_CURRENT_OFF);
    setIDACcurrent(ADS122C04_IDAC_CURRENT_OFF);
    setIDAC1mux(ADS122C04_IDAC1_DISABLED);
    setIDAC2mux(ADS122C04_IDAC2_DISABLED);
    _delay_ms(5);

    uint8_t rb0=0, rb1=0;
    ADS122C04_readReg(ADS122C04_CONFIG_0_REG, &rb0);
    ADS122C04_readReg(ADS122C04_CONFIG_1_REG, &rb1);
    diag_dr   = (rb1 >> 5) & 0x07;
    diag_pga  = rb0 & 0x01;
    diag_gain = (rb0 >> 1) & 0x07;
    set_sample_timing(diag_dr);	

    reset();
    _delay_ms(2);
    setDataRate(ADS122C04_Reg.reg1.bit.DR);

    run_mode();
}
