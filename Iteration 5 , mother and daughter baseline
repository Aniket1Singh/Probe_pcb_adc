# ── VLOOKUP HELPERS ───────────────────────────────────────────────────────────
def vlu(v, tbl):
    r = tbl[0][1]
    for k, val in tbl:
        if v >= k: r = val
        else: break
    return r

def vlu_sd(v, tbl):
    r = tbl[0][1]
    for k, val in tbl:
        if v >= k: r = val
    return r

def calib_interp(p_val, tbl):
    if p_val <= tbl[0][0]:  return float(tbl[0][1])
    if p_val >= tbl[-1][0]: return float(tbl[-1][1])
    for i in range(len(tbl) - 1):
        x0, y0 = tbl[i]; x1, y1 = tbl[i + 1]
        if x0 <= p_val <= x1:
            t = (p_val - x0) / (x1 - x0)
            return round(y0 + t * (y1 - y0))
    return float(tbl[-1][1])


# ── LOG PARSER ────────────────────────────────────────────────────────────────
_LOG_RE = re.compile(r'^\s*[+-]?\d+(?:\.\d+)?[\s\t]+([+-]?\d+(?:\.\d+)?)')

def parse_log_emf(line):
    line = line.strip().replace('\r', '').replace('\x00', '')
    m = _LOG_RE.match(line)
    if m:
        try: return float(m.group(1))
        except: pass
    return None


