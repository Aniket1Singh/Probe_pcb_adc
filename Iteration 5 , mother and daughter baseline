    def _update_charts(self,tl,raw,C,L,MB,N,Pv,Q,RC,or_thr=720.0):
        now_ms=time.monotonic()*1000
        if now_ms-self._last_chart_ms<self.CHART_EVERY: return
        self._last_chart_ms=now_ms
        if len(tl)<2: return
        x_min=float(tl[0]); x_max=float(tl[-1])
        if not (np.isfinite(x_min) and np.isfinite(x_max)) or x_max<=x_min: return
        n_pts=len(tl)
        if n_pts>1000:
            ds=n_pts//1000; tl=tl[::ds]; raw=raw[::ds]; C=C[::ds]
            L=L[::ds]; MB=MB[::ds]; N=N[::ds]; Pv=Pv[::ds]; Q=Q[::ds]; RC=RC[::ds]
        self.ax1.set_xlim(x_min,x_max); self.ax2.set_xlim(x_min,x_max)
        self.ln_raw.set_data(tl,raw); self.ln_lea.set_data(tl,C)
        self.ln_bas.set_data(tl,L); self.ln_mother.set_data(tl,MB)
        self.ln_or_thr.set_data([x_min,x_max],[or_thr,or_thr])
        self.ln_N.set_data(tl,N); self.ln_P.set_data(tl,Pv)
        self.ln_Q.set_data(tl,Q); self.ln_REC.set_data(tl,RC)
        if len(raw)>0:
            raw_a=np.asarray(raw,dtype=float); c_a=np.asarray(C,dtype=float)
            l_a=np.asarray(L,dtype=float); mb_a=np.asarray(MB,dtype=float)
            all_y1=np.concatenate([raw_a,c_a,l_a,mb_a])
            valid1=all_y1[np.isfinite(all_y1)]
            if len(valid1)>0:
                ymin1=valid1.min(); ymax1=valid1.max(); span1=ymax1-ymin1
                if span1<MIN_MV_SPAN:
                    mid1=(ymin1+ymax1)/2.0; ymin1=mid1-MIN_MV_SPAN/2.0; ymax1=mid1+MIN_MV_SPAN/2.0; margin1=MIN_MV_SPAN*0.06
                else: margin1=span1*0.06
                self.ax1.set_ylim(ymin1-margin1,ymax1+margin1)
        if len(Q)>0:
            q_a=np.asarray(Q,dtype=float); pv_a=np.asarray(Pv,dtype=float); n_a=np.asarray(N,dtype=float)
            all_y2=np.concatenate([q_a,pv_a,n_a]); valid2=all_y2[np.isfinite(all_y2)]
            if len(valid2)>0:
                ymin2=valid2.min(); ymax2=valid2.max(); span2=ymax2-ymin2
                if span2<MIN_PPM_SPAN:
                    mid2=(ymin2+ymax2)/2.0; half=MIN_PPM_SPAN/2.0
                    ymin2=max(0.0,mid2-half); ymax2=ymin2+MIN_PPM_SPAN; margin2=MIN_PPM_SPAN*0.08
                else: margin2=span2*0.08
                self.ax2.set_ylim(max(0.0,ymin2-margin2),ymax2+margin2)
        self.ax2b.set_ylim(-5,105); self.mpl.draw_idle()

    def _draw_prog(self,pct):
        if not self._prog_w: return
        self._prog_cv.delete('all')
        self._prog_cv.create_rectangle(0,0,int(self._prog_w*pct/100),3,fill=ACC,width=0)

    def _reset_flag_boxes(self):
        self._stop_flash(); self._stop_ready_flash()
        for d in self.flag_boxes.values():
            for w in (d['frame'],d['dot'],d['name'],d['count'],d['inner']): w.config(bg=PNL)
            if d['conc_lbl']: d['conc_lbl'].config(bg=PNL)
            d['dot'].config(fg=BRD); d['name'].config(fg=DIM)
            d['count'].config(fg=DIM,text=f"{d['events']} events")
            if d['conc_lbl']: d['conc_lbl'].config(fg=DIM,text='')
            if d['rec_bar']:  d['rec_bar']['value']=0
            if d.get('rec_msg'): d['rec_msg'].config(text='0%',fg=C_REC,bg=PNL)
            if d.get('ready_msg'): d['ready_msg'].config(text='',bg=PNL)
            d['_bg_now']=PNL

    def _highlight_flag(self,fval):
        self._stop_flash(); self._stop_ready_flash()
        self._reset_flag_boxes()
        d=self.flag_boxes.get(fval)
        if not d: return
        col=d['col']; bg2=d['bg']
